---
/* ============================================================
   SISTEMA GOLEIRO DE ELITE™ — Quiz interativo de qualificação
   Abertura = hero original da landing + botão INICIAR.
   5 perguntas → bridge → pitch (pilares/entregáveis/provas)
   → diagnóstico personalizado → CTA de WhatsApp (tintim).
   O link tintim varia por página (base / julio / lucas) e
   chega via prop `whatsapp`.
============================================================ */
import Base from '../layouts/Base.astro';

interface Props {
  whatsapp: string;
}
const { whatsapp } = Astro.props;

const CTA = 'FALE COM NOSSA EQUIPE AGORA';

// 5 Pilares
const pilares = [
  { n: '01', t: 'Especificidade Aplicada™',         d: 'Seu treino é construído para as exigências reais da posição.' },
  { n: '02', t: 'Individualização Estratégica™',     d: 'Sua idade, rotina, histórico, corpo e objetivos são levados em consideração.' },
  { n: '03', t: 'Transferência Para o Jogo™',        d: 'Cada exercício precisa gerar resultado dentro do gol.' },
  { n: '04', t: 'Progressão de Performance™',        d: 'Força. Mobilidade. Potência. Explosão. Velocidade. Cada etapa prepara a próxima.' },
  { n: '05', t: 'Desenvolvimento Integral do Goleiro™', d: 'Mais confiança, mais resistência, menos dores, mais desempenho e mais longevidade.' },
];

// Provas sociais (prints) — carrossel no pitch
const provas = [
  { src: '/images/prova-compra.webp',        w: 942,  h: 1580, alt: 'Print de aluno: "foi a minha melhor compra"' },
  { src: '/images/prova-antesdepois-1.webp', w: 1080, h: 1080, alt: 'Antes e depois de aluno do Sistema Goleiro de Elite' },
  { src: '/images/prova-wagner.webp',        w: 730,  h: 1580, alt: 'Depoimento do aluno Wagner' },
  { src: '/images/prova-antesdepois-2.webp', w: 1080, h: 1149, alt: 'Evolução física de aluno' },
  { src: '/images/prova-crianca.webp',       w: 730,  h: 1580, alt: 'Depoimento de aluno da categoria de base' },
  { src: '/images/prova-antesdepois-3.webp', w: 711,  h: 1580, alt: 'Antes e depois de aluno' },
  { src: '/images/prova-msg.webp',           w: 711,  h: 1580, alt: 'Mensagem de aluno satisfeito' },
];

// Ícones SVG (linha, monocromáticos — herdam o dourado)
const ICON = {
  plano: '<rect width="8" height="4" x="8" y="2" rx="1"/><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><path d="M12 11h4"/><path d="M12 16h4"/><path d="M8 11h.01"/><path d="M8 16h.01"/>',
  app: '<rect width="14" height="20" x="5" y="2" rx="2"/><path d="M12 18h.01"/>',
  evolucao: '<polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/>',
  local: '<path d="M14.4 14.4 9.6 9.6"/><path d="m21.5 21.5-1.4-1.4"/><path d="M3.9 3.9 2.5 2.5"/><path d="M6.4 12.8a2 2 0 1 1-2.83-2.83l1.77-1.77a2 2 0 1 1-2.83-2.82l2.83-2.83a2 2 0 1 1 2.83 2.83l1.76-1.77a2 2 0 1 1 2.83 2.83z"/><path d="M18.66 21.49a2 2 0 1 1-2.83-2.83l-1.77 1.77a2 2 0 1 1-2.83-2.83l6.37-6.36a2 2 0 1 1 2.82 2.82l-1.76 1.77a2 2 0 1 1 2.83 2.83z"/>',
  nutri: '<path d="M12 20.94c1.5 0 2.75 1.06 4 1.06 3 0 6-8 6-12.22A4.91 4.91 0 0 0 17 5c-2.22 0-4 1.44-5 2-1-.56-2.78-2-5-2a4.9 4.9 0 0 0-5 4.78C2 14 5 22 8 22c1.25 0 2.5-1.06 4-1.06Z"/><path d="M10 2c1 .5 2 2 2 5"/>',
  pre: '<path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.07-2.14-.22-4.05 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.15.43-2.29 1-3a2.5 2.5 0 0 0 2.5 2.5z"/>',
  pos: '<line x1="2" x2="22" y1="12" y2="12"/><line x1="12" x2="12" y1="2" y2="22"/><path d="m20 16-4-4 4-4"/><path d="m4 8 4 4-4 4"/><path d="m16 4-4 4-4-4"/><path d="m8 20 4-4 4 4"/>',
  chat: '<path d="M7.9 20A9 9 0 1 0 4 16.1L2 22Z"/>',
};

// O que você recebe
const entregaveis = [
  { icon: ICON.plano,    t: 'Plano de Treino Personalizado', d: 'Construído para a sua realidade.' },
  { icon: ICON.app,      t: 'Aplicativo de Treinos',         d: 'Você abre e executa. Sem dúvidas. Sem improviso.' },
  { icon: ICON.evolucao, t: 'Evolução Contínua',             d: 'Seu treino evolui conforme você evolui.' },
  { icon: ICON.local,    t: 'Treino para Casa ou Academia',  d: 'Adaptado à estrutura que você possui.' },
  { icon: ICON.nutri,    t: 'Guia Nutricional',              d: 'Para melhorar recuperação, composição corporal e desempenho.' },
  { icon: ICON.pre,      t: 'Protocolo Pré-Jogo',            d: 'Prepare seu corpo para competir.' },
  { icon: ICON.pos,      t: 'Protocolo Pós-Jogo',            d: 'Recupere melhor e continue evoluindo.' },
  { icon: ICON.chat,     t: 'Suporte Direto Pelo WhatsApp',  d: 'Acompanhamento, ajustes, adaptações e direção.' },
];
---

<Base
  title="Sistema Goleiro de Elite™ | Preparação Física Específica para Goleiros"
  heroImage="/images/goleiro_de_elite_hero.webp"
>
  <!-- Tintim pixel -->
  <script is:inline>
    (function(window, document, script) {
      if (!window.tt) {
        window.tt = window.tt || {};
        c = document.getElementsByTagName('head')[0];
        k = document.createElement('script');
        k.async = 1;
        k.src = script;
        c.appendChild(k);
      }
      window.tt.accountCode = '41d4c19b-ee85-4cc2-993e-32f0e7d2c0f8';
    })(window, document, '//s.tintim.app/static/core/tintim-1.0.js');
  </script>

  <main class="sge">

    <!-- ============================================================
         ABERTURA — HERO ORIGINAL DA LANDING + BOTÃO INICIAR
    ============================================================ -->
    <section class="sge-hero" id="quiz-hero">
      <!-- Banner do programa (substitui o texto eyebrow) -->
      <div class="sge-hero-media">
        <img
          src="/images/goleiro_de_elite_hero.webp"
          alt="Sistema Goleiro de Elite — preparação física específica para goleiros"
          width="1536" height="1024"
          fetchpriority="high" decoding="async"
          class="sge-hero-img"
        />
        <div class="sge-hero-fade"></div>
      </div>
      <div class="sge-hero-inner">
        <h1 class="sge-hero-h1">
          Descubra o método que já ajudou mais de <span class="sge-hl">2.000 goleiros</span> a transformar sua preparação física em desempenho real dentro do gol.
        </h1>
        <p class="sge-hero-sub">
          Um planejamento criado para quem quer jogar com mais confiança, explosão e desempenho.
        </p>
        <!-- Botão que dá início ao quiz — acima dos números para caber na primeira dobra -->
        <button type="button" class="sge-cta sge-cta--start" id="quiz-start">
          <span>INICIAR</span>
          <svg viewBox="0 0 24 24" aria-hidden="true" class="sge-start-arrow" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </button>
        <p class="sge-micro sge-start-micro">Leva menos de 1 minuto · 5 perguntas rápidas</p>

        <div class="sge-hero-stats">
          <div><strong class="sge-count" data-to="2000" data-prefix="+">+2.000</strong><span>goleiros</span></div>
          <i></i>
          <div><strong class="sge-count" data-to="3" data-prefix="+" data-suffix=" anos">+3 anos</strong><span>de método</span></div>
          <i></i>
          <div><strong class="sge-count" data-to="100" data-suffix="%">100%</strong><span>online</span></div>
        </div>

        <noscript>
          <a href={whatsapp} target="_blank" rel="noopener" class="sge-cta">{CTA}</a>
        </noscript>
      </div>
    </section>

    <!-- ============================================================
         QUIZ — card com steps (oculto até o INICIAR)
    ============================================================ -->
    <section class="sge-quiz-sec" id="quiz-sec" style="display:none">
      <div class="sge-quiz-brand">
        <span class="sge-quiz-logo">Sistema Goleiro de Elite™</span>
        <span class="sge-quiz-logo-sub">Avaliação gratuita de perfil</span>
      </div>

      <div class="sge-card" id="quiz-card">

        <!-- Barra de progresso (visível nos steps 1–5) -->
        <div class="prog-row" id="prog-row">
          <div class="prog-track">
            <div class="prog-fill" id="prog-fill"></div>
          </div>
          <div class="prog-label"><span id="prog-current">1</span> / 5</div>
        </div>

        <!-- ══════════════════════════════════════════════
             STEP 1 — Perfil
        ══════════════════════════════════════════════ -->
        <div class="step" id="step-1" style="display:none">
          <div class="q-num">// 01 — Perfil</div>
          <div class="q-text">Você está aqui para...</div>
          <div class="options">
            <button type="button" class="opt" data-step="1" data-v="amador">
              <span class="opt-ico">🥅</span>
              <span class="opt-label">Mim mesmo — sou goleiro amador</span>
            </button>
            <button type="button" class="opt" data-step="1" data-v="profissional">
              <span class="opt-ico">⭐</span>
              <span class="opt-label">Mim mesmo — jogo em clube ou categoria de base</span>
            </button>
            <button type="button" class="opt" data-step="1" data-v="mae_pai">
              <span class="opt-ico">👨‍👩‍👦</span>
              <span class="opt-label">Meu filho — quero melhorar o desempenho dele</span>
            </button>
          </div>
        </div>

        <!-- ══════════════════════════════════════════════
             STEP 2 — Dificuldade (gancho: "dava para ter pego")
        ══════════════════════════════════════════════ -->
        <div class="step" id="step-2" style="display:none">
          <div class="q-num">// 02 — Dificuldade</div>
          <div class="q-text"
            data-voce="Todo goleiro tem aquela bola que “dava para ter pego”. O que mais te segura hoje dentro do gol?"
            data-filho="Todo goleiro tem aquela bola que “dava para ter pego”. O que mais segura o seu filho dentro do gol?">
            Todo goleiro tem aquela bola que “dava para ter pego”. O que mais te segura hoje dentro do gol?
          </div>
          <div class="options">
            <button type="button" class="opt" data-step="2" data-v="explosao">
              <span class="opt-ico">⚡</span>
              <span class="opt-label"
                data-voce="Falta de explosão e velocidade de reação"
                data-filho="Falta de explosão e velocidade de reação">
                Falta de explosão e velocidade de reação
              </span>
            </button>
            <button type="button" class="opt" data-step="2" data-v="duelos">
              <span class="opt-ico">💪</span>
              <span class="opt-label"
                data-voce="Perco os duelos aéreos com frequência"
                data-filho="Perde os duelos aéreos com frequência">
                Perco os duelos aéreos com frequência
              </span>
            </button>
            <button type="button" class="opt" data-step="2" data-v="lesoes">
              <span class="opt-ico">🤕</span>
              <span class="opt-label"
                data-voce="Sofro lesões ou dores com frequência"
                data-filho="Sofre lesões ou dores com frequência">
                Sofro lesões ou dores com frequência
              </span>
            </button>
            <button type="button" class="opt" data-step="2" data-v="sem_resultado">
              <span class="opt-ico">🎯</span>
              <span class="opt-label"
                data-voce="Treino, mas não vejo resultado dentro do gol"
                data-filho="Treina, mas não vê resultado dentro do gol">
                Treino, mas não vejo resultado dentro do gol
              </span>
            </button>
          </div>
        </div>

        <!-- ══════════════════════════════════════════════
             STEP 3 — Tentativas
        ══════════════════════════════════════════════ -->
        <div class="step" id="step-3" style="display:none">
          <div class="q-num">// 03 — Tentativas</div>
          <div class="q-text"
            data-voce="O que você já tentou para resolver isso?"
            data-filho="O que você já tentou para resolver isso com ele?">
            O que você já tentou para resolver isso?
          </div>
          <div class="options">
            <button type="button" class="opt" data-step="3" data-v="academia">
              <span class="opt-ico">🏋️</span>
              <span class="opt-label"
                data-voce="Musculação genérica, sem programa para goleiro"
                data-filho="Academia com treino genérico, sem programa para goleiro">
                Musculação genérica, sem programa para goleiro
              </span>
            </button>
            <button type="button" class="opt" data-step="3" data-v="tecnico">
              <span class="opt-ico">📋</span>
              <span class="opt-label"
                data-voce="Pedi ajuda ao instrutor / técnico"
                data-filho="Pediu ajuda ao instrutor / técnico do clube">
                Pedi ajuda ao instrutor / técnico
              </span>
            </button>
            <button type="button" class="opt" data-step="3" data-v="online">
              <span class="opt-ico">📱</span>
              <span class="opt-label"
                data-voce="Vídeos e conteúdo na internet"
                data-filho="Vídeos e conteúdo na internet">
                Vídeos e conteúdo na internet
              </span>
            </button>
            <button type="button" class="opt" data-step="3" data-v="nada">
              <span class="opt-ico">🚫</span>
              <span class="opt-label"
                data-voce="Nada estruturado até agora"
                data-filho="Nada estruturado até agora">
                Nada estruturado até agora
              </span>
            </button>
          </div>
          <p class="q-note">Treino genérico cria goleiro cansado. Não necessariamente melhor.</p>
        </div>

        <!-- ══════════════════════════════════════════════
             STEP 4 — Obstáculo
        ══════════════════════════════════════════════ -->
        <div class="step" id="step-4" style="display:none">
          <div class="q-num">// 04 — Obstáculo</div>
          <div class="q-text"
            data-voce="O que te impede de resolver isso de vez?"
            data-filho="O que impede de resolver isso de vez para ele?">
            O que te impede de resolver isso de vez?
          </div>
          <div class="options">
            <button type="button" class="opt" data-step="4" data-v="onde_comecar">
              <span class="opt-ico">🔍</span>
              <span class="opt-label"
                data-voce="Não sei o que treinar para a posição"
                data-filho="Não sabe o que treinar para a posição">
                Não sei o que treinar para a posição
              </span>
            </button>
            <button type="button" class="opt" data-step="4" data-v="sem_transferencia">
              <span class="opt-ico">😓</span>
              <span class="opt-label"
                data-voce="Já tentei, mas não aparece no jogo"
                data-filho="Já tentou, mas não aparece no jogo">
                Já tentei, mas não aparece no jogo
              </span>
            </button>
            <button type="button" class="opt" data-step="4" data-v="tempo">
              <span class="opt-ico">⏰</span>
              <span class="opt-label"
                data-voce="Falta de tempo e rotina para treinar"
                data-filho="Falta de tempo e rotina para treinar">
                Falta de tempo e rotina para treinar
              </span>
            </button>
            <button type="button" class="opt" data-step="4" data-v="acompanhamento">
              <span class="opt-ico">🧭</span>
              <span class="opt-label"
                data-voce="Falta de acompanhamento individual"
                data-filho="Falta de acompanhamento individual">
                Falta de acompanhamento individual
              </span>
            </button>
          </div>
        </div>

        <!-- ══════════════════════════════════════════════
             STEP 5 — Resultado almejado
        ══════════════════════════════════════════════ -->
        <div class="step" id="step-5" style="display:none">
          <div class="q-num">// 05 — Resultado</div>
          <div class="q-text"
            data-voce="Qual resultado você quer alcançar como goleiro?"
            data-filho="Qual resultado você quer para o seu filho?">
            Qual resultado você quer alcançar como goleiro?
          </div>
          <div class="options">
            <button type="button" class="opt" data-step="5" data-v="explosao">
              <span class="opt-ico">⚡</span>
              <span class="opt-label"
                data-voce="Mais explosão e velocidade de reação"
                data-filho="Mais explosão e velocidade de reação">
                Mais explosão e velocidade de reação
              </span>
            </button>
            <button type="button" class="opt" data-step="5" data-v="duelos">
              <span class="opt-ico">💪</span>
              <span class="opt-label"
                data-voce="Dominar os duelos aéreos"
                data-filho="Dominar os duelos aéreos">
                Dominar os duelos aéreos
              </span>
            </button>
            <button type="button" class="opt" data-step="5" data-v="longevidade">
              <span class="opt-ico">🛡️</span>
              <span class="opt-label"
                data-voce="Menos lesões e mais longevidade no gol"
                data-filho="Menos lesões e mais longevidade no gol">
                Menos lesões e mais longevidade no gol
              </span>
            </button>
            <button type="button" class="opt" data-step="5" data-v="nivel">
              <span class="opt-ico">📈</span>
              <span class="opt-label"
                data-voce="Subir de nível e me destacar"
                data-filho="Subir de nível e se destacar">
                Subir de nível e me destacar
              </span>
            </button>
          </div>
        </div>

        <!-- ══════════════════════════════════════════════
             BRIDGE — decisão
        ══════════════════════════════════════════════ -->
        <div class="step step--bridge" id="step-bridge" style="display:none">
          <div class="bridge-eyebrow">Antes de continuar</div>
          <div class="bridge-title" id="bridge-title">
            Se existisse um plano construído para esse resultado,<br />você toparia conhecer como funciona?
          </div>
          <div class="bridge-btns">
            <button type="button" class="bridge-yes" id="bridge-yes">✅ Sim, quero conhecer</button>
            <button type="button" class="bridge-no" id="bridge-no">Agora não é o meu momento</button>
          </div>
          <div class="nurturing" id="nurturing" style="display:none">
            <p>Tudo bem — quando o momento chegar, estaremos por aqui. Guarde esta página e volte quando fizer sentido para você.</p>
            <a href="https://instagram.com/goleirodeeliteof" target="_blank" rel="noopener" class="nurturing-link">Enquanto isso, acompanhe a gente no Instagram →</a>
          </div>
        </div>

        <!-- ══════════════════════════════════════════════
             PITCH — o Sistema Goleiro de Elite™ em versão compacta
        ══════════════════════════════════════════════ -->
        <div class="step step--pitch" id="step-pitch" style="display:none">
          <div class="pitch-badge">🧤 Sistema Goleiro de Elite™</div>
          <div class="pitch-title" id="pitch-title">O que o programa faz por você</div>
          <p class="pitch-intro">
            Uma metodologia construída ao longo de mais de 3 anos e aplicada em mais de 2.000 goleiros —
            para transformar treino em <strong>desempenho real dentro do gol</strong>.
          </p>

          <div class="pitch-sub">Os 5 pilares</div>
          <div class="pitch-pillars">
            {pilares.map((p) => (
              <div class="pitch-pillar">
                <span class="pitch-pillar-n" aria-hidden="true">{p.n}</span>
                <div>
                  <strong>{p.t}</strong>
                  <span>{p.d}</span>
                </div>
              </div>
            ))}
          </div>

          <div class="pitch-sub">O que você recebe</div>
          <div class="sge-deliv">
            {entregaveis.map((e) => (
              <article class="sge-deliv-card">
                <div class="sge-deliv-i" aria-hidden="true">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" set:html={e.icon}></svg>
                </div>
                <h3 class="sge-deliv-t">{e.t}</h3>
                <p class="sge-deliv-d">{e.d}</p>
              </article>
            ))}
          </div>

          <div class="pitch-sub">Quem já passou pelo sistema</div>
          <div class="sge-carousel-wrap">
            <button type="button" class="sge-car-arrow sge-car-arrow--prev" data-dir="-1" aria-label="Ver anterior">‹</button>
            <div class="sge-carousel" id="sge-provas">
              {provas.map((p) => (
                <figure class="sge-slide">
                  <img src={p.src} width={p.w} height={p.h} alt={p.alt} loading="lazy" decoding="async" />
                </figure>
              ))}
            </div>
            <button type="button" class="sge-car-arrow sge-car-arrow--next" data-dir="1" aria-label="Ver próximo">›</button>
          </div>
          <p class="sge-proof-note">Prints reais de conversas e evolução de alunos · arraste para ver mais →</p>

          <div class="pitch-stats">
            <div class="p-stat"><span class="p-n">+2.000</span><span class="p-l">Goleiros</span></div>
            <div class="p-div"></div>
            <div class="p-stat"><span class="p-n">+3 anos</span><span class="p-l">de Método</span></div>
            <div class="p-div"></div>
            <div class="p-stat"><span class="p-n">100%</span><span class="p-l">Online</span></div>
          </div>

          <button type="button" class="pitch-cta" id="pitch-cta">VER MEU DIAGNÓSTICO →</button>
        </div>

        <!-- ══════════════════════════════════════════════
             RESULTADO — diagnóstico + CTA WhatsApp
        ══════════════════════════════════════════════ -->
        <div class="step step--result" id="step-result" style="display:none">
          <div class="q-num">// Seu diagnóstico</div>
          <div class="result-title" id="result-title">Seu diagnóstico está pronto.</div>
          <p class="result-body" id="result-body"></p>

          <div class="sge-cta-box">
            <p class="sge-final-q"
              data-voce="Quer um plano construído para a sua realidade?"
              data-filho="Quer um plano construído para a realidade do seu filho?">
              Quer um plano construído para a sua realidade?
            </p>
            <a href={whatsapp} target="_blank" rel="noopener" class="sge-cta sge-cta--final" data-cta>
