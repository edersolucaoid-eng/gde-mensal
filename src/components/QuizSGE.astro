<style>
  /* ── PALETA — chumbo/preto + dourado elite + verde whatsapp ── */
  .sge {
    --bg:    #000000;
    --bg2:   #0d0f12;
    --card:  #14171c;
    --card2: #181c22;
    --border:#252a32;
    --gold:  #e8b95a;
    --gold-d:#c79a3e;
    --white: #f3f5f7;
    --gray:  #9aa1ab;
    --muted: #5d646e;
    --green: #25d366;
    --red:   #c0563f;

    position: relative;
    z-index: 1;
    width: 100%;
    min-height: 100vh;
    background: var(--bg);
    color: var(--white);
    font-family: 'Barlow', system-ui, sans-serif;
    overflow-x: hidden;
  }
  .sge * { box-sizing: border-box; }

  /* ── HERO (abertura do quiz — idêntico à landing) ── */
  .sge-hero {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 0 20px 56px;
    overflow: hidden;
  }
  .sge-hero-media {
    position: relative;
    width: calc(100% + 40px);
    margin: 0 -20px;
    max-width: 920px;
  }
  .sge-hero-img {
    width: 100%; height: auto; display: block;
    animation: sgeUp .8s ease both;
  }
  .sge-hero-fade {
    position: absolute; left: 0; right: 0; bottom: -1px;
    height: 38%;
    background: linear-gradient(180deg, transparent 0%, rgba(8,9,11,.55) 55%, var(--bg) 100%);
    pointer-events: none;
  }
  .sge-hero-inner {
    position: relative; z-index: 2;
    max-width: 760px;
    margin-top: -42px;
    display: flex; flex-direction: column; align-items: center;
  }
  .sge-hero-h1   { animation: sgeUp .7s .15s ease both; }
  .sge-hero-sub  { animation: sgeUp .7s .32s ease both; }
  .sge-cta--start{ animation: sgeUp .7s .46s ease both, sgeGlow 2.4s ease-in-out infinite; }
  .sge-start-micro{ animation: sgeUp .7s .58s ease both; }
  .sge-hero-stats{ animation: sgeUp .7s .7s ease both; }
  .sge-hero-h1 {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 800;
    font-size: clamp(2rem, 7vw, 3.6rem);
    line-height: 1.04;
    letter-spacing: -.01em;
    text-transform: uppercase;
    margin-bottom: 22px;
  }
  .sge-hl { color: var(--gold); }
  .sge-hero-sub {
    font-size: clamp(1rem, 2.4vw, 1.18rem);
    line-height: 1.55;
    color: var(--gray);
    max-width: 620px;
    margin-bottom: 0;
  }
  .sge-hero-stats {
    display: flex; align-items: center; gap: 18px;
    margin-top: 30px;
  }
  .sge-hero-stats > div { display: flex; flex-direction: column; }
  .sge-hero-stats strong {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1.9rem; line-height: 1; color: var(--white);
  }
  .sge-hero-stats span {
    font-size: .72rem; text-transform: uppercase; letter-spacing: .12em; color: var(--muted);
  }
  .sge-hero-stats i { width: 1px; height: 30px; background: var(--border); }

  /* ── CTA principal (verde WhatsApp da landing) ── */
  .sge-cta {
    position: relative;
    overflow: hidden;
    display: inline-flex; align-items: center; justify-content: center; gap: 12px;
    background: linear-gradient(180deg, #2ee572 0%, var(--green) 55%, #1fc35b 100%);
    color: #04220f;
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 800;
    font-size: clamp(.98rem, 2.7vw, 1.2rem);
    text-transform: uppercase;
    letter-spacing: .02em;
    text-decoration: none;
    border: none;
    cursor: pointer;
    padding: 19px 32px;
    border-radius: 14px;
    line-height: 1.1;
    box-shadow: 0 10px 34px rgba(37,211,102,.32);
    transition: transform .18s ease, box-shadow .18s ease, filter .18s ease;
    animation: sgeGlow 2.4s ease-in-out infinite;
  }
  .sge-cta::before {
    content: '';
    position: absolute; top: 0; bottom: 0; left: -80%;
    width: 55%;
    background: linear-gradient(120deg, transparent, rgba(255,255,255,.55), transparent);
    transform: skewX(-22deg);
    animation: sgeShine 3.4s ease-in-out infinite;
    pointer-events: none;
  }
  .sge-cta > * { position: relative; z-index: 1; }
  .sge-cta:hover { transform: translateY(-3px) scale(1.015); box-shadow: 0 18px 50px rgba(37,211,102,.5); filter: brightness(1.05); }
  .sge-cta:active { transform: translateY(-1px) scale(.99); }
  .sge-cta--final { width: 100%; max-width: 560px; margin: 6px auto 0; }
  .sge-cta--start {
    margin-top: 24px;
    min-width: min(100%, 320px);
    font-size: clamp(1.15rem, 3.4vw, 1.4rem);
    letter-spacing: .1em;
  }
  .sge-start-arrow { width: 22px; height: 22px; flex-shrink: 0; }
  .sge-start-micro { margin-top: 12px; }
  .sge-wa-ico { width: 24px; height: 24px; fill: #04220f; flex-shrink: 0; }
  @keyframes sgeGlow {
    0%,100% { box-shadow: 0 10px 34px rgba(37,211,102,.3); }
    50%     { box-shadow: 0 12px 40px rgba(37,211,102,.42), 0 0 0 6px rgba(37,211,102,.08); }
  }
  @keyframes sgeShine {
    0%      { left: -80%; }
    55%,100%{ left: 130%; }
  }

  .sge-micro { font-size: .9rem; color: var(--muted); margin-top: 16px; }

  /* ── SEÇÃO DO QUIZ ── */
  .sge-quiz-sec {
    max-width: 720px;
    margin: 0 auto;
    padding: 28px 16px 72px;
  }
  .sge-quiz-brand {
    display: flex; flex-direction: column; align-items: center; gap: 4px;
    text-align: center;
    margin-bottom: 20px;
  }
  .sge-quiz-logo {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1.35rem;
    letter-spacing: .14em;
    color: var(--gold);
  }
  .sge-quiz-logo-sub {
    font-family: 'JetBrains Mono', monospace;
    font-size: .6rem;
    font-weight: 700;
    letter-spacing: .2em;
    text-transform: uppercase;
    color: var(--muted);
  }

  .sge-card {
    position: relative;
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 20px;
    padding: 30px 24px 36px;
    overflow: hidden;
    box-shadow: 0 24px 60px rgba(0,0,0,.5), inset 0 1px 0 rgba(255,255,255,.04);
  }
  /* faixa de luz dourada no topo do card */
  .sge-card::before {
    content: '';
    position: absolute; top: 0; left: 50%; transform: translateX(-50%);
    width: 70%; height: 1px;
    background: linear-gradient(90deg, transparent, var(--gold), transparent);
    opacity: .7;
  }

  /* ── Progress ── */
  .prog-row {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 28px;
  }
  .prog-track {
    flex: 1;
    height: 3px;
    background: var(--border);
    border-radius: 99px;
    overflow: hidden;
  }
  .prog-fill {
    height: 100%;
    width: 0%;
    background: linear-gradient(90deg, var(--gold-d), var(--gold));
    border-radius: 99px;
    transition: width .5s cubic-bezier(.4,0,.2,1);
    box-shadow: 0 0 8px rgba(232,185,90,.5);
  }
  .prog-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: .65rem;
    color: var(--gray);
    white-space: nowrap;
  }
  .prog-label span { color: var(--gold); }

  /* ── Steps ── */
  .step { animation: fadeUp .35s ease both; }

  .q-num {
    font-family: 'JetBrains Mono', monospace;
    font-size: .68rem;
    font-weight: 700;
    color: var(--gold);
    letter-spacing: .18em;
    text-transform: uppercase;
    margin-bottom: 10px;
  }
  .q-text {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 800;
    text-transform: uppercase;
    font-size: clamp(1.35rem, 4.5vw, 1.8rem);
    line-height: 1.12;
    color: var(--white);
    margin-bottom: 20px;
  }
  .q-note {
    margin-top: 16px;
    font-size: .86rem;
    color: var(--muted);
    font-style: italic;
  }

  /* ── Options ── */
  .options { display: flex; flex-direction: column; gap: 8px; margin-top: 4px; }

  .opt {
    display: flex;
    align-items: center;
    gap: 12px;
    width: 100%;
    text-align: left;
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 15px 16px;
    cursor: pointer;
    transition: border-color .15s, background .15s, transform .1s;
    user-select: none;
    -webkit-tap-highlight-color: transparent;
    background: rgba(255,255,255,.02);
    color: var(--white);
    font-family: inherit;
  }
  .opt:hover { border-color: rgba(232,185,90,.4); background: rgba(232,185,90,.06); }
  .opt:active { transform: scale(.99); }
  .opt.selected { border-color: var(--gold); background: rgba(232,185,90,.1); }
  .opt.selected .opt-label { color: var(--gold); }

  .opt-ico { font-size: 1.15rem; flex-shrink: 0; }
  .opt-label {
    font-size: 1rem;
    font-weight: 600;
    color: var(--white);
    transition: color .15s;
    line-height: 1.3;
  }

  /* ── Bridge ── */
  .step--bridge { text-align: center; }
  .bridge-eyebrow {
    font-family: 'JetBrains Mono', monospace;
    font-size: .65rem;
    font-weight: 700;
    letter-spacing: .2em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 16px;
  }
  .bridge-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(1.5rem, 5vw, 2.1rem);
    line-height: 1.15;
    letter-spacing: .02em;
    color: var(--white);
    margin-bottom: 28px;
  }
  .bridge-title em { font-style: normal; color: var(--gold); }
  .bridge-btns { display: flex; flex-direction: column; gap: 10px; }
  .bridge-yes {
    width: 100%;
    padding: 18px 24px;
    background: linear-gradient(135deg, var(--gold), var(--gold-d));
    color: #1a1303;
    border: none;
    border-radius: 12px;
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1.25rem;
    letter-spacing: .08em;
    cursor: pointer;
    transition: filter .15s, transform .1s;
    box-shadow: 0 6px 32px rgba(232,185,90,.3);
  }
  .bridge-yes:hover { filter: brightness(1.08); transform: translateY(-2px); }
  .bridge-no {
    background: none;
    border: none;
    color: var(--muted);
    font-family: 'JetBrains Mono', monospace;
    font-size: .72rem;
    letter-spacing: .06em;
    cursor: pointer;
    padding: 8px;
    transition: color .15s;
  }
  .bridge-no:hover { color: var(--gray); }

  .nurturing {
    margin-top: 20px;
    padding: 16px;
    border: 1px solid var(--border);
    border-radius: 12px;
    background: rgba(255,255,255,.03);
    animation: fadeUp .3s ease;
  }
  .nurturing p {
    font-size: .9rem;
    color: var(--gray);
    line-height: 1.6;
    margin-bottom: 10px;
  }
  .nurturing-link {
    font-family: 'JetBrains Mono', monospace;
    font-size: .72rem;
    color: var(--gold);
    letter-spacing: .06em;
    text-decoration: none;
  }
  .nurturing-link:hover { text-decoration: underline; }

  /* ── Pitch ── */
  .step--pitch { text-align: center; }
  .pitch-badge {
    font-family: 'JetBrains Mono', monospace;
    font-size: .65rem;
    font-weight: 700;
    letter-spacing: .15em;
    text-transform: uppercase;
    color: #1a1303;
    background: linear-gradient(135deg, var(--gold), var(--gold-d));
    display: inline-block;
    padding: 5px 14px;
    border-radius: 99px;
    margin-bottom: 14px;
  }
  .pitch-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(1.5rem, 5vw, 2rem);
    line-height: 1.15;
    letter-spacing: .02em;
    color: var(--white);
    margin-bottom: 12px;
  }
  .pitch-intro {
    font-size: .96rem;
    color: var(--gray);
    line-height: 1.6;
    max-width: 480px;
    margin: 0 auto 24px;
  }
  .pitch-intro strong { color: var(--gold); }
  .pitch-sub {
    font-family: 'JetBrains Mono', monospace;
    font-size: .65rem;
    font-weight: 700;
    letter-spacing: .2em;
    text-transform: uppercase;
    color: var(--gold);
    margin: 26px 0 12px;
    text-align: left;
  }
  .pitch-sub::before { content: '// '; color: var(--muted); }

  .pitch-pillars { display: flex; flex-direction: column; gap: 8px; text-align: left; }
  .pitch-pillar {
    display: flex;
    gap: 14px;
    align-items: flex-start;
    padding: 12px 14px;
    border: 1px solid var(--border);
    border-left: 3px solid var(--gold);
    border-radius: 10px;
    background: rgba(255,255,255,.02);
  }
  .pitch-pillar-n {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1.5rem;
    line-height: 1;
    color: transparent;
    -webkit-text-stroke: 1.2px rgba(232,185,90,.5);
    flex-shrink: 0;
    margin-top: 2px;
  }
  .pitch-pillar div {
    display: flex; flex-direction: column; gap: 2px;
    font-size: .88rem;
    color: var(--gray);
    line-height: 1.5;
  }
  .pitch-pillar strong {
    color: var(--white);
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 700;
    text-transform: uppercase;
    font-size: 1.02rem;
  }

  /* entregáveis (grid compacto no card) */
  .sge-deliv {
    display: grid; gap: 10px;
    grid-template-columns: 1fr 1fr;
    text-align: left;
  }
  .sge-deliv-card {
    background: rgba(255,255,255,.02);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 14px 12px;
  }
  .sge-deliv-i {
    width: 38px; height: 38px;
    display: grid; place-items: center;
    margin-bottom: 10px;
    border-radius: 10px;
    color: var(--gold);
    background: rgba(232,185,90,.08);
    border: 1px solid rgba(232,185,90,.2);
  }
  .sge-deliv-i svg { width: 20px; height: 20px; }
  .sge-deliv-t {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 700; text-transform: uppercase;
    font-size: .96rem; line-height: 1.1; margin-bottom: 4px;
    color: var(--white);
  }
  .sge-deliv-d { font-size: .8rem; line-height: 1.4; color: var(--gray); }

  /* carrossel de provas */
  .sge-carousel-wrap { position: relative; }
  .sge-carousel {
    display: flex; gap: 12px;
    align-items: center;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    padding: 4px 2px 12px;
    scrollbar-width: none;
  }
  .sge-carousel::-webkit-scrollbar { display: none; }
  .sge-slide {
    flex: 0 0 auto;
    scroll-snap-align: center;
    width: min(72vw, 280px);
    margin: 0;
    border: 1px solid var(--border);
    border-radius: 14px;
    background: var(--bg2);
    overflow: hidden;
  }
  .sge-slide img { width: 100%; height: auto; display: block; }
  .sge-car-arrow {
    position: absolute; top: 50%; transform: translateY(-50%);
    z-index: 3;
    width: 40px; height: 40px; border-radius: 50%;
    background: rgba(13,15,18,.92); border: 1px solid var(--border);
    color: var(--gold); font-size: 1.6rem; line-height: 1;
    cursor: pointer; display: none;
    align-items: center; justify-content: center;
    transition: border-color .15s, background .15s;
  }
  .sge-car-arrow:hover { border-color: var(--gold); background: var(--card2); }
  .sge-car-arrow--prev { left: -8px; }
  .sge-car-arrow--next { right: -8px; }
  .sge-proof-note { font-size: .78rem; color: var(--muted); text-align: center; margin-top: 8px; }

  @media (min-width: 720px) {
    .sge-car-arrow { display: flex; }
  }

  .pitch-stats {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 0;
    border: 1px solid var(--border);
    border-radius: 12px;
    background: rgba(255,255,255,.02);
    overflow: hidden;
    margin: 26px 0 22px;
  }
  .p-stat {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
    padding: 14px 8px;
  }
  .p-n {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1.3rem;
    color: var(--gold);
    letter-spacing: .04em;
  }
  .p-l {
    font-family: 'JetBrains Mono', monospace;
    font-size: .5rem;
    color: var(--muted);
    letter-spacing: .12em;
    text-transform: uppercase;
  }
  .p-div { width: 1px; height: 36px; background: var(--border); }

  .pitch-cta {
    width: 100%;
    padding: 17px 24px;
    background: linear-gradient(135deg, var(--gold), var(--gold-d));
    border: none;
    color: #1a1303;
    border-radius: 12px;
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1.25rem;
    letter-spacing: .08em;
    cursor: pointer;
    transition: filter .15s, transform .1s;
    box-shadow: 0 6px 32px rgba(232,185,90,.3);
  }
  .pitch-cta:hover { filter: brightness(1.08); transform: translateY(-2px); }

  /* ── Resultado ── */
  .step--result { text-align: center; }
  .step--result .q-num { text-align: left; }
  .result-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(1.7rem, 6vw, 2.4rem);
    line-height: 1.05;
    letter-spacing: .02em;
    color: var(--white);
    margin-bottom: 14px;
    text-align: left;
  }
  .result-body {
    font-size: 1.02rem;
    color: var(--gray);
    line-height: 1.65;
    margin-bottom: 26px;
    text-align: left;
  }
  .result-body strong { color: var(--gold); }

  /* painel destacado do CTA final */
  .sge-cta-box {
    position: relative;
    padding: 30px 22px 26px;
    border-radius: 18px;
    border: 1px solid rgba(232,185,90,.28);
    background:
      radial-gradient(120% 100% at 50% 0%, rgba(37,211,102,.10), transparent 60%),
      linear-gradient(180deg, #11140f 0%, #0a0c0a 100%);
    box-shadow: 0 24px 60px rgba(0,0,0,.5), inset 0 1px 0 rgba(255,255,255,.04);
    overflow: hidden;
  }
  .sge-cta-box::before {
    content: '';
    position: absolute; top: 0; left: 50%; transform: translateX(-50%);
    width: 70%; height: 1px;
    background: linear-gradient(90deg, transparent, var(--gold), transparent);
    opacity: .7;
  }
  .sge-final-q {
    font-family: 'Bebas Neue', sans-serif;
    font-weight: 400; text-transform: uppercase;
    font-size: clamp(1.6rem, 5.5vw, 2.3rem);
    line-height: .98;
    letter-spacing: .01em;
    color: var(--white);
    margin: 0 auto 22px;
    max-width: 480px;
  }

  /* ── QUEM SOMOS ── */
  .sge-h2 {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 800;
    font-size: clamp(1.6rem, 5vw, 2.5rem);
    line-height: 1.08;
    text-transform: uppercase;
    margin-bottom: 18px;
  }
  .sge-whoweare {
    max-width: 760px;
    margin: 0 auto;
    padding: 52px 0 0;
    text-align: center;
    background: #000;
  }
  .sge-whoweare::before {
    content: '';
    display: block;
    width: 64px; height: 3px;
    margin: 0 auto 26px;
    border-radius: 3px;
    background: linear-gradient(90deg, var(--gold-d), var(--gold));
  }
  .sge-whoweare-kicker {
    display: inline-block;
    font-family: 'JetBrains Mono', monospace;
    font-size: .7rem; font-weight: 700;
    letter-spacing: .24em; text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 10px;
  }
  .sge-whoweare-title { padding: 0 20px; margin-bottom: 26px; }
  .sge-whoweare-img {
    width: 100%;
    height: auto;
    display: block;
    margin: 0;
    border: 0;
    border-radius: 0;
    max-width: none;
  }

  /* ── RODAPÉ ── */
  .sge-footer {
    text-align: center;
    padding: 50px 20px 104px;
    background: #000;
  }
  .sge-foot-rule {
    width: 56px; height: 3px; border-radius: 3px;
    margin: 0 auto 24px;
    background: linear-gradient(90deg, var(--gold-d), var(--gold));
  }
  .sge-foot-brand {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 800; text-transform: uppercase; letter-spacing: .06em;
    color: var(--gold); font-size: 1.4rem; line-height: 1; margin-bottom: 22px;
  }
  .sge-foot-social {
    display: flex; justify-content: center; flex-wrap: wrap; gap: 12px;
    margin-bottom: 26px;
  }
  .sge-soc {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 9px 16px;
    border-radius: 100px;
    border: 1px solid var(--border);
    background: var(--card);
    color: var(--white);
    font-size: .86rem; font-weight: 600;
    text-decoration: none;
    transition: transform .15s ease, border-color .15s ease, background .15s ease;
  }
  .sge-soc svg { width: 16px; height: 16px; flex-shrink: 0; }
  .sge-soc:hover { transform: translateY(-2px); }
  .sge-soc--wa svg { fill: var(--green); }
  .sge-soc--wa:hover { border-color: var(--green); background: rgba(37,211,102,.08); }
  .sge-soc--ig svg { fill: #e1306c; }
  .sge-soc--ig:hover { border-color: #e1306c; background: rgba(225,48,108,.08); }
  .sge-foot-meta {
    font-family: 'JetBrains Mono', monospace;
    font-size: .72rem; letter-spacing: .06em;
    color: var(--muted); line-height: 1.6;
  }

  /* ── BOTÃO FLUTUANTE WHATSAPP ── */
  .sge-float {
    position: fixed; bottom: 22px; right: 18px; z-index: 998;
    width: 58px; height: 58px; border-radius: 50%;
    background: var(--green);
    display: flex; align-items: center; justify-content: center;
    box-shadow: 0 8px 28px rgba(37,211,102,.5);
    opacity: 0; transform: translateY(16px) scale(.8);
    transition: opacity .35s ease, transform .35s ease, background .15s;
    pointer-events: none;
  }
  .sge-float svg { width: 30px; height: 30px; fill: #fff; }
  .sge-float.is-visible { opacity: 1; transform: translateY(0) scale(1); pointer-events: auto; }
  .sge-float:hover { background: #1fbd57; transform: scale(1.08); }

  /* ── REVEAL ── */
  .reveal { opacity: 0; transform: translateY(26px); transition: opacity .6s ease, transform .6s ease; }
  .reveal.in { opacity: 1; transform: translateY(0); }

  @keyframes sgeUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }

  @media (max-width: 480px) {
    .sge-card { padding: 24px 16px 30px; }
    .sge-deliv { grid-template-columns: 1fr 1fr; }
  }

  @media (prefers-reduced-motion: reduce) {
    .sge-cta, .sge-cta::before { animation: none; }
    .sge-cta::before { display: none; }
    .sge-hero-img, .sge-hero-h1, .sge-hero-sub, .sge-hero-stats, .sge-cta--start, .sge-start-micro { animation: none; }
    .step { animation: none; }
    .reveal { transition: none; opacity: 1; transform: none; }
  }
</style>

<script>
  // ── Estado global ────────────────────────────────────────────────
  type Mode = 'voce' | 'filho';

  const state: { mode: Mode; answers: Record<number, string> } = {
    mode: 'voce',
    answers: {},
  };

  const TOTAL_STEPS = 5;

  const stepNames: Record<number, string> = {
    1: 'perfil', 2: 'dificuldade', 3: 'tentativas', 4: 'obstaculo', 5: 'resultado',
  };

  // Valor → label legível (bridge e diagnóstico)
  const resultadoLabels: Record<string, { voce: string; filho: string }> = {
    explosao:   { voce: 'mais explosão e velocidade de reação', filho: 'mais explosão e velocidade de reação' },
    duelos:     { voce: 'dominar os duelos aéreos',             filho: 'dominar os duelos aéreos' },
    longevidade:{ voce: 'menos lesões e mais longevidade no gol', filho: 'menos lesões e mais longevidade no gol' },
    nivel:      { voce: 'subir de nível e me destacar',         filho: 'subir de nível e se destacar' },
  };

  const dificuldadeLabels: Record<string, string> = {
    explosao:      'a falta de explosão e velocidade de reação',
    duelos:        'os duelos aéreos perdidos',
    lesoes:        'as lesões e dores frequentes',
    sem_resultado: 'o treino que não aparece dentro do gol',
  };

  // ── Helpers ──────────────────────────────────────────────────────
  function track(data: Record<string, unknown>) {
    (window as any).dataLayer = (window as any).dataLayer || [];
    (window as any).dataLayer.push(data);
  }

  function showStep(id: string) {
    document.querySelectorAll<HTMLElement>('.step').forEach(el => {
      el.style.display = 'none';
    });
    const target = document.getElementById(`step-${id}`);
    if (target) {
      target.style.display = '';
      target.style.animation = 'none';
      void target.offsetWidth; // reflow para reiniciar o fade
      target.style.animation = '';
    }
    document.getElementById('quiz-card')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
  }

  function updateProgress(step: number) {
    const fill = document.getElementById('prog-fill') as HTMLElement;
    const current = document.getElementById('prog-current') as HTMLElement;
    fill.style.width = `${(step / TOTAL_STEPS) * 100}%`;
    current.textContent = String(step);
  }

  function applyMode() {
    document.querySelectorAll<HTMLElement>('[data-voce]').forEach(el => {
      el.textContent = el.dataset[state.mode] ?? el.dataset.voce ?? '';
    });
  }

  // ── Abertura: INICIAR revela o quiz ──────────────────────────────
  document.getElementById('quiz-start')!.addEventListener('click', () => {
    track({ event: 'quiz_start', quiz_name: 'quiz_sge' });
    (document.getElementById('quiz-hero') as HTMLElement).style.display = 'none';
    (document.getElementById('quiz-sec') as HTMLElement).style.display = '';
    showStep('1');
    window.scrollTo({ top: 0 });
  });

  // ── Seleção de opções ────────────────────────────────────────────
  document.querySelectorAll<HTMLButtonElement>('.opt').forEach(opt => {
    opt.addEventListener('click', () => {
      const stepNum = parseInt(opt.dataset.step!);
      const val = opt.dataset.v!;

      // Marca visualmente
      document.querySelectorAll<HTMLElement>(`.opt[data-step="${stepNum}"]`)
        .forEach(o => o.classList.remove('selected'));
      opt.classList.add('selected');

      // Salva resposta
      state.answers[stepNum] = val;
      track({ event: 'quiz_step', quiz_name: 'quiz_sge', step: stepNum, step_name: stepNames[stepNum], answer: val });

      // Q1 define o modo (você / filho)
      if (stepNum === 1) {
        state.mode = val === 'mae_pai' ? 'filho' : 'voce';
        applyMode();
      }

      updateProgress(stepNum);

      // Avança após 320ms
      setTimeout(() => {
        if (stepNum < TOTAL_STEPS) {
          showStep(String(stepNum + 1));
        } else {
          // Monta texto dinâmico do bridge
          const resultado = state.answers[5] || '';
          const labels = resultadoLabels[resultado];
          const labelText = labels ? labels[state.mode] : 'esse resultado';
          const alvo = state.mode === 'filho' ? 'para o seu filho' : 'para você';
          document.getElementById('bridge-title')!.innerHTML =
            `Se existisse um plano construído ${alvo} — feito para <em>${labelText}</em> —,<br />você toparia conhecer como funciona?`;
          showStep('bridge');
          (document.getElementById('prog-row') as HTMLElement).style.display = 'none';
        }
      }, 320);
    });
  });

  // ── Bridge ───────────────────────────────────────────────────────
  document.getElementById('bridge-yes')!.addEventListener('click', () => {
    document.getElementById('pitch-title')!.textContent = state.mode === 'filho'
      ? 'O que o programa faz pelo seu filho'
      : 'O que o programa faz por você';
    showStep('pitch');
  });

  document.getElementById('bridge-no')!.addEventListener('click', () => {
    const nurturing = document.getElementById('nurturing')!;
    nurturing.style.display = '';
    nurturing.style.animation = 'none';
    void nurturing.offsetWidth;
    nurturing.style.animation = '';
  });

  // ── Pitch → Diagnóstico ─────────────────────────────────────────
  document.getElementById('pitch-cta')!.addEventListener('click', () => {
    renderResult();
    showStep('result');
    document.getElementById('sge-float')?.classList.add('is-visible');
    (document.getElementById('sge-whoweare') as HTMLElement).style.display = '';
    (document.getElementById('sge-footer') as HTMLElement).style.display = '';
    track({
      event: 'quiz_complete',
      quiz_name: 'quiz_sge',
      lead_perfil: state.answers[1],
      lead_dificuldade: state.answers[2],
      lead_resultado: state.answers[5],
    });
  });

  function renderResult() {
    const filho = state.mode === 'filho';
    const dificuldade = dificuldadeLabels[state.answers[2]] || 'a falta de um treino específico para a posição';
    const resultado = resultadoLabels[state.answers[5]];
    const objetivo = resultado ? resultado[state.mode] : 'evoluir dentro do gol';

    document.getElementById('result-title')!.textContent = filho
      ? 'O seu filho tem espaço claro para evoluir.'
      : 'Você tem espaço claro para evoluir.';

    document.getElementById('result-body')!.innerHTML =
      `Pelas suas respostas, o que está segurando ${filho ? 'a evolução do seu filho' : 'a sua evolução'} hoje é ` +
      `<strong>${dificuldade}</strong>. Isso não se resolve com treino genérico — se resolve com um plano específico ` +
      `para goleiro, construído para <strong>${objetivo}</strong>. É exatamente isso que a nossa equipe monta com você ` +
      `na consultoria.`;
  }

  // ── Clique nos CTAs de WhatsApp ─────────────────────────────────
  // Delegação no document: o pixel Tintim reescreve os <a> de tintim.link
  // (troca os nós do DOM), o que derrubaria listeners ligados direto neles.
  document.addEventListener('click', (e) => {
    if (!(e.target as HTMLElement).closest?.('[data-cta]')) return;
    track({
      event: 'whatsapp_click',
      quiz_name: 'quiz_sge',
      lead_perfil: state.answers[1] || '',
      lead_resultado: state.answers[5] || '',
    });
  });

  // ── Count-up nas estatísticas do hero ───────────────────────────
  const fmtNum = (n: number) => n.toLocaleString('pt-BR');
  const finalText = (el: HTMLElement) =>
    (el.dataset.prefix || '') + fmtNum(Number(el.dataset.to)) + (el.dataset.suffix || '');
  const counters = document.querySelectorAll<HTMLElement>('.sge-count');
  const statsEl = document.querySelector('.sge-hero-stats');
  const reduceMotion = matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (counters.length && statsEl && !reduceMotion) {
    const runCount = (el: HTMLElement) => {
      const to = Number(el.dataset.to);
      const pre = el.dataset.prefix || '', suf = el.dataset.suffix || '';
      const dur = 1300, start = performance.now();
      const tick = (now: number) => {
        const p = Math.min((now - start) / dur, 1);
        const eased = 1 - Math.pow(1 - p, 3); // easeOutCubic
        el.textContent = pre + fmtNum(Math.round(to * eased)) + suf;
        if (p < 1) requestAnimationFrame(tick);
        else el.textContent = finalText(el);
      };
      el.textContent = pre + '0' + suf;
      requestAnimationFrame(tick);
    };
    new IntersectionObserver((entries, ob) => {
      if (entries[0].isIntersecting) { counters.forEach(runCount); ob.disconnect(); }
    }, { threshold: 0.4 }).observe(statsEl);
  } else {
    counters.forEach((el) => { el.textContent = finalText(el); });
  }

  // ── Carrossel de provas — setas (desktop) ───────────────────────
  document.querySelectorAll<HTMLButtonElement>('.sge-car-arrow').forEach((btn) => {
    btn.addEventListener('click', () => {
      const track_ = btn.closest('.sge-carousel-wrap')?.querySelector<HTMLElement>('.sge-carousel');
      if (!track_) return;
      track_.scrollBy({ left: Number(btn.dataset.dir) * Math.round(track_.clientWidth * 0.8), behavior: 'smooth' });
    });
  });

  // ── Reveal ao rolar (quem somos) ─────────────────────────────────
  const obs = new IntersectionObserver((entries) => {
    entries.forEach((e) => { if (e.isIntersecting) e.target.classList.add('in'); });
  }, { threshold: 0.08 });
  document.querySelectorAll('.reveal').forEach((el) => obs.observe(el));
</script>
