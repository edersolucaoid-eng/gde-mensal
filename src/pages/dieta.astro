---
import Base from '../layouts/Base.astro';
---
<Base title="Dieta do Jogador | Goleiro de Elite" heroImage="/images/logo-gde.webp">
<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --black:  #0B0B0B;
  --white:  #ffffff;
  --yellow: #F4B400;
  --card:   rgba(255,255,255,.04);
  --border: rgba(255,255,255,.08);
}

body {
  font-family: 'Barlow', sans-serif;
  background: var(--black);
  color: var(--white);
  min-height: 100vh;
  overflow-x: hidden;
}

/* ─── i18n via class toggle ─────────────────────────────── */
html[data-lang="pt"] .lang-es { display: none !important; }
html[data-lang="es"] .lang-pt { display: none !important; }

/* ─── Top header sticky ────────────────────────────────────── */
.dt-top {
  position: sticky;
  top: 0;
  z-index: 50;
  background: rgba(11,11,11,.92);
  backdrop-filter: blur(14px);
  -webkit-backdrop-filter: blur(14px);
  border-bottom: 1px solid var(--border);
}
.dt-top-inner {
  max-width: 720px;
  margin: 0 auto;
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 12px 20px;
}
.dt-logo {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  background: rgba(244,180,0,.08);
  border: 1px solid rgba(244,180,0,.25);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 6px;
  flex-shrink: 0;
}
.dt-logo img { width: 100%; height: auto; filter: brightness(1.2); }
.dt-brand {
  flex: 1;
  font-family: 'Barlow Condensed', sans-serif;
  font-size: .7rem;
  font-weight: 700;
  letter-spacing: .2em;
  text-transform: uppercase;
  color: var(--white);
  line-height: 1;
}
.dt-brand span { color: var(--yellow); }

/* ─── Lang switch ──────────────────────────────────────────── */
.dt-lang {
  display: flex;
  gap: 2px;
  border: 1px solid var(--border);
  border-radius: 9999px;
  padding: 3px;
}
.dt-lang button {
  background: none;
  border: none;
  font-family: 'Barlow Condensed', sans-serif;
  font-size: .68rem;
  font-weight: 700;
  letter-spacing: .14em;
  color: rgba(255,255,255,.5);
  padding: 4px 10px;
  border-radius: 9999px;
  cursor: pointer;
  transition: background .2s, color .2s;
}
.dt-lang button:hover { color: var(--white); }
html[data-lang="pt"] .dt-lang button[data-set-lang="pt"],
html[data-lang="es"] .dt-lang button[data-set-lang="es"] {
  background: var(--yellow);
  color: var(--black);
}

/* ─── Hero ─────────────────────────────────────────────────── */
.dt-wrap {
  max-width: 720px;
  margin: 0 auto;
  padding: 0 20px 80px;
}
.dt-hero {
  text-align: center;
  padding: clamp(36px,6vw,60px) 0 clamp(28px,4vw,40px);
}
.dt-eyebrow {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: .68rem;
  font-weight: 700;
  letter-spacing: .24em;
  text-transform: uppercase;
  color: var(--yellow);
  margin-bottom: 14px;
}
.dt-eyebrow::before { content: '// '; color: rgba(255,255,255,.25); }
.dt-h1 {
  font-family: 'Bebas Neue', sans-serif;
  font-size: clamp(2.6rem,7vw,4rem);
  line-height: .92;
  letter-spacing: .02em;
  margin-bottom: 16px;
}
.dt-h1 .yl { color: var(--yellow); }
.dt-h-sub {
  font-size: .95rem;
  color: rgba(255,255,255,.6);
  line-height: 1.5;
  max-width: 460px;
  margin: 0 auto;
}

/* ─── Disclaimer card ──────────────────────────────────────── */
.dt-disclaimer {
  background: var(--card);
  border: 1px solid var(--border);
  border-left: 3px solid var(--yellow);
  border-radius: 12px;
  padding: 18px 22px;
  font-size: .82rem;
  color: rgba(255,255,255,.6);
  line-height: 1.6;
  margin-bottom: clamp(40px,5vw,56px);
}
.dt-disclaimer strong { color: var(--white); }

/* ─── Section ──────────────────────────────────────────────── */
.dt-sec {
  margin-bottom: clamp(40px,6vw,64px);
  scroll-margin-top: 80px;
}
.dt-label {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: .65rem;
  font-weight: 700;
  letter-spacing: .24em;
  text-transform: uppercase;
  color: var(--yellow);
  margin-bottom: 10px;
}
.dt-label::before { content: '// '; color: rgba(255,255,255,.25); }
.dt-h2 {
  font-family: 'Bebas Neue', sans-serif;
  font-size: clamp(1.8rem,5vw,2.6rem);
  line-height: 1;
  letter-spacing: .02em;
  margin-bottom: 8px;
}
.dt-h2 .yl { color: var(--yellow); }
.dt-h2-sub {
  font-size: .9rem;
  color: rgba(255,255,255,.5);
  line-height: 1.5;
  margin-bottom: 24px;
}

/* ─── Calculadora ──────────────────────────────────────────── */
.dt-calc {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 18px;
  padding: 24px;
}
.dt-calc-row {
  display: flex;
  flex-direction: column;
  gap: 8px;
  margin-bottom: 18px;
}
.dt-calc-row label {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: .72rem;
  font-weight: 700;
  letter-spacing: .14em;
  text-transform: uppercase;
  color: rgba(255,255,255,.6);
}
.dt-input {
  width: 100%;
  padding: 14px 16px;
  border-radius: 10px;
  background: rgba(255,255,255,.04);
  border: 1px solid var(--border);
  color: var(--white);
  font-family: 'Barlow', sans-serif;
  font-size: 1rem;
  outline: none;
  transition: border-color .2s, background .2s;
}
.dt-input:focus {
  border-color: var(--yellow);
  background: rgba(244,180,0,.04);
}
.dt-radio {
  display: flex;
  flex-direction: column;
  gap: 8px;
}
.dt-radio-opt {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 12px 14px;
  border-radius: 10px;
  background: rgba(255,255,255,.02);
  border: 1px solid var(--border);
  cursor: pointer;
  transition: border-color .2s, background .2s;
}
.dt-radio-opt:hover { border-color: rgba(244,180,0,.3); }
.dt-radio-opt input[type="radio"] {
  appearance: none;
  width: 16px;
  height: 16px;
  border-radius: 50%;
  border: 2px solid rgba(255,255,255,.25);
  background: transparent;
  flex-shrink: 0;
  cursor: pointer;
  transition: border-color .2s;
}
.dt-radio-opt input[type="radio"]:checked {
  border-color: var(--yellow);
  background: radial-gradient(circle, var(--yellow) 40%, transparent 50%);
}
.dt-radio-opt:has(input:checked) {
  border-color: rgba(244,180,0,.45);
  background: rgba(244,180,0,.06);
}
.dt-radio-opt span {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: .88rem;
  font-weight: 600;
  letter-spacing: .04em;
  color: var(--white);
}
.dt-radio-opt em {
  font-style: normal;
  color: rgba(255,255,255,.4);
  font-size: .78rem;
  margin-left: auto;
}
.dt-result {
  margin-top: 22px;
  padding: 22px;
  border-radius: 14px;
  background: linear-gradient(160deg, rgba(244,180,0,.12), rgba(244,180,0,.04));
  border: 1px solid rgba(244,180,0,.25);
}
.dt-result-label {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: .65rem;
  font-weight: 700;
  letter-spacing: .2em;
  text-transform: uppercase;
  color: var(--yellow);
  margin-bottom: 6px;
}
.dt-result-value {
  font-family: 'Bebas Neue', sans-serif;
  font-size: clamp(2.4rem,7vw,3.4rem);
  color: var(--white);
  line-height: 1;
  margin-bottom: 4px;
}
.dt-result-value span {
  font-size: 1rem;
  color: rgba(255,255,255,.5);
  font-family: 'Barlow Condensed', sans-serif;
  margin-left: 6px;
  letter-spacing: .1em;
  text-transform: uppercase;
}
.dt-result-hint {
  font-size: .78rem;
  color: rgba(255,255,255,.55);
  line-height: 1.5;
  margin-top: 14px;
}

/* ─── Goal hint cards ──────────────────────────────────────── */
.dt-goals {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 8px;
  margin-top: 14px;
}
.dt-goal {
  padding: 12px;
  border-radius: 10px;
  background: rgba(255,255,255,.04);
  border: 1px solid var(--border);
  text-align: center;
}
.dt-goal-label {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: .56rem;
  font-weight: 700;
  letter-spacing: .14em;
  text-transform: uppercase;
  color: rgba(255,255,255,.4);
}
.dt-goal-value {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 1.4rem;
  color: var(--yellow);
  line-height: 1;
  margin-top: 4px;
}
.dt-goal-hint {
  font-size: .68rem;
  color: rgba(255,255,255,.4);
  margin-top: 2px;
}

/* ─── Tabs cardápios ──────────────────────────────────────── */
.dt-tabs {
  display: flex;
  gap: 6px;
  margin-bottom: 18px;
  overflow-x: auto;
  padding-bottom: 4px;
  scrollbar-width: thin;
}
.dt-tab {
  flex-shrink: 0;
  padding: 10px 16px;
  border-radius: 10px;
  background: rgba(255,255,255,.04);
  border: 1px solid var(--border);
  color: rgba(255,255,255,.6);
  font-family: 'Barlow Condensed', sans-serif;
  font-size: .82rem;
  font-weight: 700;
  letter-spacing: .08em;
  text-transform: uppercase;
  cursor: pointer;
  transition: all .2s ease;
}
.dt-tab:hover { border-color: rgba(244,180,0,.3); color: var(--white); }
.dt-tab.is-active {
  background: rgba(244,180,0,.12);
  border-color: rgba(244,180,0,.45);
  color: var(--yellow);
}

.dt-menu { display: none; }
.dt-menu.is-active { display: block; }

.dt-meal {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 14px;
  padding: 18px 20px;
  margin-bottom: 10px;
}
.dt-meal-head {
  display: flex;
  align-items: baseline;
  gap: 12px;
  margin-bottom: 12px;
  padding-bottom: 10px;
  border-bottom: 1px dashed rgba(255,255,255,.06);
}
.dt-meal-time {
  font-family: 'JetBrains Mono', monospace;
  font-size: .72rem;
  font-weight: 700;
  color: var(--yellow);
  letter-spacing: .04em;
}
.dt-meal-name {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: .95rem;
  font-weight: 700;
  letter-spacing: .08em;
  text-transform: uppercase;
  color: var(--white);
}
.dt-meal ul {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 6px;
}
.dt-meal li {
  font-size: .86rem;
  color: rgba(255,255,255,.7);
  line-height: 1.4;
  display: flex;
  gap: 10px;
  align-items: flex-start;
}
.dt-meal li::before {
  content: '·';
  color: var(--yellow);
  font-weight: 700;
  flex-shrink: 0;
}
.dt-meal li strong { color: var(--white); font-weight: 600; }

/* ─── Substituições ────────────────────────────────────────── */
.dt-sub-card {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 14px;
  padding: 18px 20px;
  margin-bottom: 10px;
}
.dt-sub-original {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: .92rem;
  font-weight: 700;
  letter-spacing: .04em;
  text-transform: uppercase;
  color: var(--white);
  margin-bottom: 10px;
  padding-bottom: 8px;
  border-bottom: 1px dashed rgba(255,255,255,.06);
}
.dt-sub-original .yl { color: var(--yellow); }
.dt-sub-list {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 6px;
}
.dt-sub-list li {
  font-size: .86rem;
  color: rgba(255,255,255,.65);
  display: flex;
  gap: 10px;
  align-items: center;
}
.dt-sub-list li::before {
  content: '→';
  color: var(--yellow);
  font-weight: 700;
}

/* ─── Dicas ────────────────────────────────────────────────── */
.dt-tips {
  display: flex;
  flex-direction: column;
  gap: 10px;
}
.dt-tip {
  background: var(--card);
  border: 1px solid var(--border);
  border-left: 3px solid var(--yellow);
  border-radius: 10px;
  padding: 16px 18px;
  font-size: .88rem;
  color: rgba(255,255,255,.7);
  line-height: 1.5;
}

/* ─── Suplementos (accordion) ──────────────────────────────── */
.dt-supp { display: flex; flex-direction: column; gap: 8px; }
.dt-supp-item {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 12px;
  overflow: hidden;
}
.dt-supp-head {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16px 20px;
  background: none;
  border: none;
  color: var(--white);
  text-align: left;
  cursor: pointer;
  font-family: 'Barlow Condensed', sans-serif;
  font-size: .95rem;
  font-weight: 700;
  letter-spacing: .08em;
  text-transform: uppercase;
  transition: background .2s;
  gap: 12px;
}
.dt-supp-head:hover { background: rgba(244,180,0,.04); }
.dt-supp-head .dt-supp-name { flex: 1; }
.dt-supp-head .dt-supp-ico {
  width: 24px;
  height: 24px;
  border-radius: 50%;
  background: rgba(244,180,0,.12);
  border: 1px solid rgba(244,180,0,.3);
  color: var(--yellow);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.1rem;
  font-weight: 400;
  transition: transform .25s ease;
  flex-shrink: 0;
}
.dt-supp-item.is-open .dt-supp-ico {
  transform: rotate(45deg);
}
.dt-supp-body {
  max-height: 0;
  overflow: hidden;
  transition: max-height .35s ease;
}
.dt-supp-body-inner {
  padding: 0 20px 18px;
  font-size: .85rem;
  color: rgba(255,255,255,.65);
  line-height: 1.55;
}
.dt-supp-body-inner ul {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 6px;
}
.dt-supp-body-inner li {
  display: flex;
  gap: 10px;
  align-items: flex-start;
}
.dt-supp-body-inner li::before {
  content: '·';
  color: var(--yellow);
  font-weight: 700;
  flex-shrink: 0;
}
.dt-supp-body-inner strong { color: var(--white); }

/* ─── Calculadora de proteína ──────────────────────────────── */
.dt-prot {
  display: grid;
  grid-template-columns: 1fr;
  gap: 8px;
}
.dt-prot-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14px 18px;
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 12px;
  gap: 12px;
}
.dt-prot-label {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: .82rem;
  font-weight: 700;
  letter-spacing: .04em;
  text-transform: uppercase;
  color: var(--white);
}
.dt-prot-value {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 1.2rem;
  color: var(--yellow);
  letter-spacing: .04em;
  white-space: nowrap;
}

/* ─── Footer ───────────────────────────────────────────────── */
.dt-foot {
  margin-top: 60px;
  padding-top: 28px;
  border-top: 1px solid var(--border);
  text-align: center;
}
.dt-foot-title {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: .65rem;
  font-weight: 700;
  letter-spacing: .22em;
  text-transform: uppercase;
  color: rgba(255,255,255,.4);
  margin-bottom: 12px;
}
.dt-foot-team {
  display: flex;
  justify-content: center;
  gap: 24px;
  flex-wrap: wrap;
  margin-bottom: 24px;
}
.dt-foot-person {
  font-size: .82rem;
  color: rgba(255,255,255,.55);
  line-height: 1.4;
}
.dt-foot-person strong { color: var(--white); display: block; font-weight: 600; }
.dt-foot-person a {
  color: var(--yellow);
  text-decoration: none;
  font-family: 'Barlow Condensed', sans-serif;
  font-weight: 700;
  letter-spacing: .04em;
}
.dt-foot-copy {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: .62rem;
  font-weight: 600;
  letter-spacing: .16em;
  text-transform: uppercase;
  color: rgba(255,255,255,.2);
}

@media (max-width: 480px) {
  .dt-goals { gap: 6px; }
  .dt-goal { padding: 10px 8px; }
}
</style>

<header class="dt-top">
  <div class="dt-top-inner">
    <div class="dt-logo">
      <img src="/images/logo-gde.webp" alt="Goleiro de Elite" width="34" height="34" loading="eager" />
    </div>
    <div class="dt-brand">
      <span class="lang-pt">Goleiro de Elite <span>· Dieta do Jogador</span></span>
      <span class="lang-es">Goleiro de Elite <span>· Dieta del Jugador</span></span>
    </div>
    <div class="dt-lang" role="group">
      <button type="button" data-set-lang="pt">PT</button>
      <button type="button" data-set-lang="es">ES</button>
    </div>
  </div>
</header>

<main class="dt-wrap">

  <section class="dt-hero">
    <div class="dt-eyebrow">
      <span class="lang-pt">Guia nutricional</span>
      <span class="lang-es">Guía nutricional</span>
    </div>
    <h1 class="dt-h1">
      <span class="lang-pt">Dieta do<br><span class="yl">Jogador</span></span>
      <span class="lang-es">Dieta del<br><span class="yl">Jugador</span></span>
    </h1>
    <p class="dt-h-sub">
      <span class="lang-pt">Cardápios práticos pra otimizar seu desempenho — feitos pela nossa nutricionista em parceria com a equipe técnica.</span>
      <span class="lang-es">Menús prácticos para optimizar tu rendimiento — hechos por nuestra nutricionista en colaboración con el equipo técnico.</span>
    </p>
  </section>

  <div class="dt-disclaimer">
    <span class="lang-pt"><strong>Orientações gerais.</strong> Os cardápios e dicas a seguir são baseados em indivíduos saudáveis. Caso tenha alguma patologia ou condição especial de saúde, procure orientação individualizada. As orientações aqui não substituem uma consulta personalizada com nutricionista.</span>
    <span class="lang-es"><strong>Orientaciones generales.</strong> Los menús y consejos a continuación están basados en individuos saludables. En caso de tener alguna patología o condición especial de salud, busca orientación individualizada. Las orientaciones aquí no sustituyen una consulta personalizada con nutricionista.</span>
  </div>

  <!-- ── Calculadora TMB ────────────────────────────────────── -->
  <section class="dt-sec" id="calc">
    <div class="dt-label">
      <span class="lang-pt">Cálculo de calorias</span>
      <span class="lang-es">Cálculo de calorías</span>
    </div>
    <h2 class="dt-h2">
      <span class="lang-pt">Quantas calorias você <span class="yl">gasta por dia?</span></span>
      <span class="lang-es">¿Cuántas calorías <span class="yl">quemas por día?</span></span>
    </h2>
    <p class="dt-h2-sub">
      <span class="lang-pt">Coloque seu peso e seu nível de atividade física. A calculadora usa a fórmula da Taxa Metabólica Basal (TMB).</span>
      <span class="lang-es">Pon tu peso y tu nivel de actividad física. La calculadora usa la fórmula de la Tasa Metabólica Basal (TMB).</span>
    </p>

    <div class="dt-calc">
      <div class="dt-calc-row">
        <label for="dt-peso">
          <span class="lang-pt">Peso atual</span>
          <span class="lang-es">Peso actual</span>
        </label>
        <input type="number" id="dt-peso" class="dt-input" placeholder="Ex: 75" min="30" max="200" step="0.1" inputmode="decimal" />
      </div>

      <div class="dt-calc-row">
        <label>
          <span class="lang-pt">Nível de atividade física</span>
          <span class="lang-es">Nivel de actividad física</span>
        </label>
        <div class="dt-radio">
          <label class="dt-radio-opt">
            <input type="radio" name="dt-atv" value="1" />
            <span><span class="lang-pt">Sedentário</span><span class="lang-es">Sedentario</span></span>
            <em><span class="lang-pt">sem treino</span><span class="lang-es">sin entreno</span></em>
          </label>
          <label class="dt-radio-opt">
            <input type="radio" name="dt-atv" value="1.5" checked />
            <span><span class="lang-pt">Leve</span><span class="lang-es">Ligera</span></span>
            <em><span class="lang-pt">treina 2-3×/sem</span><span class="lang-es">entrena 2-3×/sem</span></em>
          </label>
          <label class="dt-radio-opt">
            <input type="radio" name="dt-atv" value="1.8" />
            <span><span class="lang-pt">Moderada</span><span class="lang-es">Moderada</span></span>
            <em><span class="lang-pt">treina 4-5×/sem</span><span class="lang-es">entrena 4-5×/sem</span></em>
          </label>
          <label class="dt-radio-opt">
            <input type="radio" name="dt-atv" value="2.1" />
            <span><span class="lang-pt">Intensa</span><span class="lang-es">Intensa</span></span>
            <em><span class="lang-pt">treina diário + jogo</span><span class="lang-es">diario + partido</span></em>
          </label>
        </div>
      </div>

      <div class="dt-result">
