<script is:inline>
  // Aplica idioma salvo ANTES do paint para evitar flash
  (function() {
    const saved = localStorage.getItem('dieta-lang');
    const lang = saved === 'es' ? 'es' : 'pt';
    document.documentElement.setAttribute('data-lang', lang);
  })();
</script>
<script>
  // ── Lang switch ────────────────────────────────────────────
  document.querySelectorAll('[data-set-lang]').forEach(btn => {
    btn.addEventListener('click', () => {
      const lang = btn.dataset.setLang;
      document.documentElement.setAttribute('data-lang', lang);
      try { localStorage.setItem('dieta-lang', lang); } catch {}
    });
  });

  // ── Calculadora TMB ────────────────────────────────────────
  const peso = document.getElementById('dt-peso');
  const radios = document.querySelectorAll('input[name="dt-atv"]');
  const tmbEl = document.getElementById('dt-tmb');
  const cutEl = document.getElementById('dt-cut');
  const maintEl = document.getElementById('dt-maint');
  const bulkEl = document.getElementById('dt-bulk');

  function fmt(n) {
    const lang = document.documentElement.getAttribute('data-lang') || 'pt';
    return n.toLocaleString(lang === 'es' ? 'es' : 'pt-BR');
  }
  function calcTMB() {
    const p = parseFloat(peso.value);
    if (!isFinite(p) || p <= 0) {
      tmbEl.textContent = '—';
      cutEl.textContent = maintEl.textContent = bulkEl.textContent = '—';
      return;
    }
    let mult = 1;
    radios.forEach(r => { if (r.checked) mult = parseFloat(r.value); });
    const tmbBasal = (0.063 * p + 2.896) * 239;
    const total = Math.round(tmbBasal * mult);
    tmbEl.textContent = fmt(total);
    cutEl.textContent = fmt(Math.round(total * 0.85));
    maintEl.textContent = fmt(total);
    bulkEl.textContent = fmt(Math.round(total * 1.15));
  }
  peso.addEventListener('input', calcTMB);
  radios.forEach(r => r.addEventListener('change', calcTMB));

  // ── Tabs ───────────────────────────────────────────────────
  document.querySelectorAll('.dt-tab').forEach(tab => {
    tab.addEventListener('click', () => {
      const target = tab.dataset.menu;
      document.querySelectorAll('.dt-tab').forEach(t => t.classList.toggle('is-active', t === tab));
      document.querySelectorAll('.dt-menu').forEach(m => {
        m.classList.toggle('is-active', m.dataset.menu === target);
      });
    });
  });

  // ── Accordion ──────────────────────────────────────────────
  document.querySelectorAll('.dt-supp-head').forEach(btn => {
    btn.addEventListener('click', () => {
      const item = btn.parentElement;
      const body = btn.nextElementSibling;
      const isOpen = item.classList.contains('is-open');
      document.querySelectorAll('.dt-supp-item.is-open').forEach(it => {
        if (it !== item) {
          it.classList.remove('is-open');
          it.querySelector('.dt-supp-body').style.maxHeight = null;
        }
      });
      if (isOpen) {
        item.classList.remove('is-open');
        body.style.maxHeight = null;
      } else {
        item.classList.add('is-open');
        body.style.maxHeight = body.scrollHeight + 'px';
      }
    });
  });

  // ── Calculadora de proteína ────────────────────────────────
  const peso2 = document.getElementById('dt-peso2');
  const protLow = document.getElementById('dt-prot-low');
  const protMid = document.getElementById('dt-prot-mid');
  const protHigh = document.getElementById('dt-prot-high');

  function calcProt() {
    const p = parseFloat(peso2.value);
    const lang = document.documentElement.getAttribute('data-lang') || 'pt';
    const day = lang === 'es' ? 'día' : 'dia';
    if (!isFinite(p) || p <= 0) {
      protLow.innerHTML = `— g/<span>${day}</span>`;
      protMid.innerHTML = `— g/<span>${day}</span>`;
      protHigh.innerHTML = `— g/<span>${day}</span>`;
      return;
    }
    protLow.innerHTML = `${Math.round(p * 0.8)} g/<span>${day}</span>`;
    protMid.innerHTML = `${Math.round(p * 1.2)} – ${Math.round(p * 1.4)} g/<span>${day}</span>`;
    protHigh.innerHTML = `${Math.round(p * 1.2)} – ${Math.round(p * 1.7)} g/<span>${day}</span>`;
  }
  peso2.addEventListener('input', calcProt);
</script>
</Base>
