---
/* ============================================================
   SISTEMA GOLEIRO DE ELITE™ — Landing de conversão p/ WhatsApp
   Consultoria online de preparação física específica p/ goleiros.
   Objetivo único da página: clique no botão de WhatsApp.
============================================================ */
import Base from '../layouts/Base.astro';

// ⚽ Link do WhatsApp — troque o número/mensagem se necessário.
const WHATSAPP = 'https://wa.me/5565981351676?text=Ol%C3%A1%2C%20vim%20da%20p%C3%A1gina%20do%20Sistema%20Goleiro%20de%20Elite%20e%20quero%20saber%20se%20o%20acompanhamento%20faz%20sentido%20pra%20mim';
const CTA = 'QUERO PARTICIPAR DO SISTEMA GOLEIRO DE ELITE™';

// 5 Pilares
const pilares = [
  { n: '01', t: 'Especificidade Aplicada™',         d: 'Seu treino é construído para as exigências reais da posição.' },
  { n: '02', t: 'Individualização Estratégica™',     d: 'Sua idade, rotina, histórico, corpo e objetivos são levados em consideração.' },
  { n: '03', t: 'Transferência Para o Jogo™',        d: 'Cada exercício precisa gerar resultado dentro do gol.' },
  { n: '04', t: 'Progressão de Performance™',        d: 'Força. Mobilidade. Potência. Explosão. Velocidade. Cada etapa prepara a próxima.' },
  { n: '05', t: 'Desenvolvimento Integral do Goleiro™', d: 'Mais confiança, mais resistência, menos dores, mais desempenho e mais longevidade.' },
];

// Depoimentos
const depoimentos = [
  { nome: 'Carlos Eduardo', txt: 'Meu desempenho em campo está melhorando. Estou chegando em bolas que antes eu não chegava.' },
  { nome: 'Wagner Ulian',   txt: 'Estou tendo força para dar passadas laterais e impulsão que nunca tinha conseguido antes.' },
  { nome: 'Aluno da Consultoria', txt: 'Foi a melhor compra em termos de assistência ao cliente que eu já fiz.' },
];

// O que você recebe
const entregaveis = [
  { i: '📋', t: 'Plano de Treino Personalizado', d: 'Construído para a sua realidade.' },
  { i: '📱', t: 'Aplicativo de Treinos',         d: 'Você abre e executa. Sem dúvidas. Sem improviso.' },
  { i: '📈', t: 'Evolução Contínua',             d: 'Seu treino evolui conforme você evolui.' },
  { i: '🏠', t: 'Treino para Casa ou Academia',  d: 'Adaptado à estrutura que você possui.' },
  { i: '🥗', t: 'Guia Nutricional',              d: 'Para melhorar recuperação, composição corporal e desempenho.' },
  { i: '🔥', t: 'Protocolo Pré-Jogo',            d: 'Prepare seu corpo para competir.' },
  { i: '🧊', t: 'Protocolo Pós-Jogo',            d: 'Recupere melhor e continue evoluindo.' },
  { i: '💬', t: 'Suporte Direto Pelo WhatsApp',  d: 'Acompanhamento, ajustes, adaptações e direção.' },
];

// Objeções (FAQ)
const faq = [
  { q: 'Mas será que funciona online?', a: 'Hoje atendemos goleiros de todo o Brasil. O acompanhamento é individual, os ajustes acontecem continuamente e o processo é adaptado à sua realidade.' },
  { q: 'Não tenho muito tempo.', a: 'O objetivo não é transformar você em atleta profissional. É encaixar a preparação física na sua rotina.' },
  { q: 'Minha academia é simples. Funciona?', a: 'Sim. O treino é adaptado à estrutura disponível.' },
  { q: 'Será que serve para mim?', a: 'Se você quer jogar melhor, sentir mais confiança, chegar em mais bolas e parar de treinar sem direção, provavelmente sim.' },
];
---

<Base
  title="Sistema Goleiro de Elite™ | Preparação Física Específica para Goleiros"
  heroImage="/images/goleiro_de_elite_hero.webp"
>
  <main class="sge">

    <!-- ============================================================
         1 — HERO
    ============================================================ -->
    <section class="sge-hero">
      <!-- Banner do programa (substitui o texto eyebrow) -->
      <div class="sge-hero-media">
        <img
          src="/images/goleiro_de_elite_hero.webp"
          alt="Sistema Goleiro de Elite — preparação física específica para goleiros"
          width="1536" height="1024"
          fetchpriority="high" decoding="async"
          class="sge-hero-img"
        />
        <div class="sge-hero-fade"></div>
      </div>
      <div class="sge-hero-inner">
        <h1 class="sge-hero-h1">
          Volte a confiar no seu corpo dentro do gol <span class="sge-hl">antes que mais uma temporada termine</span> com a sensação de que você poderia ter feito mais.
        </h1>
        <p class="sge-hero-sub">
          Descubra exatamente o que treinar para chegar em mais bolas, reagir mais rápido e transformar
          seu trabalho na academia em desempenho real dentro do jogo através do Sistema Goleiro de Elite™.
        </p>
        <div class="sge-hero-stats">
          <div><strong>+2.000</strong><span>goleiros</span></div>
          <i></i>
          <div><strong>+3 anos</strong><span>de método</span></div>
          <i></i>
          <div><strong>100%</strong><span>online</span></div>
        </div>
      </div>
    </section>

    <!-- ============================================================
         2 — A DOR
    ============================================================ -->
    <section class="sge-sec sge-pain reveal">
      <span class="sge-tag">A bola</span>
      <h2 class="sge-h2">Você sabe exatamente qual foi a bola.</h2>
      <p class="sge-lead">
        Não foi a impossível.<br />
        Não foi a que entrou no ângulo.<br />
        Foi aquela que você <em>quase</em> chegou.
      </p>
      <p class="sge-lead">
        Aquela que raspou na ponta dos dedos.<br />
        Aquela que ficou voltando na sua cabeça durante o caminho para casa.
      </p>

      <div class="sge-quote">“Dava para ter pego.”</div>

      <p class="sge-body">
        Não porque faltou vontade.<br />
        Não porque faltou comprometimento.<br />
        Mas porque seu corpo não respondeu como deveria.
      </p>

      <div class="sge-faltou">
        <span>Faltou explosão.</span>
        <span>Faltou velocidade.</span>
        <span>Faltou reação.</span>
        <span>Faltou confiança.</span>
      </div>

      <p class="sge-body sge-strong">E para um goleiro, meio segundo muda tudo.</p>
    </section>

    <!-- ============================================================
         3 — O PROBLEMA REAL
    ============================================================ -->
    <section class="sge-sec reveal">
      <span class="sge-tag">O problema real</span>
      <h2 class="sge-h2">O problema não é que você está treinando pouco.</h2>
      <p class="sge-sub-h2">O problema é que seu treino não está aparecendo dentro do gol.</p>
      <p class="sge-body">
        A maioria dos goleiros treina, sua, corre, faz musculação e procura exercícios na internet.
        Mas continua sem saber se aquilo realmente está ajudando a defender mais bolas.
      </p>
      <p class="sge-body">
        Porque uma coisa é ficar mais forte.<br />
        <span class="sge-gold-text">Outra é transformar força em desempenho.</span>
      </p>
    </section>

    <!-- ============================================================
         4 — O INIMIGO
    ============================================================ -->
    <section class="sge-sec sge-enemy reveal">
      <span class="sge-tag">A mentira</span>
      <h2 class="sge-h2">Durante anos venderam para goleiros uma mentira.</h2>
      <ul class="sge-lies">
        <li>Que qualquer treino serve.</li>
        <li>Que basta fazer musculação.</li>
        <li>Que basta correr.</li>
        <li>Que basta treinar mais.</li>
      </ul>
      <p class="sge-body">
        Mas se isso fosse verdade, todo frequentador de academia seria um grande goleiro.
      </p>
      <p class="sge-body sge-strong">
        Treinos genéricos criam goleiros mais cansados.<br />
        Não necessariamente melhores.
      </p>
    </section>

    <!-- ============================================================
         5 — BIG IDEA
    ============================================================ -->
    <section class="sge-sec sge-bigidea reveal">
      <h2 class="sge-bigidea-h">
        Treino bom não é o que te deixa <span class="sge-strike">cansado</span>.
      </h2>
      <p class="sge-bigidea-sub">Treino bom é o que te deixa <span class="sge-gold-text">melhor dentro do gol.</span></p>
      <p class="sge-body">Essa é a diferença entre treinar por treinar e treinar para performar.</p>
    </section>

    <!-- ============================================================
         6 — O MECANISMO
    ============================================================ -->
    <section class="sge-sec sge-mech reveal">
      <span class="sge-tag">A metodologia</span>
      <h2 class="sge-h2 sge-mech-title">Sistema Goleiro de Elite™</h2>
      <p class="sge-body">
        Uma metodologia construída ao longo de mais de 3 anos e aplicada em mais de 2.000 goleiros.
      </p>
      <div class="sge-objective">
        Transformar força de academia em <strong>desempenho real dentro do gol.</strong>
      </div>
      <p class="sge-body">
        Existe apenas uma pergunta que realmente importa:
      </p>
      <p class="sge-mech-q">“Esse treino vai me ajudar a defender melhor?”</p>
    </section>

    <!-- ============================================================
         7 — OS 5 PILARES
    ============================================================ -->
    <section class="sge-sec reveal">
      <span class="sge-tag">Os 5 pilares</span>
      <h2 class="sge-h2">Tudo é decidido por estes 5 pilares.</h2>
      <div class="sge-pillars">
        {pilares.map((p) => (
          <article class="sge-pillar">
            <div class="sge-pillar-n">{p.n}</div>
            <h3 class="sge-pillar-t">{p.t}</h3>
            <p class="sge-pillar-d">{p.d}</p>
          </article>
        ))}
      </div>
    </section>

    <!-- ============================================================
         8 — A TRANSFORMAÇÃO
    ============================================================ -->
    <section class="sge-sec sge-transform reveal">
      <span class="sge-tag">A virada</span>
      <h2 class="sge-h2">O que acontece quando seu treino finalmente faz sentido para a posição?</h2>
      <ul class="sge-transform-list">
        <li>Você para de entrar em campo preocupado.</li>
        <li>Você para de pensar na falta de explosão, mobilidade ou condicionamento.</li>
        <li>Você volta a confiar.</li>
        <li>Volta a atacar a bola.</li>
        <li>Volta a jogar solto.</li>
        <li>Volta a sentir que seu corpo trabalha a seu favor.</li>
      </ul>
    </section>

    <!-- ============================================================
         9 — PROVAS / DEPOIMENTOS
    ============================================================ -->
    <section class="sge-sec reveal">
      <span class="sge-tag">Prova social</span>
      <h2 class="sge-h2">Mais de 2.000 goleiros já passaram pelo Sistema Goleiro de Elite™</h2>
      <div class="sge-testis">
        {depoimentos.map((d) => (
          <figure class="sge-testi">
            <div class="sge-stars">★★★★★</div>
            <blockquote>“{d.txt}”</blockquote>
            <figcaption>
              <span class="sge-avatar">{d.nome.charAt(0)}</span>
              {d.nome}
            </figcaption>
          </figure>
        ))}
      </div>

      <!-- Área para prints / imagens de resultados -->
      <div class="sge-proof-gallery">
        <div class="sge-proof-ph"><span>📸</span>Print de resultado</div>
        <div class="sge-proof-ph"><span>📸</span>Print de resultado</div>
        <div class="sge-proof-ph"><span>📸</span>Print de resultado</div>
      </div>
      <p class="sge-proof-note">Espaço reservado para prints de conversas e fotos de evolução dos alunos.</p>
    </section>

    <!-- ============================================================
         10 — O QUE VOCÊ RECEBE
    ============================================================ -->
    <section class="sge-sec reveal">
      <span class="sge-tag">O que você recebe</span>
      <h2 class="sge-h2">Tudo que você precisa para evoluir com direção.</h2>
      <div class="sge-deliv">
        {entregaveis.map((e) => (
          <article class="sge-deliv-card">
            <div class="sge-deliv-i">{e.i}</div>
            <h3 class="sge-deliv-t">{e.t}</h3>
            <p class="sge-deliv-d">{e.d}</p>
          </article>
        ))}
      </div>
    </section>

    <!-- ============================================================
         11 — OBJEÇÕES (FAQ ACORDEÃO)
    ============================================================ -->
    <section class="sge-sec reveal">
      <span class="sge-tag">Sem enrolação</span>
      <h2 class="sge-h2">Talvez você esteja pensando...</h2>
      <div class="sge-faq">
        {faq.map((f) => (
          <div class="sge-faq-item">
            <button class="sge-faq-q" aria-expanded="false">
              <span>{f.q}</span>
              <i class="sge-faq-plus" aria-hidden="true"></i>
            </button>
            <div class="sge-faq-a"><p>{f.a}</p></div>
          </div>
        ))}
      </div>
    </section>

    <!-- ============================================================
         12 — FECHAMENTO + CTA FINAL
    ============================================================ -->
    <section class="sge-sec sge-close reveal">
      <span class="sge-tag">A decisão</span>
      <h2 class="sge-h2">Daqui alguns meses você terá duas opções.</h2>
      <div class="sge-paths">
        <div class="sge-path sge-path--bad">
          <span class="sge-path-tag">Opção 1</span>
          <p>Continuar repetindo os mesmos treinos.</p>
          <p>Continuar tentando descobrir sozinho o que funciona.</p>
          <p>Continuar voltando para casa pensando:</p>
          <span class="sge-path-quote">“Dava para ter pego.”</span>
        </div>
        <div class="sge-path sge-path--good">
          <span class="sge-path-tag">Opção 2</span>
          <p>Ou finalmente seguir um plano construído para transformar seu esforço em desempenho dentro do gol.</p>
        </div>
      </div>

      <p class="sge-final-q">Quando esta temporada terminar, você estará jogando no seu melhor nível?</p>

      <a href={WHATSAPP} target="_blank" rel="noopener" class="sge-cta sge-cta--final" data-cta>
        <svg viewBox="0 0 24 24" aria-hidden="true" class="sge-wa-ico"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884"/></svg>
        <span>{CTA}</span>
      </a>
      <p class="sge-micro">Clique no botão, fale com a equipe e descubra se o acompanhamento faz sentido para você.</p>
    </section>

    <!-- ============================================================
         RODAPÉ
    ============================================================ -->
    <footer class="sge-footer">
      <div class="sge-foot-brand">SISTEMA GOLEIRO DE ELITE™</div>
      <p class="sge-foot-tag">Preparação física específica para goleiros que levam o jogo a sério.</p>
      <a href={WHATSAPP} target="_blank" rel="noopener" class="sge-foot-wa">Falar no WhatsApp</a>
      <div class="sge-foot-legal">© 2026 · Todos os direitos reservados</div>
    </footer>

    <!-- Botão flutuante de WhatsApp (mobile + desktop), aparece após o hero -->
    <a id="sge-float" href={WHATSAPP} target="_blank" rel="noopener" class="sge-float" aria-label="Falar no WhatsApp" data-cta>
      <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/></svg>
    </a>

  </main>
</Base>

<style>
  /* ── PALETA — chumbo/preto + dourado elite + verde whatsapp ── */
  .sge {
    --bg:    #08090b;
    --bg2:   #0d0f12;
    --card:  #14171c;
    --card2: #181c22;
    --border:#252a32;
    --gold:  #e8b95a;
    --gold-d:#c79a3e;
    --white: #f3f5f7;
    --gray:  #9aa1ab;
    --muted: #5d646e;
    --green: #25d366;
    --red:   #c0563f;

    position: relative;
    z-index: 1;
    width: 100%;
    background: var(--bg);
    color: var(--white);
    font-family: 'Barlow', system-ui, sans-serif;
    overflow-x: hidden;
  }
  .sge * { box-sizing: border-box; }

  /* ── HERO ── */
  .sge-hero {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 0 20px 56px;
    overflow: hidden;
  }
  /* banner do programa no topo */
  .sge-hero-media {
    position: relative;
    width: calc(100% + 40px);
    margin: 0 -20px;
    max-width: 920px;
  }
  .sge-hero-img {
    width: 100%; height: auto; display: block;
    animation: sgeUp .8s ease both;
  }
  /* degradê na base da imagem para fundir com o fundo */
  .sge-hero-fade {
    position: absolute; left: 0; right: 0; bottom: -1px;
    height: 38%;
    background: linear-gradient(180deg, transparent 0%, rgba(8,9,11,.55) 55%, var(--bg) 100%);
    pointer-events: none;
  }
  .sge-hero-inner {
    position: relative; z-index: 2;
    max-width: 760px;
    /* headline sobrepõe levemente a base da imagem */
    margin-top: -42px;
    display: flex; flex-direction: column; align-items: center;
    animation: sgeUp .8s .1s ease both;
  }
  .sge-hero-h1 {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 800;
    font-size: clamp(2rem, 7vw, 3.6rem);
    line-height: 1.04;
    letter-spacing: -.01em;
    text-transform: uppercase;
    margin-bottom: 22px;
  }
  .sge-hl { color: var(--gold); }
  .sge-hero-sub {
    font-size: clamp(1rem, 2.4vw, 1.18rem);
    line-height: 1.55;
    color: var(--gray);
    max-width: 620px;
    margin-bottom: 34px;
  }
  .sge-hero-stats {
    display: flex; align-items: center; gap: 18px;
    margin-top: 38px;
  }
  .sge-hero-stats > div { display: flex; flex-direction: column; }
  .sge-hero-stats strong {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1.9rem; line-height: 1; color: var(--white);
  }
  .sge-hero-stats span {
    font-size: .72rem; text-transform: uppercase; letter-spacing: .12em; color: var(--muted);
  }
  .sge-hero-stats i { width: 1px; height: 30px; background: var(--border); }

  /* ── CTA principal ── */
  .sge-cta {
    display: inline-flex; align-items: center; justify-content: center; gap: 12px;
    background: var(--green);
    color: #04220f;
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 800;
    font-size: clamp(.95rem, 2.6vw, 1.15rem);
    text-transform: uppercase;
    letter-spacing: .02em;
    text-decoration: none;
    padding: 18px 30px;
    border-radius: 14px;
    line-height: 1.1;
    box-shadow: 0 10px 34px rgba(37,211,102,.32);
    transition: transform .18s ease, box-shadow .18s ease, background .18s ease;
    animation: sgePulse 2.6s ease-in-out infinite;
  }
  .sge-cta:hover { transform: translateY(-3px); box-shadow: 0 16px 44px rgba(37,211,102,.46); background: #2ee572; }
  .sge-cta--final { max-width: 600px; margin: 8px auto 0; }
  .sge-wa-ico { width: 24px; height: 24px; fill: #04220f; flex-shrink: 0; }
  @keyframes sgePulse {
    0%,100% { box-shadow: 0 10px 34px rgba(37,211,102,.32); }
    50%     { box-shadow: 0 10px 34px rgba(37,211,102,.32), 0 0 0 8px rgba(37,211,102,.06); }
  }

  /* ── SEÇÕES BASE ── */
  .sge-sec {
    max-width: 760px;
    margin: 0 auto;
    padding: 64px 20px;
    border-top: 1px solid var(--border);
  }
  .sge-tag {
    display: inline-block;
    font-family: 'JetBrains Mono', monospace;
    font-size: .72rem; font-weight: 700;
    letter-spacing: .22em; text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 16px;
  }
  .sge-tag::before { content: '// '; color: var(--muted); }
  .sge-h2 {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 800;
    font-size: clamp(1.6rem, 5vw, 2.5rem);
    line-height: 1.08;
    text-transform: uppercase;
