    .sge-pillars { grid-template-columns: repeat(2, 1fr); }
    .sge-pillars .sge-pillar:nth-child(5) { grid-column: 1 / -1; }
    .sge-testis { grid-template-columns: repeat(3, 1fr); }
    .sge-deliv  { grid-template-columns: repeat(4, 1fr); }
    .sge-paths  { grid-template-columns: 1fr 1fr; }
  }

  @media (prefers-reduced-motion: reduce) {
    .sge-cta { animation: none; }
    .reveal { transition: none; opacity: 1; transform: none; }
  }
</style>

<script>
  // Reveal ao rolar
  const obs = new IntersectionObserver((entries) => {
    entries.forEach((e) => { if (e.isIntersecting) e.target.classList.add('in'); });
  }, { threshold: 0.08 });
  document.querySelectorAll('.reveal').forEach((el) => obs.observe(el));

  // Botão flutuante só ativa quando o lead chega no CTA final (e fica ativo dali em diante)
  const float = document.getElementById('sge-float');
  const finalCta = document.querySelector('.sge-cta--final');
  if (float && finalCta) {
    const floatObs = new IntersectionObserver((entries) => {
      if (entries[0].isIntersecting) {
        float.classList.add('is-visible');
        floatObs.disconnect();
      }
    }, { threshold: 0 });
    floatObs.observe(finalCta);
  }

  // FAQ acordeão (abre um, fecha os outros)
  document.querySelectorAll<HTMLButtonElement>('.sge-faq-q').forEach((btn) => {
    btn.addEventListener('click', () => {
      const isOpen = btn.getAttribute('aria-expanded') === 'true';
      document.querySelectorAll<HTMLButtonElement>('.sge-faq-q').forEach((b) => {
        b.setAttribute('aria-expanded', 'false');
        (b.nextElementSibling as HTMLElement)?.classList.remove('open');
      });
      if (!isOpen) {
        btn.setAttribute('aria-expanded', 'true');
        (btn.nextElementSibling as HTMLElement)?.classList.add('open');
      }
    });
  });
</script>
