  .sge-float svg { width: 30px; height: 30px; fill: #fff; }
  .sge-float.is-visible { opacity: 1; transform: translateY(0) scale(1); pointer-events: auto; }
  .sge-float:hover { background: #1fbd57; transform: scale(1.08); }

  /* ── REVEAL ── */
  .reveal { opacity: 0; transform: translateY(26px); transition: opacity .6s ease, transform .6s ease; }
  .reveal.in { opacity: 1; transform: translateY(0); }

  @keyframes sgeUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }

  /* ── RESPONSIVO (desktop) ── */
  @media (min-width: 720px) {
    .sge-hero { padding-bottom: 64px; }
