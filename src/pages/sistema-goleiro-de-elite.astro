<style>
  /* ── PALETA — chumbo/preto + dourado elite + verde whatsapp ── */
  .sge {
    --bg:    #000000;
    --bg2:   #0d0f12;
    --card:  #14171c;
    --card2: #181c22;
    --border:#252a32;
    --gold:  #e8b95a;
    --gold-d:#c79a3e;
    --white: #f3f5f7;
    --gray:  #9aa1ab;
    --muted: #5d646e;
    --green: #25d366;
    --red:   #c0563f;

    position: relative;
    z-index: 1;
    width: 100%;
    background: var(--bg);
    color: var(--white);
    font-family: 'Barlow', system-ui, sans-serif;
    overflow-x: hidden;
  }
  .sge * { box-sizing: border-box; }

  /* ── HERO ── */
  .sge-hero {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 0 20px 56px;
    overflow: hidden;
  }
  /* banner do programa no topo */
  .sge-hero-media {
    position: relative;
    width: calc(100% + 40px);
    margin: 0 -20px;
    max-width: 920px;
  }
  .sge-hero-img {
    width: 100%; height: auto; display: block;
    animation: sgeUp .8s ease both;
  }
  /* degradê na base da imagem para fundir com o fundo */
  .sge-hero-fade {
    position: absolute; left: 0; right: 0; bottom: -1px;
    height: 38%;
    background: linear-gradient(180deg, transparent 0%, rgba(8,9,11,.55) 55%, var(--bg) 100%);
    pointer-events: none;
  }
  .sge-hero-inner {
    position: relative; z-index: 2;
    max-width: 760px;
    /* headline sobrepõe levemente a base da imagem */
    margin-top: -42px;
    display: flex; flex-direction: column; align-items: center;
  }
  /* page-load orquestrado: entrada em cascata */
  .sge-hero-h1   { animation: sgeUp .7s .15s ease both; }
  .sge-hero-sub  { animation: sgeUp .7s .32s ease both; }
  .sge-hero-stats{ animation: sgeUp .7s .48s ease both; }
  .sge-hero-h1 {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 800;
    font-size: clamp(2rem, 7vw, 3.6rem);
    line-height: 1.04;
    letter-spacing: -.01em;
    text-transform: uppercase;
    margin-bottom: 22px;
  }
  .sge-hl { color: var(--gold); }
  .sge-hero-sub {
    font-size: clamp(1rem, 2.4vw, 1.18rem);
    line-height: 1.55;
    color: var(--gray);
    max-width: 620px;
    margin-bottom: 34px;
  }
  .sge-hero-stats {
    display: flex; align-items: center; gap: 18px;
    margin-top: 38px;
  }
  .sge-hero-stats > div { display: flex; flex-direction: column; }
  .sge-hero-stats strong {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1.9rem; line-height: 1; color: var(--white);
  }
  .sge-hero-stats span {
    font-size: .72rem; text-transform: uppercase; letter-spacing: .12em; color: var(--muted);
  }
  .sge-hero-stats i { width: 1px; height: 30px; background: var(--border); }

  /* ── CTA principal ── */
  .sge-cta {
    position: relative;
    overflow: hidden;
    display: inline-flex; align-items: center; justify-content: center; gap: 12px;
    background: linear-gradient(180deg, #2ee572 0%, var(--green) 55%, #1fc35b 100%);
    color: #04220f;
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 800;
    font-size: clamp(.98rem, 2.7vw, 1.2rem);
    text-transform: uppercase;
    letter-spacing: .02em;
    text-decoration: none;
    padding: 19px 32px;
    border-radius: 14px;
    line-height: 1.1;
    box-shadow: 0 10px 34px rgba(37,211,102,.32);
    transition: transform .18s ease, box-shadow .18s ease, filter .18s ease;
    animation: sgeGlow 2.4s ease-in-out infinite;
  }
  /* brilho varrendo */
  .sge-cta::before {
    content: '';
    position: absolute; top: 0; bottom: 0; left: -80%;
    width: 55%;
    background: linear-gradient(120deg, transparent, rgba(255,255,255,.55), transparent);
    transform: skewX(-22deg);
    animation: sgeShine 3.4s ease-in-out infinite;
    pointer-events: none;
  }
  .sge-cta > * { position: relative; z-index: 1; }
  .sge-cta:hover { transform: translateY(-3px) scale(1.015); box-shadow: 0 18px 50px rgba(37,211,102,.5); filter: brightness(1.05); }
  .sge-cta:active { transform: translateY(-1px) scale(.99); }
  .sge-cta--final { width: 100%; max-width: 560px; margin: 6px auto 0; }
  .sge-wa-ico { width: 24px; height: 24px; fill: #04220f; flex-shrink: 0; }
  @keyframes sgeGlow {
    0%,100% { box-shadow: 0 10px 34px rgba(37,211,102,.3); }
    50%     { box-shadow: 0 12px 40px rgba(37,211,102,.42), 0 0 0 6px rgba(37,211,102,.08); }
  }
  @keyframes sgeShine {
    0%      { left: -80%; }
    55%,100%{ left: 130%; }
  }

  /* ── SEÇÕES BASE ── */
  .sge-sec {
    max-width: 760px;
    margin: 0 auto;
    padding: 64px 20px;
    border-top: 1px solid var(--border);
  }
  .sge-tag {
    display: inline-block;
    font-family: 'JetBrains Mono', monospace;
    font-size: .72rem; font-weight: 700;
    letter-spacing: .22em; text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 16px;
  }
  .sge-tag::before { content: '// '; color: var(--muted); }
  .sge-h2 {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 800;
    font-size: clamp(1.6rem, 5vw, 2.5rem);
    line-height: 1.08;
    text-transform: uppercase;
    margin-bottom: 18px;
  }
  .sge-sub-h2 {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 700;
    font-size: clamp(1.15rem, 3.4vw, 1.5rem);
    color: var(--gold);
    margin-bottom: 22px;
    line-height: 1.2;
  }
  .sge-body { font-size: 1.06rem; line-height: 1.65; color: var(--gray); margin-bottom: 16px; }
  .sge-body.sge-strong { color: var(--white); font-weight: 600; }
  .sge-lead { font-size: 1.18rem; line-height: 1.6; color: var(--white); margin-bottom: 18px; }
  .sge-lead em { color: var(--gold); font-style: italic; font-weight: 600; }
  .sge-gold-text { color: var(--gold); font-weight: 600; }

  /* ── NÚMERO GIGANTE EM OUTLINE (acento assimétrico) ── */
  .sge-bignum {
    font-family: 'Bebas Neue', sans-serif;
    color: transparent;
    -webkit-text-stroke: 2px rgba(232,185,90,.22);
    line-height: .8;
    pointer-events: none;
    user-select: none;
  }
  .sge-bignum small { font-size: .5em; -webkit-text-stroke-width: 1.5px; }

  /* ── DOR (layout assimétrico) ── */
  .sge-pain { position: relative; overflow: hidden; }
  .sge-pain-body { position: relative; z-index: 1; }
  .sge-bignum--pain {
    position: absolute; z-index: 0;
    right: -12px; bottom: 40px;
    font-size: clamp(7rem, 32vw, 15rem);
    -webkit-text-stroke-width: 2.5px;
    transform: rotate(-7deg);
  }
  .sge-pain-final { font-size: 1.16rem; }
  .sge-quote {
    position: relative;
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(2.4rem, 11vw, 4.6rem);
    color: var(--gold);
    text-align: left;
    line-height: .95;
    letter-spacing: .01em;
    margin: 36px 0;
    padding-left: 18px;
    border-left: 4px solid var(--gold);
    text-shadow: 0 0 36px rgba(232,185,90,.28);
  }
  /* glow dourado por trás da frase de impacto */
  .sge-quote::before {
    content: '';
    position: absolute; left: 50%; top: 50%;
    width: 360px; height: 180px;
    transform: translate(-50%, -50%);
    background: radial-gradient(ellipse, rgba(232,185,90,.18), transparent 70%);
    filter: blur(14px);
    z-index: -1; pointer-events: none;
  }
  .sge-faltou {
    display: flex; flex-wrap: wrap; gap: 10px;
    margin: 22px 0;
  }
  .sge-faltou span {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 700; text-transform: uppercase;
    font-size: 1rem; letter-spacing: .03em;
    padding: 9px 16px;
    border: 1px solid var(--border);
    border-left: 3px solid var(--red);
    border-radius: 8px;
    background: var(--card);
  }

  /* ── INIMIGO ── */
  .sge-lies { list-style: none; margin: 0 0 22px; padding: 0; }
  .sge-lies li {
    position: relative;
    padding: 12px 12px 12px 40px;
    font-size: 1.05rem; color: var(--gray);
    border-bottom: 1px solid var(--border);
  }
  .sge-lies li::before {
    content: '✕'; position: absolute; left: 12px; top: 12px;
    color: var(--red); font-weight: 700;
  }

  /* ── BIG IDEA — faixa full-bleed assimétrica + rede de gol + glow ── */
  .sge-bigidea {
    position: relative;
    width: 100%;
    padding: 88px 20px;
    text-align: left;
    overflow: hidden;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    background: linear-gradient(180deg, #050505, #0b0b0b);
  }
  .sge-bigidea-inner { max-width: 720px; margin: 0 auto; }
  .sge-bigidea .sge-tag { margin-bottom: 18px; }
  /* malha da rede do gol, concentrada e desbotando nas bordas */
  .sge-bigidea::before {
    content: '';
    position: absolute; inset: 0; z-index: 0;
    background-image:
      repeating-linear-gradient(90deg, rgba(232,185,90,.08) 0 1px, transparent 1px 26px),
      repeating-linear-gradient(0deg,  rgba(232,185,90,.08) 0 1px, transparent 1px 26px);
    -webkit-mask-image: radial-gradient(ellipse 62% 72% at 50% 46%, #000 0%, transparent 72%);
            mask-image: radial-gradient(ellipse 62% 72% at 50% 46%, #000 0%, transparent 72%);
    pointer-events: none;
  }
  /* halo dourado por trás do título */
  .sge-bigidea::after {
    content: '';
    position: absolute; left: 50%; top: 42%; z-index: 0;
    width: 460px; height: 320px;
    transform: translate(-50%, -50%);
    background: radial-gradient(ellipse, rgba(232,185,90,.16), transparent 65%);
    filter: blur(18px);
    pointer-events: none;
  }
  .sge-bigidea > * { position: relative; z-index: 1; }
  .sge-bigidea-h {
    font-family: 'Bebas Neue', sans-serif;   /* fonte de clímax */
    font-weight: 400; text-transform: uppercase;
    font-size: clamp(2.6rem, 9vw, 5rem);
    line-height: .92;
    letter-spacing: .01em;
    margin-bottom: 16px;
    max-width: 15ch;            /* corta a linha cedo: cria respiro à direita */
  }
  .sge-strike {
    color: var(--muted);
    text-decoration: line-through;
    text-decoration-color: var(--red);
    text-decoration-thickness: 3px;
  }
  .sge-bigidea-sub {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 700;
    font-size: clamp(1.35rem, 4.6vw, 2.1rem);
    margin-bottom: 18px;
    max-width: 20ch;
  }

  /* ── MECANISMO ── */
  .sge-mech { text-align: center; }
  .sge-mech-title { color: var(--gold); }
  .sge-objective {
    background: linear-gradient(135deg, var(--card), var(--card2));
    border: 1px solid rgba(232,185,90,.3);
    border-radius: 16px;
    padding: 26px 22px;
    font-family: 'Barlow Condensed', sans-serif;
    font-size: clamp(1.2rem, 4vw, 1.65rem);
    line-height: 1.25;
    margin: 24px 0;
  }
  .sge-objective strong { color: var(--gold); }
  .sge-mech-q {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(1.8rem, 6vw, 2.8rem);
    color: var(--white);
    margin-top: 8px;
  }

  /* ── PILARES (cards) ── */
  .sge-pillars {
    display: grid; gap: 14px;
    grid-template-columns: 1fr;
    margin-top: 10px;
  }
  .sge-pillar {
    position: relative;
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 26px 22px 24px;
    overflow: hidden;
    transition: transform .2s ease, border-color .2s ease, background .2s ease;
  }
  .sge-pillar::before {
    content: ''; position: absolute; left: 0; top: 0; bottom: 0; width: 3px;
    background: linear-gradient(var(--gold), transparent);
    opacity: .55;
  }
  .sge-pillar:hover { transform: translateY(-4px); border-color: rgba(232,185,90,.45); background: var(--card2); }
  .sge-pillar:hover .sge-pillar-n { color: rgba(232,185,90,.22); -webkit-text-stroke-color: rgba(232,185,90,.5); }
  /* número gigante em outline, vazando pelo canto */
  .sge-pillar-n {
    position: absolute;
    top: -14px; right: -6px;
    font-family: 'Bebas Neue', sans-serif;
    font-size: 7rem; line-height: 1;
    color: transparent;
    -webkit-text-stroke: 1.5px rgba(232,185,90,.28);
    pointer-events: none;
    transition: color .2s ease, -webkit-text-stroke-color .2s ease;
  }
  .sge-pillar-body { position: relative; z-index: 1; }
  .sge-pillar-t {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 700; text-transform: uppercase;
    font-size: 1.3rem; margin-bottom: 8px;
    max-width: 78%;
  }
  .sge-pillar-d { font-size: 1rem; line-height: 1.55; color: var(--gray); }

  /* ── TRANSFORMAÇÃO ── */
  .sge-transform-list { list-style: none; margin: 8px 0 0; padding: 0; }
  .sge-transform-list li {
    position: relative;
    padding: 13px 12px 13px 40px;
    font-size: 1.08rem; color: var(--white);
    border-bottom: 1px solid var(--border);
  }
  .sge-transform-list li::before {
    content: '✓'; position: absolute; left: 12px; top: 13px;
    color: var(--green); font-weight: 800;
  }

  /* ── DEPOIMENTOS ── */
  .sge-testis {
    display: grid; gap: 14px;
    grid-template-columns: 1fr;
    margin: 32px 0 0;
  }
  .sge-testi {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 22px;
    margin: 0;
  }
  .sge-stars { color: var(--gold); letter-spacing: 2px; font-size: .95rem; margin-bottom: 10px; }
  .sge-testi blockquote {
    font-size: 1.08rem; line-height: 1.55; color: var(--white);
    margin: 0 0 16px; font-style: italic;
  }
  .sge-testi figcaption {
    display: flex; align-items: center; gap: 10px;
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 700; text-transform: uppercase; letter-spacing: .03em;
    color: var(--gray);
  }
  .sge-avatar {
    width: 34px; height: 34px; border-radius: 50%;
    display: grid; place-items: center;
    background: linear-gradient(135deg, var(--gold), var(--gold-d));
    color: #1a1303; font-weight: 800;
  }

  /* carrossel de prints */
  .sge-carousel-wrap { position: relative; }
  .sge-carousel {
    display: flex; gap: 16px;
    align-items: center;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    padding: 4px 2px 16px;
    scrollbar-width: none;
  }
  .sge-carousel::-webkit-scrollbar { display: none; }
  /* largura fixa, altura livre → imagem inteira, sem cortes */
  .sge-slide {
    flex: 0 0 auto;
    scroll-snap-align: center;
    width: min(84vw, 360px);
    margin: 0;
    border: 1px solid var(--border);
    border-radius: 14px;
    background: var(--bg2);
    overflow: hidden;
  }
  .sge-slide img { width: 100%; height: auto; display: block; }
  /* setas (desktop) */
  .sge-car-arrow {
    position: absolute; top: 50%; transform: translateY(-50%);
    z-index: 3;
    width: 44px; height: 44px; border-radius: 50%;
    background: rgba(13,15,18,.92); border: 1px solid var(--border);
    color: var(--gold); font-size: 1.7rem; line-height: 1;
    cursor: pointer; display: none;
    align-items: center; justify-content: center;
    transition: border-color .15s, background .15s;
  }
  .sge-car-arrow:hover { border-color: var(--gold); background: var(--card2); }
  .sge-car-arrow--prev { left: -8px; }
  .sge-car-arrow--next { right: -8px; }
  .sge-proof-note { font-size: .82rem; color: var(--muted); text-align: center; margin-top: 12px; }

  @media (min-width: 720px) {
    .sge-slide { width: 400px; }
    .sge-car-arrow { display: flex; }
  }

  /* ── ENTREGÁVEIS ── */
  .sge-deliv {
    display: grid; gap: 12px;
    grid-template-columns: 1fr 1fr;
    margin-top: 8px;
  }
  .sge-deliv-card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 20px 18px;
    transition: transform .2s ease, border-color .2s ease;
  }
  .sge-deliv-card:hover { transform: translateY(-3px); border-color: rgba(232,185,90,.4); }
  .sge-deliv-card:hover .sge-deliv-i { background: rgba(232,185,90,.14); border-color: rgba(232,185,90,.4); }
  .sge-deliv-i {
    width: 46px; height: 46px;
    display: grid; place-items: center;
    margin-bottom: 14px;
    border-radius: 12px;
    color: var(--gold);
    background: rgba(232,185,90,.08);
    border: 1px solid rgba(232,185,90,.2);
    transition: background .2s ease, border-color .2s ease;
  }
  .sge-deliv-i svg { width: 24px; height: 24px; }
  .sge-deliv-t {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 700; text-transform: uppercase;
    font-size: 1.1rem; line-height: 1.1; margin-bottom: 6px;
  }
  .sge-deliv-d { font-size: .92rem; line-height: 1.45; color: var(--gray); }

  /* ── FAQ ACORDEÃO ── */
  .sge-faq { margin-top: 8px; }
  .sge-faq-item {
    border: 1px solid var(--border);
    border-radius: 12px;
    background: var(--card);
    margin-bottom: 10px;
    overflow: hidden;
  }
  .sge-faq-q {
    width: 100%;
    display: flex; align-items: center; justify-content: space-between; gap: 14px;
    background: none; border: none; cursor: pointer;
    text-align: left;
    color: var(--white);
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 700; font-size: 1.12rem;
    padding: 18px 18px;
  }
  .sge-faq-q[aria-expanded='true'] { color: var(--gold); }
  .sge-faq-plus {
    position: relative; width: 16px; height: 16px; flex-shrink: 0;
  }
  .sge-faq-plus::before, .sge-faq-plus::after {
    content: ''; position: absolute; background: var(--gold);
    transition: transform .25s ease;
  }
  .sge-faq-plus::before { left: 0; top: 7px; width: 16px; height: 2px; }
  .sge-faq-plus::after  { left: 7px; top: 0; width: 2px; height: 16px; }
  .sge-faq-q[aria-expanded='true'] .sge-faq-plus::after { transform: scaleY(0); }
  .sge-faq-a {
    max-height: 0; overflow: hidden;
    transition: max-height .3s ease;
  }
  .sge-faq-a.open { max-height: 240px; }
  .sge-faq-a p {
    padding: 0 18px 18px;
    font-size: 1rem; line-height: 1.6; color: var(--gray);
  }

  /* ── FECHAMENTO ── */
  .sge-close { text-align: center; padding-bottom: 28px; }
  .sge-paths {
    display: grid; gap: 14px;
    grid-template-columns: 1fr;
    margin: 24px 0;
    text-align: left;
  }
  .sge-path {
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 22px;
    background: var(--card);
  }
  .sge-path p { color: var(--gray); margin-bottom: 6px; line-height: 1.5; }
  .sge-path-tag {
    font-family: 'JetBrains Mono', monospace;
    font-size: .7rem; letter-spacing: .2em; text-transform: uppercase;
    display: inline-block; margin-bottom: 12px;
  }
  .sge-path--bad { border-left: 3px solid var(--red); }
  .sge-path--bad .sge-path-tag { color: var(--red); }
  .sge-path--good { border-left: 3px solid var(--green); background: var(--card2); }
  .sge-path--good .sge-path-tag { color: var(--green); }
  .sge-path--good p { color: var(--white); font-weight: 500; }
  .sge-path-quote {
    display: block; margin-top: 8px;
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1.7rem; color: var(--muted);
  }
  /* painel destacado do CTA final */
  .sge-cta-box {
    position: relative;
    margin-top: 30px;
    padding: 32px 24px 28px;
    border-radius: 22px;
    border: 1px solid rgba(232,185,90,.28);
    background:
      radial-gradient(120% 100% at 50% 0%, rgba(37,211,102,.10), transparent 60%),
      linear-gradient(180deg, #11140f 0%, #0a0c0a 100%);
    box-shadow: 0 24px 60px rgba(0,0,0,.5), inset 0 1px 0 rgba(255,255,255,.04);
    overflow: hidden;
  }
  /* faixa de luz no topo do painel */
  .sge-cta-box::before {
    content: '';
    position: absolute; top: 0; left: 50%; transform: translateX(-50%);
    width: 70%; height: 1px;
    background: linear-gradient(90deg, transparent, var(--gold), transparent);
    opacity: .7;
  }
  .sge-cta-badge {
    display: inline-block;
    font-family: 'JetBrains Mono', monospace;
    font-size: .68rem; font-weight: 700;
    letter-spacing: .22em; text-transform: uppercase;
    color: var(--gold);
    padding: 6px 14px;
    border: 1px solid rgba(232,185,90,.35);
    border-radius: 100px;
    background: rgba(232,185,90,.06);
    margin-bottom: 16px;
  }
  .sge-final-q {
    font-family: 'Bebas Neue', sans-serif;   /* fonte de clímax */
    font-weight: 400; text-transform: uppercase;
    font-size: clamp(1.9rem, 6.5vw, 2.9rem);
    line-height: .98;
    letter-spacing: .01em;
    color: var(--white);
    margin: 0 auto 24px;
    max-width: 540px;
  }
  .sge-micro { font-size: .9rem; color: var(--muted); margin-top: 16px; }

  /* ── QUEM SOMOS — separado do fechamento, imagem flush sem bordas ── */
  .sge-whoweare {
    max-width: 760px;
    margin: 0 auto;
    padding: 52px 0 0;          /* respiro que separa do bloco anterior */
    text-align: center;
    background: #000;            /* mesmo preto da imagem */
  }
  /* divisor sutil entre o CTA e o Quem Somos */
  .sge-whoweare::before {
    content: '';
    display: block;
    width: 64px; height: 3px;
    margin: 0 auto 26px;
    border-radius: 3px;
    background: linear-gradient(90deg, var(--gold-d), var(--gold));
  }
  .sge-whoweare-kicker {
    display: inline-block;
    font-family: 'JetBrains Mono', monospace;
    font-size: .7rem; font-weight: 700;
    letter-spacing: .24em; text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 10px;
  }
  .sge-whoweare-title { padding: 0 20px; margin-bottom: 26px; }
  .sge-whoweare-img {
    width: 100%;
    height: auto;
    display: block;
    margin: 0;
    border: 0;
    border-radius: 0;
    max-width: none;
  }

  /* ── RODAPÉ ── */
  .sge-footer {
    text-align: center;
    padding: 50px 20px 104px;
    background: #000;
  }
  .sge-foot-rule {
    width: 56px; height: 3px; border-radius: 3px;
    margin: 0 auto 24px;
    background: linear-gradient(90deg, var(--gold-d), var(--gold));
  }
  .sge-foot-brand {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 800; text-transform: uppercase; letter-spacing: .06em;
    color: var(--gold); font-size: 1.4rem; line-height: 1; margin-bottom: 22px;
  }
  .sge-foot-social {
    display: flex; justify-content: center; flex-wrap: wrap; gap: 12px;
    margin-bottom: 26px;
  }
  .sge-soc {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 9px 16px;
    border-radius: 100px;
    border: 1px solid var(--border);
    background: var(--card);
    color: var(--white);
    font-size: .86rem; font-weight: 600;
    text-decoration: none;
    transition: transform .15s ease, border-color .15s ease, background .15s ease;
  }
  .sge-soc svg { width: 16px; height: 16px; flex-shrink: 0; }
  .sge-soc:hover { transform: translateY(-2px); }
  .sge-soc--wa svg { fill: var(--green); }
  .sge-soc--wa:hover { border-color: var(--green); background: rgba(37,211,102,.08); }
  .sge-soc--ig svg { fill: #e1306c; }
  .sge-soc--ig:hover { border-color: #e1306c; background: rgba(225,48,108,.08); }
  .sge-foot-meta {
    font-family: 'JetBrains Mono', monospace;
    font-size: .72rem; letter-spacing: .06em;
    color: var(--muted); line-height: 1.6;
  }

  /* ── BOTÃO FLUTUANTE WHATSAPP ── */
  .sge-float {
    position: fixed; bottom: 22px; right: 18px; z-index: 998;
    width: 58px; height: 58px; border-radius: 50%;
    background: var(--green);
    display: flex; align-items: center; justify-content: center;
    box-shadow: 0 8px 28px rgba(37,211,102,.5);
    opacity: 0; transform: translateY(16px) scale(.8);
    transition: opacity .35s ease, transform .35s ease, background .15s;
    pointer-events: none;
  }
  .sge-float svg { width: 30px; height: 30px; fill: #fff; }
  .sge-float.is-visible { opacity: 1; transform: translateY(0) scale(1); pointer-events: auto; }
  .sge-float:hover { background: #1fbd57; transform: scale(1.08); }

  /* ── REVEAL ── */
  .reveal { opacity: 0; transform: translateY(26px); transition: opacity .6s ease, transform .6s ease; }
  .reveal.in { opacity: 1; transform: translateY(0); }

  @keyframes sgeUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }

  /* ── RESPONSIVO (desktop) ── */
  @media (min-width: 720px) {
    .sge-hero { padding-bottom: 64px; }
    .sge-hero-inner { margin-top: -64px; }
    .sge-pillars { grid-template-columns: repeat(2, 1fr); }
    .sge-pillars .sge-pillar:nth-child(5) { grid-column: 1 / -1; }
    .sge-testis { grid-template-columns: repeat(3, 1fr); }
    .sge-deliv  { grid-template-columns: repeat(4, 1fr); }
    .sge-paths  { grid-template-columns: 1fr 1fr; }
  }

  @media (prefers-reduced-motion: reduce) {
    .sge-cta, .sge-cta::before { animation: none; }
    .sge-cta::before { display: none; }
    .sge-hero-img, .sge-hero-h1, .sge-hero-sub, .sge-hero-stats { animation: none; }
    .reveal { transition: none; opacity: 1; transform: none; }
  }
</style>

<script>
  // Reveal ao rolar
  const obs = new IntersectionObserver((entries) => {
    entries.forEach((e) => { if (e.isIntersecting) e.target.classList.add('in'); });
  }, { threshold: 0.08 });
  document.querySelectorAll('.reveal').forEach((el) => obs.observe(el));

  // Count-up nas estatísticas do hero
  const fmtNum = (n: number) => n.toLocaleString('pt-BR');
  const finalText = (el: HTMLElement) =>
    (el.dataset.prefix || '') + fmtNum(Number(el.dataset.to)) + (el.dataset.suffix || '');
  const counters = document.querySelectorAll<HTMLElement>('.sge-count');
  const statsEl = document.querySelector('.sge-hero-stats');
  const reduceMotion = matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (counters.length && statsEl && !reduceMotion) {
    const runCount = (el: HTMLElement) => {
      const to = Number(el.dataset.to);
      const pre = el.dataset.prefix || '', suf = el.dataset.suffix || '';
      const dur = 1300, start = performance.now();
      const tick = (now: number) => {
        const p = Math.min((now - start) / dur, 1);
        const eased = 1 - Math.pow(1 - p, 3); // easeOutCubic
        el.textContent = pre + fmtNum(Math.round(to * eased)) + suf;
        if (p < 1) requestAnimationFrame(tick);
        else el.textContent = finalText(el);
      };
      el.textContent = pre + '0' + suf;
      requestAnimationFrame(tick);
    };
    new IntersectionObserver((entries, ob) => {
      if (entries[0].isIntersecting) { counters.forEach(runCount); ob.disconnect(); }
    }, { threshold: 0.4 }).observe(statsEl);
  } else {
    counters.forEach((el) => { el.textContent = finalText(el); });
  }

  // Botão flutuante só ativa quando o lead chega no CTA final (e fica ativo dali em diante)
  const float = document.getElementById('sge-float');
  const finalCta = document.querySelector('.sge-cta--final');
  if (float && finalCta) {
    const floatObs = new IntersectionObserver((entries) => {
      if (entries[0].isIntersecting) {
        float.classList.add('is-visible');
        floatObs.disconnect();
      }
    }, { threshold: 0 });
    floatObs.observe(finalCta);
  }

  // Carrossel de provas — setas (desktop)
  document.querySelectorAll<HTMLButtonElement>('.sge-car-arrow').forEach((btn) => {
    btn.addEventListener('click', () => {
      const track = btn.closest('.sge-carousel-wrap')?.querySelector<HTMLElement>('.sge-carousel');
      if (!track) return;
      track.scrollBy({ left: Number(btn.dataset.dir) * Math.round(track.clientWidth * 0.8), behavior: 'smooth' });
    });
  });

  // FAQ acordeão (abre um, fecha os outros)
  document.querySelectorAll<HTMLButtonElement>('.sge-faq-q').forEach((btn) => {
    btn.addEventListener('click', () => {
      const isOpen = btn.getAttribute('aria-expanded') === 'true';
      document.querySelectorAll<HTMLButtonElement>('.sge-faq-q').forEach((b) => {
        b.setAttribute('aria-expanded', 'false');
        (b.nextElementSibling as HTMLElement)?.classList.remove('open');
      });
      if (!isOpen) {
        btn.setAttribute('aria-expanded', 'true');
        (btn.nextElementSibling as HTMLElement)?.classList.add('open');
      }
    });
  });
</script>
