---
import Base from '../../layouts/Base.astro';
---
<Base title="Evaluación para el Desafío Portero de Elite" heroImage="/images/desafio_portero_elite_hero.webp">
<style>
/* ─── Reset ─────────────────────────────────────────────────── */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

body {
  font-family: 'Barlow', sans-serif;
  background: var(--black);
  color: #fff;
  overflow-x: hidden;
  min-height: 100vh;
}

:root {
  --black:  #0B0B0B;
  --white:  #ffffff;
  --yellow: #F4B400;
}

/* ─── Layout principal ─────────────────────────────────────── */
.qz-wrap {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: clamp(12px,3vw,28px) clamp(16px,4vw,32px) clamp(32px,6vw,60px);
}

/* ─── Header com progress ──────────────────────────────────── */
.qz-head {
  width: 100%;
  max-width: 720px;
  margin-bottom: clamp(18px,3vw,32px);
}
.qz-prog {
  display: flex;
  align-items: center;
  gap: 14px;
}
.qz-prog-track {
  flex: 1;
  height: 3px;
  background: rgba(255,255,255,.08);
  border-radius: 2px;
  overflow: hidden;
}
.qz-prog-fill {
  height: 100%;
  background: linear-gradient(90deg, #F4C400, #E0A800);
  width: 12.5%;
  transition: width .4s ease;
}
.qz-prog-label {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: .68rem;
  font-weight: 700;
  letter-spacing: .14em;
  text-transform: uppercase;
  color: rgba(255,255,255,.5);
  white-space: nowrap;
  min-width: 110px;
  text-align: right;
}

/* ─── Hero intro (step-intro) ──────────────────────────────── */
.qz-hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: clamp(16px,3vw,28px);
}
.qz-hero-media {
  width: 100%;
  max-width: 320px;
  max-height: 32vh;
  display: flex;
  justify-content: center;
}
.qz-hero-media img {
  width: 100%;
  max-height: 32vh;
  height: auto;
  display: block;
  border-radius: 16px;
  object-fit: contain;
}
.qz-hero-text {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  gap: 18px;
}
.qz-hero-eyebrow {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: .7rem;
  font-weight: 700;
  letter-spacing: .24em;
  text-transform: uppercase;
  color: var(--yellow);
}
.qz-hero-headline {
  font-family: 'Bebas Neue', sans-serif;
  font-size: clamp(1.5rem, 4vw, 2.6rem);
  line-height: 1.0;
  color: var(--white);
  letter-spacing: .01em;
  margin: -2px 0;
}
.qz-hero-headline .yl { color: var(--yellow); }
.qz-hero-sub {
  font-size: clamp(.85rem, 1.3vw, 1rem);
  color: rgba(255,255,255,.55);
  line-height: 1.45;
  max-width: 480px;
}
.qz-hero-cta {
  position: relative;
  overflow: hidden;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 10px;
  padding: 18px 36px;
  margin-top: 4px;
  border-radius: 14px;
  background: linear-gradient(180deg, #F4C400 0%, #E0A800 100%);
  box-shadow: 0 16px 40px rgba(244,180,0,.28);
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 1.02rem;
  font-weight: 700;
  letter-spacing: .14em;
  text-transform: uppercase;
  color: var(--black);
  text-decoration: none;
  border: none;
  cursor: pointer;
  transition: opacity .15s, transform .2s, box-shadow .3s;
  animation: ctaPulse 2.6s ease-in-out infinite;
}
.qz-hero-cta:hover {
  opacity: .95;
  transform: translateY(-3px);
  box-shadow: 0 24px 60px rgba(244,180,0,.5);
  animation-play-state: paused;
}
.qz-hero-cta::after {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(120deg, transparent 30%, rgba(255,255,255,.55) 50%, transparent 70%);
  transform: translateX(-100%);
  transition: transform .7s ease;
  pointer-events: none;
}
.qz-hero-cta:hover::after { transform: translateX(100%); }
@media (max-width: 540px) {
  .qz-hero-media { max-width: 100%; }
  .qz-hero-media img { border-radius: 12px; }
}

/* ─── Stage e steps ────────────────────────────────────────── */
.qz-stage {
  width: 100%;
  max-width: 720px;
  position: relative;
}
.step {
  display: none;
  animation: stepIn .4s ease both;
}
.step.active { display: block; }
@keyframes stepIn {
  from { opacity: 0; transform: translateY(10px); }
  to   { opacity: 1; transform: none; }
}

/* ─── Pregunta ─────────────────────────────────────────────── */
.q-num {
  font-family: 'JetBrains Mono', monospace;
  font-size: .72rem;
  font-weight: 700;
  letter-spacing: .12em;
  color: rgba(255,255,255,.3);
  margin-bottom: 10px;
}
.q-num::before { content: '// '; }
.q-text {
  font-family: 'Bebas Neue', sans-serif;
  font-size: clamp(1.8rem, 4.2vw, 2.8rem);
  line-height: 1.05;
  color: var(--white);
  letter-spacing: .01em;
  margin-bottom: clamp(28px,4vw,40px);
}
.q-text .yl { color: var(--yellow); }

/* ─── Opciones ─────────────────────────────────────────────── */
.opts {
  display: flex;
  flex-direction: column;
  gap: 12px;
}
.opt {
  width: 100%;
  text-align: left;
  cursor: pointer;
  background: rgba(255,255,255,.025);
  border: 1px solid rgba(255,255,255,.08);
  border-radius: 14px;
  padding: 18px 22px;
  font-family: 'Barlow', sans-serif;
  color: var(--white);
  display: flex;
  flex-direction: column;
  gap: 4px;
  transition: transform .25s ease, border-color .25s, background .25s, box-shadow .25s;
}
.opt:hover {
  transform: translateY(-2px);
  border-color: rgba(244,180,0,.45);
  background: rgba(244,180,0,.06);
  box-shadow: 0 16px 36px rgba(244,180,0,.18);
}
.opt:focus-visible {
  outline: 2px solid var(--yellow);
  outline-offset: 2px;
}
.opt-label {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 1.05rem;
  font-weight: 700;
  letter-spacing: .04em;
  text-transform: uppercase;
  color: var(--white);
}
.opt-desc {
  font-size: .82rem;
  color: rgba(255,255,255,.55);
  line-height: 1.4;
}

/* ─── Botão volver ─────────────────────────────────────────── */
.qz-back {
  margin-top: 22px;
  background: none;
  border: none;
  font-family: 'Barlow Condensed', sans-serif;
  font-size: .74rem;
  font-weight: 600;
  letter-spacing: .14em;
  text-transform: uppercase;
  color: rgba(255,255,255,.35);
  cursor: pointer;
  padding: 6px 10px 6px 0;
  transition: color .2s;
}
.qz-back:hover { color: var(--yellow); }

/* ─── VSL ──────────────────────────────────────────────────── */
.vsl-eyebrow {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: .62rem;
  font-weight: 700;
  letter-spacing: .24em;
  text-transform: uppercase;
  color: var(--yellow);
  margin-bottom: 8px;
  text-align: center;
}
.vsl-title {
  font-family: 'Bebas Neue', sans-serif;
  font-size: clamp(1.3rem, 3.2vw, 1.8rem);
  line-height: 1.05;
  margin-bottom: 16px;
  text-align: center;
}
.vsl-frame {
  background: #161616;
  border: 1px solid rgba(255,255,255,.08);
  border-radius: 18px;
  aspect-ratio: 16 / 9;
  display: flex;
  align-items: center;
  justify-content: center;
  color: rgba(255,255,255,.3);
  font-family: 'JetBrains Mono', monospace;
  font-size: .8rem;
  margin-bottom: 28px;
}
.vsl-continue {
  width: 100%;
  position: relative;
  overflow: hidden;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 10px;
  padding: 18px 30px;
  border-radius: 14px;
  background: linear-gradient(180deg, #F4C400 0%, #E0A800 100%);
  box-shadow: 0 16px 40px rgba(244,180,0,.3);
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 1.02rem;
  font-weight: 700;
  letter-spacing: .14em;
  text-transform: uppercase;
  color: var(--black);
  text-decoration: none;
  border: none;
  cursor: pointer;
  transition: opacity .15s, transform .2s, box-shadow .3s;
}
.vsl-continue:hover {
  opacity: .95;
  transform: translateY(-2px);
  box-shadow: 0 22px 50px rgba(244,180,0,.45);
}
.vsl-continue::after {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(120deg, transparent 30%, rgba(255,255,255,.5) 50%, transparent 70%);
  transform: translateX(-100%);
  transition: transform .7s ease;
  pointer-events: none;
}
.vsl-continue:hover::after { transform: translateX(100%); }
.vsl-continue.is-hidden {
  opacity: 0;
  pointer-events: none;
}
.vsl-continue {
  transition: opacity .6s ease, transform .2s, box-shadow .3s;
}

/* ─── Resultado ────────────────────────────────────────────── */
.result-eyebrow {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: .68rem;
  font-weight: 700;
  letter-spacing: .24em;
  text-transform: uppercase;
  color: var(--yellow);
  text-align: center;
  margin-bottom: 12px;
}
.result-headline {
  font-family: 'Bebas Neue', sans-serif;
  font-size: clamp(2rem, 5vw, 3.2rem);
  line-height: 1.02;
  text-align: center;
  color: var(--white);
  letter-spacing: .01em;
  margin-bottom: 18px;
}
.result-headline .yl { color: var(--yellow); }
.result-diag {
  font-size: .98rem;
  color: rgba(255,255,255,.65);
  line-height: 1.55;
  text-align: center;
  margin-bottom: 32px;
  max-width: 540px;
  margin-left: auto;
  margin-right: auto;
}
.result-diag strong { color: var(--white); }

/* ─── Bloco de cupos (resultado) ──────────────────────────── */
.result-vagas {
  max-width: 480px;
  margin: 0 auto 24px;
  text-align: center;
}
.result-vagas-label {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: .68rem;
  font-weight: 700;
  letter-spacing: .22em;
  text-transform: uppercase;
  color: rgba(255,255,255,.4);
  margin-bottom: 12px;
}
.result-vagas-label span { color: var(--yellow); }
.result-vagas-bar {
  height: 3px;
  background: rgba(255,255,255,.08);
  border-radius: 2px;
  overflow: hidden;
  margin-bottom: 10px;
}
.result-vagas-fill {
  height: 100%;
  background: linear-gradient(90deg, #F4C400, #E0A800);
  width: 74.3%;
}
.result-vagas-text {
  font-size: .76rem;
  color: rgba(255,255,255,.5);
  letter-spacing: .03em;
}
.result-vagas-text strong { color: var(--yellow); font-weight: 700; }

/* ─── Plan card (copia da landing) ─────────────────────────── */
.plan-card {
  border: 1px solid rgba(255,255,255,.1);
  outline: 1px solid rgba(244,180,0,.18);
  border-radius: 24px;
  padding: 6px;
  max-width: 480px;
  margin: 0 auto;
  animation: planPulse 3.5s ease-in-out infinite;
}
@keyframes planPulse {
  0%, 100% { outline-color: rgba(244,180,0,.18); box-shadow: 0 0 0 rgba(244,180,0,0); }
  50%      { outline-color: rgba(244,180,0,.4);  box-shadow: 0 0 80px rgba(244,180,0,.1); }
}
.plan-inner {
  position: relative;
  overflow: hidden;
  border-radius: 18px;
  background: linear-gradient(160deg, rgba(255,255,255,.08) 0%, rgba(255,255,255,.02) 100%);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
}
.plan-inner::before {
  content: '';
  position: absolute;
  inset: 0;
  background: radial-gradient(60% 50% at 70% 0%, rgba(244,180,0,.2), transparent 70%);
  pointer-events: none;
}
.plan-body { padding: 28px; position: relative; }
.plan-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  margin-bottom: 8px;
}
.plan-label {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: .65rem;
  font-weight: 700;
  letter-spacing: .2em;
  text-transform: uppercase;
  color: rgba(255,255,255,.5);
}
.plan-badge {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  border-radius: 9999px;
  background: rgba(244,180,0,.15);
  border: 1px solid rgba(244,180,0,.25);
  padding: 4px 10px;
  font-family: 'Barlow Condensed', sans-serif;
  font-size: .58rem;
  font-weight: 700;
  letter-spacing: .1em;
  text-transform: uppercase;
  color: var(--yellow);
}
.plan-price {
  font-family: 'Bebas Neue', sans-serif;
  font-size: clamp(3.5rem,10vw,5rem);
  color: var(--white);
  line-height: 1;
  letter-spacing: -.01em;
  margin-top: 4px;
}
.plan-price sup { font-size: 1.7rem; vertical-align: super; color: var(--yellow); }
.plan-period {
  font-size: .76rem;
  color: rgba(255,255,255,.35);
  margin-top: 2px;
  margin-bottom: 24px;
}
.plan-btn {
  position: relative;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  padding: 16px 24px;
  border-radius: 14px;
  background: linear-gradient(180deg, #F4C400 0%, #E0A800 100%);
  box-shadow: 0 12px 36px rgba(244,180,0,.32);
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 1rem;
  font-weight: 700;
  letter-spacing: .14em;
  text-transform: uppercase;
  color: var(--black);
  text-decoration: none;
  transition: opacity .15s, transform .2s, box-shadow .3s;
  margin-bottom: 28px;
  animation: ctaPulse 2.6s ease-in-out infinite;
}
@keyframes ctaPulse {
  0%, 100% { box-shadow: 0 12px 36px rgba(244,180,0,.32); }
  50%      { box-shadow: 0 18px 52px rgba(244,180,0,.5); }
}
.plan-btn:hover {
  opacity: .95;
  transform: translateY(-2px);
  box-shadow: 0 20px 50px rgba(244,180,0,.5);
  animation-play-state: paused;
}
.plan-btn::after {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(120deg, transparent 30%, rgba(255,255,255,.55) 50%, transparent 70%);
  transform: translateX(-100%);
  transition: transform .7s ease;
  pointer-events: none;
}
.plan-btn:hover::after { transform: translateX(100%); }
.plan-divider {
  height: 1px;
  background: rgba(255,255,255,.07);
  margin-bottom: 22px;
}
.plan-features { list-style: none; display: flex; flex-direction: column; gap: 12px; }
.plan-features li {
  display: flex;
  align-items: flex-start;
  gap: 10px;
  font-size: .88rem;
  color: rgba(255,255,255,.72);
  line-height: 1.4;
}
.plan-check {
  width: 18px;
  height: 18px;
  flex-shrink: 0;
  border-radius: 50%;
  background: rgba(244,180,0,.12);
  border: 1px solid rgba(244,180,0,.3);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 1px;
}

/* ─── PROOF CAROUSEL (copia da landing) ────────────────────── */
.proof-clip {
  overflow: hidden;
  width: 100%;
  margin: clamp(28px,4vw,40px) 0;
}
.proof-carousel-outer {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  perspective: 1200px;
}
.proof-track {
  position: relative;
  width: 100%;
  height: 460px;
  display: flex;
  align-items: center;
  justify-content: center;
  transform-style: preserve-3d;
}
.proof-slide {
  position: absolute;
  width: 260px;
  height: 400px;
  border-radius: 20px;
  overflow: hidden;
  border: 1px solid rgba(255,255,255,.1);
  transition: transform .5s ease, opacity .5s ease, filter .5s ease, box-shadow .5s ease, border-color .5s ease;
  cursor: pointer;
}
.proof-slide img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}
.proof-slide-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to top, rgba(0,0,0,.88) 0%, rgba(0,0,0,.2) 55%, transparent 100%);
}
.proof-caption {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 18px 18px 22px;
  z-index: 2;
}
.proof-role-pill {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  border-radius: 9999px;
  background: rgba(255,255,255,.08);
  border: 1px solid rgba(255,255,255,.15);
  padding: 3px 10px;
  font-family: 'Barlow Condensed', sans-serif;
  font-size: .62rem;
  letter-spacing: .08em;
  color: rgba(255,255,255,.75);
  margin-bottom: 7px;
}
.proof-slide-name {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 1.25rem;
  font-weight: 700;
  letter-spacing: .03em;
  color: var(--white);
  line-height: 1.1;
}
.proof-active-badge {
  display: none;
  position: absolute;
  top: 14px;
  right: 14px;
  z-index: 3;
  background: var(--yellow);
  color: var(--black);
  font-family: 'Barlow Condensed', sans-serif;
  font-size: .6rem;
  font-weight: 700;
  letter-spacing: .1em;
  text-transform: uppercase;
  border-radius: 9999px;
  padding: 4px 10px;
}
.proof-slide.is-active { border-color: rgba(244,180,0,.5); }
.proof-slide.is-active .proof-active-badge { display: block; }
.proof-nav {
  position: absolute;
  z-index: 20;
  width: 44px;
  height: 44px;
  border-radius: 50%;
  background: rgba(0,0,0,.55);
  border: 1px solid rgba(255,255,255,.1);
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  color: var(--white);
  transition: background .2s;
  flex-shrink: 0;
}
.proof-nav:hover { background: rgba(255,255,255,.08); }
.proof-nav-prev { left: 0; }
.proof-nav-next { right: 0; }

/* ─── Mobile tweaks ────────────────────────────────────────── */
@media (max-width: 540px) {
  .opt { padding: 16px 18px; }
  .opt-label { font-size: 1rem; }
  .opt-desc { font-size: .78rem; }
  .plan-body { padding: 22px; }
}
</style>

<main class="qz-wrap">

  <header class="qz-head">
    <div class="qz-prog">
      <div class="qz-prog-track"><div class="qz-prog-fill" id="prog-fill"></div></div>
      <div class="qz-prog-label" id="prog-label">¿Listo?</div>
    </div>
  </header>

  <div class="qz-stage">

    <!-- ── Intro ────────────────────────────────────────────── -->
    <section class="step active" id="step-intro">
      <div class="qz-hero">
        <div class="qz-hero-media">
          <img
            src="/images/desafio_portero_elite_hero.webp"
            alt="Desafío Portero de Elite"
            width="1461"
            height="1076"
            loading="eager"
            fetchpriority="high" />
        </div>
        <div class="qz-hero-text">
          <h1 class="qz-hero-headline">
            Un plan práctico de entrenamientos para ser un portero con más
            <span class="yl">explosión, fuerza y velocidad</span>
            y empezar a cerrar el arco para tu equipo.
          </h1>
          <p class="qz-hero-sub">
            Entrenamientos físicos simples que puedes hacer en el gimnasio de tu barrio o en casa.
          </p>
          <button class="qz-hero-cta" id="intro-start">Quiero el desafío</button>
        </div>
      </div>
    </section>

    <!-- ── Q1 ───────────────────────────────────────────────── -->
    <section class="step" id="step-1">
      <div class="q-num">01 / Perfil</div>
      <h2 class="q-text">¿Cuál es tu perfil hoy?</h2>
      <div class="opts">
        <button class="opt" data-step="1" data-value="amador">
          <span class="opt-label">Portero amateur</span>
          <span class="opt-desc">Juego entre amigos, picaditos, fútbol de fin de semana</span>
        </button>
        <button class="opt" data-step="1" data-value="profissional">
          <span class="opt-label">Portero profesional</span>
          <span class="opt-desc">Juego en club o compito profesionalmente</span>
        </button>
        <button class="opt" data-step="1" data-value="base">
          <span class="opt-label">Portero de base</span>
          <span class="opt-desc">Categorías formadoras — quiero llegar al profesional</span>
        </button>
        <button class="opt" data-step="1" data-value="responsavel">
          <span class="opt-label">Padre, madre o responsable</span>
          <span class="opt-desc">Quiero ayudar a mi hijo a evolucionar</span>
        </button>
      </div>
    </section>

    <!-- ── Q2 ───────────────────────────────────────────────── -->
    <section class="step" id="step-2">
      <div class="q-num">02 / Trayectoria</div>
      <h2 class="q-text" id="q2-text">¿Hace cuánto tiempo eres portero?</h2>
      <div class="opts">
        <button class="opt" data-step="2" data-value="lt1"><span class="opt-label">Menos de 1 año</span></button>
        <button class="opt" data-step="2" data-value="1to3"><span class="opt-label">1 a 3 años</span></button>
        <button class="opt" data-step="2" data-value="3to7"><span class="opt-label">3 a 7 años</span></button>
