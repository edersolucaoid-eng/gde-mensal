          <div class="offer-items">
            <div class="offer-item offer-item--highlight">✓ Treino personalizado</div>
            <div class="offer-item offer-item--highlight">✓ Avaliação Postural</div>
            <div class="offer-item offer-item--highlight">✓ Protocolo pré-jogo</div>
            <div class="offer-item offer-item--highlight">✓ Protocolo pós-jogo</div>
            <div class="offer-item offer-item--highlight">✓ Guia Nutricional</div>
            <div class="offer-item offer-item--highlight">✓ Comunidade de Goleiros</div>
            <div class="offer-item offer-item--highlight">✓ App premium</div>
            <div class="offer-item offer-item--highlight">✓ Garantia 7 Dias</div>
            <div class="offer-item offer-item--highlight">✓ Professor no WhatsApp</div>
          </div>
          <a href="https://pay.goleirodeelite.com/checkout/209239805:1" class="buy-btn">GARANTIR MINHA VAGA</a>
          <div class="offer-micro">🔒 Pagamento seguro · Garantia de 7 dias</div>
          <div class="offer-installment-disclaimer">Parcelamento disponível apenas no cartão de crédito. Sujeito a juros da operadora.</div>
        </div>

        <!-- PLANO ANUAL -->
        <div class="offer-card offer-card--premium">
          <div class="offer-badge-top">🏆 TRANSFORMAÇÃO REAL</div>
          <div class="offer-name">ANUAL</div>
          <div class="offer-desc">12 meses de evolução com acompanhamento contínuo.</div>
