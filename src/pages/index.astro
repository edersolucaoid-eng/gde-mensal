            <div class="offer-item">✓ Comunidade de Goleiros</div>
            <div class="offer-item">✓ App premium</div>
            <div class="offer-item">✓ Garantia 7 Dias</div>
            <div class="offer-item">✓ Professor no WhatsApp</div>
          </div>
          <a href="https://pay.goleirodeelite.com/checkout/209015635:1" class="buy-btn buy-btn--outline">ENTRAR NO MÉTODO GOLEIRO 2.0</a>
          <div class="offer-micro">🔒 Pagamento seguro · Garantia de 7 dias</div>
