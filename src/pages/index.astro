        <span class="carousel-dot active" data-carousel="plans-a" data-idx="0"></span>
        <span class="carousel-dot" data-carousel="plans-a" data-idx="1"></span>
        <span class="carousel-dot" data-carousel="plans-a" data-idx="2"></span>
        <button class="carousel-arrow" data-carousel="plans-a" data-dir="1" aria-label="Próximo plano">&#8250;</button>
      </div>
    </div>
  </section>

  <div class="hr"></div>

  <!-- ============================================================
       BLOCO WA — DÚVIDAS NO WHATSAPP
  ============================================================ -->
  <section class="section wa-doubt-block reveal" style="transition-delay:.1s">
    <div class="wa-doubt-inner">
      <p class="wa-doubt-text">💬 Ficou com alguma dúvida antes de decidir?</p>
