        <!-- PLANO TRIMESTRAL -->
        <div class="offer-card offer-card--featured">
          <div class="offer-badge-top">⭐ MAIS ESCOLHIDO</div>
          <div class="offer-name">TRIMESTRAL</div>
          <div class="offer-desc">Pague 3, treine por 6.</div>
          <div class="offer-anchor">De <span>R$497</span></div>
          <div class="offer-price-row">
