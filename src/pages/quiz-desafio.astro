    'step-6', 'step-7', 'step-vsl', 'step-result'
  ];
  const answers = {};
  let currentIdx = 0;

  // ── VSL: carrega script só na primeira visita ao step ──────
  let vslLoaded = false;
  let vslButtonTimerStarted = false;
  function loadVSL() {
    if (vslLoaded) return;
    vslLoaded = true;
    const s = document.createElement('script');
    s.src = 'https://scripts.converteai.net/54614f94-0915-47ec-b3bb-c6614fdad9d2/players/6a189d70b7169516c91e6866/v4/player.js';
    s.async = true;
    document.head.appendChild(s);
  }
  function startVslButtonTimer() {
    if (vslButtonTimerStarted) return;
    vslButtonTimerStarted = true;
    initVslGate({
      storageKey: 'vsl_quiz_pt',
      targetSeconds: 90,
      playerId: 'vid-6a189d70b7169516c91e6866',
      onUnlock: () => {
        const btn = document.getElementById('vsl-continue');
        if (btn) btn.classList.remove('is-hidden');
      }
    });
  }

  // ── VSL gate persistente: desconta tempo ja assistido ──────
  function initVslGate({ storageKey, targetSeconds, playerId, onUnlock }) {
    const EXPIRY_MS = 30 * 24 * 60 * 60 * 1000;
    let unlocked = false;

    function readState() {
      try {
        const raw = localStorage.getItem(storageKey);
        if (!raw) return 0;
        const s = JSON.parse(raw);
        if (s.playerId !== playerId) return 0;
        if (Date.now() - s.savedAt > EXPIRY_MS) return 0;
        return Number(s.watched) || 0;
      } catch { return 0; }
    }

    function saveState(watched) {
      try {
        localStorage.setItem(storageKey, JSON.stringify({
          watched, savedAt: Date.now(), playerId
        }));
      } catch {}
    }

    let maxWatched = readState();

    function tryUnlock() {
      if (unlocked) return;
      unlocked = true;
      saveState(targetSeconds);
      onUnlock();
    }

    if (maxWatched >= targetSeconds) { tryUnlock(); return; }

    const remainingMs = (targetSeconds - maxWatched) * 1000;
    const fallbackTimer = setTimeout(tryUnlock, remainingMs);

    const pollInterval = setInterval(() => {
      if (unlocked) { clearInterval(pollInterval); return; }
      const el = document.getElementById(playerId);
      if (!el) return;
      let t = Number(el.currentTime);
      if (!isFinite(t) || t < 0) {
        const innerVideo = el.querySelector && el.querySelector('video');
        if (innerVideo) t = innerVideo.currentTime;
      }
      if (!isFinite(t) || t < 0) return;
      if (t > maxWatched) {
        maxWatched = Math.floor(t);
        saveState(maxWatched);
        if (maxWatched >= targetSeconds) {
          clearTimeout(fallbackTimer);
          tryUnlock();
        }
      }
    }, 1000);
  }

  // ── Navegação ───────────────────────────────────────────────
  function showStep(idx) {
    if (idx < 0 || idx >= stepOrder.length) return;
    document.querySelectorAll('.step').forEach(s => s.classList.remove('active'));
    document.getElementById(stepOrder[idx]).classList.add('active');
    currentIdx = idx;
    updateProgress(idx);
    if (stepOrder[idx] === 'step-2') adaptQ2();
    if (stepOrder[idx] === 'step-vsl') { loadVSL(); startVslButtonTimer(); }
    if (stepOrder[idx] === 'step-result') renderResult();
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  function updateProgress(idx) {
    let label, pct;
    // idx 0 = intro · 1-7 = Q1-Q7 · 8 = VSL · 9 = resultado
    if (idx === 0) {
      label = 'Pronto?';
      pct = 0;
    } else if (idx >= 1 && idx <= 7) {
      label = `Pergunta ${idx}/7`;
      pct = (idx / 9) * 100;
    } else if (idx === 8) {
      label = 'Vídeo';
      pct = 90;
    } else {
      label = 'Resultado';
      pct = 100;
    }
    document.getElementById('prog-label').textContent = label;
    document.getElementById('prog-fill').style.width = pct + '%';
  }

  // ── Q2 adapta texto pra "seu filho" se Q1 = responsável ────
  function adaptQ2() {
    const q2 = document.getElementById('q2-text');
    if (answers.q1 === 'responsavel') {
      q2.textContent = 'Há quanto tempo seu filho é goleiro?';
    } else {
      q2.textContent = 'Há quanto tempo você é goleiro?';
    }
  }

  // ── Resultado personalizado ─────────────────────────────────
  const templates = {
    amador: {
      eyebrow: '// Seu diagnóstico · Goleiro amador',
      headline: 'Você está pronto pra <span class="yl">subir de nível</span>.',
      diag: 'Pelas suas respostas, o gargalo principal é <strong>[DOR]</strong>. Treino físico genérico não resolve — você precisa de preparação específica pra goleiro. O Desafio entrega isso em 5 dias.',
      cta: 'Garantir minha vaga agora'
    },
    profissional: {
      eyebrow: '// Seu diagnóstico · Goleiro profissional',
      headline: 'Está na hora do <span class="yl">diferencial físico</span>.',
      diag: 'O time treina pra técnica e coletivo. O Desafio entrega o físico específico — <strong>[DOR]</strong> — que separa você dos outros goleiros do plantel.',
      cta: 'Garantir minha vaga agora'
    },
    base: {
      eyebrow: '// Seu diagnóstico · Goleiro de base',
      headline: 'Categorias de base <span class="yl">premiam o físico</span>.',
      diag: 'Pra subir, o corpo precisa responder. Sua maior dor — <strong>[DOR]</strong> — é exatamente o que o Desafio ataca. 5 dias de preparação específica que faz diferença na avaliação.',
      cta: 'Garantir minha vaga agora'
    },
    responsavel: {
      eyebrow: '// Seu diagnóstico · Responsável por goleiro',
      headline: 'Você quer dar a ele o que <span class="yl">falta</span>.',
      diag: 'Ele se dedica, mas falta estrutura física específica — <strong>[DOR]</strong>. O Desafio entrega 5 dias de treino feito por treinadores que entendem a posição. Material fica pra sempre.',
      cta: 'Garantir vaga pro meu goleiro'
    }
  };

  const dorTexts = {
    explosao: 'falta de explosão nas pernas',
    aerea: 'disputa aérea fraca',
    levantar: 'demora pra levantar após cair',
    cansaco: 'cansaço no segundo tempo'
  };

  function renderResult() {
    const perfil = answers.q1 || 'amador';
    const dor = answers.q3 ? dorTexts[answers.q3] : 'preparação física específica';
    const t = templates[perfil] || templates.amador;
    document.getElementById('result-eyebrow').textContent = t.eyebrow.replace('// ', '// ');
    document.getElementById('result-headline').innerHTML = t.headline;
    document.getElementById('result-diag').innerHTML = t.diag.replace('[DOR]', dor);
    document.getElementById('result-cta').textContent = t.cta;
  }

  // ── Listeners das opções ───────────────────────────────────
  document.querySelectorAll('.opt').forEach(opt => {
    opt.addEventListener('click', () => {
      const step = opt.dataset.step;
      const value = opt.dataset.value;
      answers[`q${step}`] = value;
      showStep(currentIdx + 1);
    });
  });

  // ── Botão voltar ───────────────────────────────────────────
  document.querySelectorAll('.qz-back').forEach(btn => {
    btn.addEventListener('click', () => showStep(currentIdx - 1));
  });

  // ── Botão continuar VSL ────────────────────────────────────
  document.getElementById('vsl-continue').addEventListener('click', () => {
    showStep(currentIdx + 1);
  });

  // ── Botão "Começar avaliação" do intro ─────────────────────
  document.getElementById('intro-start').addEventListener('click', () => {
    showStep(currentIdx + 1);
  });

  // ── Botão "Seguir" da Q7 ───────────────────────────────────
  document.getElementById('q7-continue').addEventListener('click', () => {
    answers.q7 = 'sim_implicito';
    showStep(currentIdx + 1);
  });

  // ── Carrossel de provas (copia da landing) ─────────────────
  (function() {
    const slides = Array.from(document.querySelectorAll('.proof-slide'));
    if (!slides.length) return;
    const total = slides.length;
    let current = 2;
    const INTERVAL = 3500;

    function update() {
      slides.forEach((slide, i) => {
        let rel = i - current;
        if (rel > total / 2)  rel -= total;
        if (rel < -total / 2) rel += total;

        slide.classList.remove('is-active');
        let tx, scale, rotY, opacity, brightness, zIndex, shadow;

        if (rel === 0) {
          tx = 0; scale = 1; rotY = 0; opacity = 1; brightness = 1; zIndex = 10;
          shadow = '0 20px 60px rgba(244,180,0,.22)';
          slide.classList.add('is-active');
        } else if (Math.abs(rel) === 1) {
          tx = rel * 200; scale = 0.87; rotY = rel > 0 ? -15 : 15;
          opacity = 0.55; brightness = 0.7; zIndex = 5; shadow = 'none';
        } else if (Math.abs(rel) === 2) {
          tx = rel * 340; scale = 0.76; rotY = rel > 0 ? -25 : 25;
          opacity = 0.3; brightness = 0.5; zIndex = 2; shadow = 'none';
        } else {
          tx = 0; scale = 0.65; rotY = 0;
          opacity = 0; brightness = 0.4; zIndex = 1; shadow = 'none';
        }

        slide.style.transform = `translateX(${tx}px) scale(${scale}) rotateY(${rotY}deg)`;
        slide.style.opacity = opacity;
        slide.style.filter = `brightness(${brightness})`;
        slide.style.zIndex = zIndex;
        slide.style.boxShadow = shadow;
      });
    }

    function next() { current = (current + 1) % total; update(); }
    function prev() { current = (current - 1 + total) % total; update(); }

    let timer = setInterval(next, INTERVAL);
    const outer = document.querySelector('.proof-clip');
    outer.addEventListener('mouseenter', () => clearInterval(timer));
    outer.addEventListener('mouseleave', () => { timer = setInterval(next, INTERVAL); });

    document.querySelector('.proof-nav-prev').addEventListener('click', () => { prev(); clearInterval(timer); timer = setInterval(next, INTERVAL); });
    document.querySelector('.proof-nav-next').addEventListener('click', () => { next(); clearInterval(timer); timer = setInterval(next, INTERVAL); });
    slides.forEach((slide, i) => {
      slide.addEventListener('click', () => { current = i; update(); clearInterval(timer); timer = setInterval(next, INTERVAL); });
    });

    update();
  })();

  // ── Countdown / data próxima turma ─────────────────────────
  function nextMonday() {
    const fixed = new Date('2026-06-01T03:00:00Z');
    if (Date.now() < fixed.getTime()) return fixed;
    const brt = new Date(new Date().toLocaleString('en-US', { timeZone: 'America/Sao_Paulo' }));
    const d = brt.getDay();
    const days = (8 - d) % 7 || 7;
    const m = new Date(brt);
    m.setDate(brt.getDate() + days);
    m.setHours(0, 0, 0, 0);
    return m;
  }
  function setNextClassDate() {
    const dateStr = nextMonday().toLocaleDateString('pt-BR', {
      weekday: 'long', day: 'numeric', month: 'long', timeZone: 'America/Sao_Paulo'
    });
    const el = document.getElementById('result-date');
    if (el) el.textContent = dateStr;
  }
  setNextClassDate();

  // ── Init ───────────────────────────────────────────────────
  showStep(0);
</script>
</Base>
