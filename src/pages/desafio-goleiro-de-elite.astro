---
import Base from '../layouts/Base.astro';
---
<Base title="Desafio Goleiro de Elite | 5 Dias de Treino Físico Específico para Goleiros">
<style>
@import url('https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Barlow:ital,wght@0,400;0,500;0,600;1,400&family=Barlow+Condensed:wght@600;700&display=swap');

/* ─── Reset & base ─────────────────────────────────────────── */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

body {
  font-family: 'Barlow', sans-serif;
  background: #0B0B0B;
  color: #fff;
  overflow-x: hidden;
}

/* ─── Tokens ────────────────────────────────────────────────── */
:root {
  --black:  #0B0B0B;
  --white:  #ffffff;
  --yellow: #F4B400;
  --sec-v: clamp(60px, 8vw, 100px);
  --wrap: 860px;
  --wrap-wide: 1040px;
}

/* ─── Layout ────────────────────────────────────────────────── */
.wrap      { max-width: var(--wrap);      margin: 0 auto; padding: 0 clamp(24px,5vw,48px); }
.wrap-wide { max-width: var(--wrap-wide); margin: 0 auto; padding: 0 clamp(24px,5vw,48px); }

/* dark and light sections */
.s-dark  { background: var(--black); color: var(--white); padding: var(--sec-v) 0; }
.s-light { background: var(--white); color: var(--black); padding: var(--sec-v) 0; }
.s-yellow{ background: var(--yellow);color: var(--black); padding: var(--sec-v) 0; }

/* ─── Section label ─────────────────────────────────────────── */
.label {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: .65rem;
  font-weight: 700;
  letter-spacing: .22em;
  text-transform: uppercase;
  display: flex;
  align-items: center;
  gap: 10px;
  margin-bottom: 18px;
}
.label::before {
  content: '';
  display: block;
  width: 24px;
  height: 1px;
}
.s-dark  .label { color: var(--yellow); }
.s-dark  .label::before { background: var(--yellow); }
.s-light .label { color: rgba(0,0,0,.4); }
.s-light .label::before { background: rgba(0,0,0,.4); }
.s-yellow .label { color: rgba(0,0,0,.55); }
.s-yellow .label::before { background: rgba(0,0,0,.55); }

/* ─── Headings ──────────────────────────────────────────────── */
.display {
  font-family: 'Bebas Neue', sans-serif;
  line-height: .88;
  letter-spacing: .01em;
  font-size: clamp(3.2rem, 9vw, 6.5rem);
  margin-bottom: clamp(48px, 7vw, 80px);
}
.display .yl   { color: var(--yellow); }
.display .faded{ color: rgba(255,255,255,.18); }

/* ─── Horizontal rule ───────────────────────────────────────── */
hr {
  border: none;
  height: 1px;
  margin-bottom: clamp(48px, 7vw, 80px);
}
.s-dark  hr { background: rgba(255,255,255,.08); }
.s-light hr { background: rgba(0,0,0,.1); }

/* ─── HERO ──────────────────────────────────────────────────── */
.hero {
  background: var(--black);
  display: flex;
  justify-content: center;
  align-items: flex-end;
  min-height: 100svh;
  padding-top: clamp(40px,8vw,80px);
}
.hero img { width: 100%; max-width: 540px; height: auto; display: block; }

/* ─── VAGAS ─────────────────────────────────────────────────── */
.vagas-block { text-align: center; max-width: 440px; margin: 0 auto; }

.vagas-num {
  font-family: 'Bebas Neue', sans-serif;
  font-size: clamp(9rem, 24vw, 14rem);
  line-height: .8;
  color: var(--white);
  letter-spacing: -.02em;
}
.vagas-num b { color: var(--yellow); }

.vagas-sub {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: .68rem;
  font-weight: 700;
  letter-spacing: .22em;
  text-transform: uppercase;
  color: rgba(255,255,255,.2);
  margin-top: 8px;
  margin-bottom: 28px;
}
.vagas-bar {
  height: 2px;
  background: rgba(255,255,255,.08);
  margin-bottom: 8px;
}
.vagas-fill {
  height: 100%;
  background: var(--yellow);
  width: 74.3%;
}
.vagas-slots {
  font-size: .72rem;
  color: rgba(255,255,255,.25);
  font-weight: 500;
  margin-bottom: 48px;
}
.vagas-slots strong { color: var(--yellow); }

.vagas-divider {
  width: 1px;
  height: 48px;
  background: rgba(255,255,255,.08);
  margin: 0 auto 40px;
}
.vagas-cd-lbl {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: .62rem;
  font-weight: 700;
  letter-spacing: .22em;
  text-transform: uppercase;
  color: rgba(255,255,255,.2);
  margin-bottom: 10px;
}
.vagas-cd {
  font-family: 'Bebas Neue', sans-serif;
  font-size: clamp(3.5rem, 10vw, 5.5rem);
  letter-spacing: .06em;
  color: var(--white);
  line-height: 1;
}
.vagas-date {
  font-size: .72rem;
  color: rgba(255,255,255,.2);
  margin-top: 10px;
  font-weight: 500;
}

/* ─── PROBLEM LIST ──────────────────────────────────────────── */
.pain-list {
  list-style: none;
  border-top: 1px solid rgba(0,0,0,.1);
}
.pain-item {
  display: flex;
  align-items: center;
  gap: 20px;
  padding: 22px 0;
  border-bottom: 1px solid rgba(0,0,0,.1);
}
.pain-x {
  width: 26px;
  height: 26px;
  border: 1.5px solid var(--black);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: .62rem;
  font-weight: 700;
  color: var(--black);
  flex-shrink: 0;
}
.pain-item span {
  font-size: 1rem;
  font-weight: 500;
  color: var(--black);
  line-height: 1.3;
}
.pivot-quote {
  margin-top: 40px;
  padding: 28px 32px;
  background: var(--black);
  font-size: clamp(.95rem,2.2vw,1.08rem);
  font-weight: 500;
  color: rgba(255,255,255,.45);
  line-height: 1.7;
  border-left: 3px solid var(--yellow);
}
.pivot-quote strong { color: var(--yellow); }

/* ─── PROOF CAROUSEL ─────────────────────────────────────────── */
.proof-clip {
  overflow: hidden;   /* clips side cards — must be separate from perspective element */
  width: 100%;
  margin-top: clamp(40px,6vw,64px);
}
.proof-carousel-outer {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  perspective: 1200px;
}
.proof-track {
  position: relative;
  width: 100%;
  height: 460px;
  display: flex;
  align-items: center;
  justify-content: center;
  transform-style: preserve-3d;
}
.proof-slide {
  position: absolute;
  width: 260px;
  height: 400px;
  border-radius: 20px;
  overflow: hidden;
  border: 1px solid rgba(255,255,255,.1);
  transition: transform .5s ease, opacity .5s ease, filter .5s ease, box-shadow .5s ease, border-color .5s ease;
  cursor: pointer;
}
.proof-slide img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}
.proof-slide-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to top, rgba(0,0,0,.88) 0%, rgba(0,0,0,.2) 55%, transparent 100%);
}
.proof-caption {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 18px 18px 22px;
  z-index: 2;
}
.proof-role-pill {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  border-radius: 9999px;
  background: rgba(255,255,255,.08);
  border: 1px solid rgba(255,255,255,.15);
  padding: 3px 10px;
  font-family: 'Barlow Condensed', sans-serif;
  font-size: .62rem;
  letter-spacing: .08em;
  color: rgba(255,255,255,.75);
  margin-bottom: 7px;
}
.proof-slide-name {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 1.25rem;
  font-weight: 700;
  letter-spacing: .03em;
  color: var(--white);
  line-height: 1.1;
}
.proof-active-badge {
  display: none;
  position: absolute;
  top: 14px;
  right: 14px;
  z-index: 3;
  background: var(--yellow);
  color: var(--black);
  font-family: 'Barlow Condensed', sans-serif;
  font-size: .6rem;
  font-weight: 700;
  letter-spacing: .1em;
  text-transform: uppercase;
  border-radius: 9999px;
  padding: 4px 10px;
}
.proof-slide.is-active { border-color: rgba(244,180,0,.5); }
.proof-slide.is-active .proof-active-badge { display: block; }
/* nav buttons */
.proof-nav {
  position: absolute;
  z-index: 20;
  width: 44px;
  height: 44px;
  border-radius: 50%;
  background: rgba(0,0,0,.55);
  border: 1px solid rgba(255,255,255,.1);
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  color: var(--white);
  transition: background .2s;
  flex-shrink: 0;
}
.proof-nav:hover { background: rgba(255,255,255,.08); }
.proof-nav-prev { left: 0; }
.proof-nav-next { right: 0; }

/* ─── METHOD LIST ───────────────────────────────────────────── */
.method-list { border-top: 1px solid rgba(0,0,0,.1); }
.method-item {
  display: grid;
  grid-template-columns: 80px 1fr;
  border-bottom: 1px solid rgba(0,0,0,.1);
  padding: 36px 0;
  gap: 0;
}
.method-n {
  font-family: 'Bebas Neue', sans-serif;
  font-size: clamp(3rem,7vw,4.5rem);
  color: var(--yellow);
  line-height: 1;
  padding-right: 24px;
  border-right: 1px solid rgba(0,0,0,.1);
  align-self: start;
}
.method-body { padding-left: 32px; padding-top: 4px; }
.method-title {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 1.1rem;
  font-weight: 700;
  letter-spacing: .05em;
  text-transform: uppercase;
  color: var(--black);
  margin-bottom: 12px;
}
.method-ul { list-style: none; display: flex; flex-direction: column; gap: 8px; }
.method-ul li {
  font-size: .88rem;
  color: rgba(0,0,0,.55);
  display: flex;
  gap: 12px;
  align-items: center;
}
.method-ul li::before {
  content: '';
  width: 16px;
  height: 1px;
  background: var(--yellow);
  flex-shrink: 0;
}

/* ─── TRANSFORMATION ────────────────────────────────────────── */
.trfm-list { border-top: 1px solid rgba(255,255,255,.06); }
.trfm-item {
  display: grid;
  grid-template-columns: 80px 1fr;
  border-bottom: 1px solid rgba(255,255,255,.06);
  padding: 36px 0;
}
.trfm-n {
  font-family: 'Bebas Neue', sans-serif;
  font-size: clamp(3rem,7vw,4.5rem);
  color: var(--yellow);
  line-height: 1;
  padding-right: 24px;
  border-right: 1px solid rgba(255,255,255,.06);
  align-self: start;
}
.trfm-body { padding-left: 32px; padding-top: 4px; }
.trfm-title {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 1.1rem;
  font-weight: 700;
  letter-spacing: .05em;
  text-transform: uppercase;
  color: var(--white);
  margin-bottom: 12px;
}
.trfm-ul { list-style: none; display: flex; flex-direction: column; gap: 8px; }
.trfm-ul li {
  font-size: .88rem;
  color: rgba(255,255,255,.38);
  display: flex;
  gap: 10px;
  align-items: flex-start;
  line-height: 1.55;
}
.trfm-ul li::before {
  content: '';
  width: 14px;
  height: 1px;
  background: rgba(255,255,255,.25);
  flex-shrink: 0;
  margin-top: 9px;
}

/* ─── INCLUDED TABLE ────────────────────────────────────────── */
.inc-table { border-top: 1px solid rgba(255,255,255,.06); }
.inc-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  padding: 22px 0;
  border-bottom: 1px solid rgba(255,255,255,.06);
  gap: 24px;
}
.inc-name {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: .95rem;
  font-weight: 700;
  letter-spacing: .04em;
  text-transform: uppercase;
  color: var(--white);
  margin-bottom: 4px;
}
.inc-desc { font-size: .76rem; color: rgba(255,255,255,.3); }
.inc-val {
  font-size: .8rem;
  color: rgba(255,255,255,.15);
  text-decoration: line-through;
  white-space: nowrap;
  flex-shrink: 0;
  padding-top: 2px;
}
.inc-total {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28px 0;
  border-top: 1px solid var(--yellow);
}
.inc-total-lbl {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: .6rem;
  letter-spacing: .16em;
  text-transform: uppercase;
  color: rgba(255,255,255,.3);
}
.inc-total-was { font-size: .82rem; color: rgba(255,255,255,.18); text-decoration: line-through; margin-top: 4px; }
.inc-price {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 4.5rem;
  color: var(--yellow);
  line-height: 1;
}
.inc-price sup { font-size: 1.6rem; vertical-align: super; }
.inc-price-label {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: .58rem;
  letter-spacing: .16em;
  text-transform: uppercase;
  color: rgba(255,255,255,.28);
  margin-bottom: 4px;
  text-align: right;
}

/* ─── ACCESS STEPS ──────────────────────────────────────────── */
.step-list { border-top: 1px solid rgba(0,0,0,.1); max-width: 640px; }
.step-item {
  display: flex;
  gap: 28px;
  padding: 32px 0;
  border-bottom: 1px solid rgba(0,0,0,.1);
  align-items: flex-start;
}
.step-n {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 2.2rem;
  color: var(--yellow);
  line-height: 1;
  flex-shrink: 0;
  min-width: 32px;
}
.step-title {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 1.05rem;
  font-weight: 700;
  letter-spacing: .05em;
  text-transform: uppercase;
  color: var(--black);
  margin-bottom: 6px;
}
.step-desc { font-size: .86rem; color: rgba(0,0,0,.5); line-height: 1.6; }

/* ─── WHO IS / IS NOT ───────────────────────────────────────── */
.whom-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
}
.whom-side {
  padding: clamp(60px,10vw,100px) clamp(24px,6vw,64px);
}
.whom-yes { background: var(--black); }
.whom-no  { background: #111; }
.whom-hd {
  font-family: 'Bebas Neue', sans-serif;
  font-size: clamp(2rem,4vw,3rem);
  letter-spacing: .02em;
  padding-bottom: 16px;
  margin-bottom: 4px;
  border-bottom: 2px solid;
}
.whom-yes .whom-hd { color: var(--yellow); border-color: var(--yellow); }
.whom-no  .whom-hd { color: rgba(255,255,255,.22); border-color: rgba(255,255,255,.08); }
.whom-ul { list-style: none; margin-top: 28px; display: flex; flex-direction: column; gap: 16px; }
.whom-ul li { display: flex; gap: 14px; font-size: .9rem; line-height: 1.45; align-items: flex-start; }
.whom-yes .whom-ul li { color: rgba(255,255,255,.58); }
.whom-no  .whom-ul li { color: rgba(255,255,255,.22); }
.ico-y { color: var(--yellow); font-weight: 700; flex-shrink: 0; }
.ico-n { color: rgba(255,255,255,.2); font-weight: 700; flex-shrink: 0; }

/* ─── FAQ ───────────────────────────────────────────────────── */
.faq-list { border-top: 1px solid rgba(0,0,0,.1); }
.faq-item { border-bottom: 1px solid rgba(0,0,0,.1); }
.faq-btn {
  width: 100%;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 22px 0;
  background: none;
  border: none;
  cursor: pointer;
  font-family: 'Barlow', sans-serif;
  font-size: .98rem;
  font-weight: 600;
  color: var(--black);
  text-align: left;
  gap: 20px;
}
.faq-ico {
  width: 26px;
  height: 26px;
  border: 1.5px solid rgba(0,0,0,.2);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1rem;
  font-weight: 400;
  flex-shrink: 0;
  transition: background .2s, border-color .2s, color .2s;
}
.faq-btn[aria-expanded="true"] .faq-ico {
  background: var(--yellow);
  border-color: var(--yellow);
  color: var(--black);
}
.faq-body { max-height: 0; overflow: hidden; transition: max-height .35s ease; }
.faq-body p { font-size: .88rem; color: rgba(0,0,0,.55); line-height: 1.8; padding-bottom: 22px; padding-right: 46px; }

/* ─── CTA FINAL ─────────────────────────────────────────────── */
.cta-tag {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: .65rem;
  letter-spacing: .24em;
  text-transform: uppercase;
  color: rgba(0,0,0,.5);
  display: block;
  margin-bottom: 20px;
}
.cta-hd {
  font-family: 'Bebas Neue', sans-serif;
  font-size: clamp(3.5rem, 9vw, 7rem);
  line-height: .88;
  color: var(--black);
  margin-bottom: 48px;
}
.cta-price {
  font-family: 'Bebas Neue', sans-serif;
  font-size: clamp(7rem, 20vw, 12rem);
  color: var(--black);
  line-height: 1;
  letter-spacing: -.02em;
}
.cta-price sup { font-size: 2.5rem; vertical-align: super; }
.cta-note {
  font-size: .7rem;
  color: rgba(0,0,0,.4);
  letter-spacing: .12em;
  text-transform: uppercase;
  margin-top: 6px;
  margin-bottom: 44px;
  font-weight: 500;
}
.cta-ul {
  list-style: none;
  display: inline-flex;
  flex-direction: column;
  gap: 10px;
  text-align: left;
  margin-bottom: 52px;
}
.cta-ul li {
  display: flex;
  gap: 12px;
  font-size: .88rem;
  color: rgba(0,0,0,.55);
  align-items: center;
}
.cta-ul li::before {
  content: '';
  width: 16px;
  height: 1.5px;
  background: var(--black);
  flex-shrink: 0;
}
.cta-foot {
  margin-top: 20px;
  font-size: .7rem;
  color: rgba(0,0,0,.38);
  line-height: 1.8;
  max-width: 340px;
  margin-left: auto;
  margin-right: auto;
}

/* ─── PLAN CARD CTA ──────────────────────────────────────────── */
.plan-sec {
  background: var(--black);
  padding: clamp(60px,8vw,100px) 0;
  border-top: 1px solid rgba(255,255,255,.05);
  border-bottom: 1px solid rgba(255,255,255,.05);
}
.plan-wrap {
  max-width: 480px;
  margin: 0 auto;
  padding: 0 clamp(24px,5vw,48px);
}
/* outer card — thin border + faint amber ring */
.plan-card {
  border: 1px solid rgba(255,255,255,.1);
  outline: 1px solid rgba(244,180,0,.15);
  border-radius: 28px;
  padding: 6px;
}
/* inner card — gradient bg */
.plan-inner {
  position: relative;
  overflow: hidden;
  border-radius: 22px;
  background: linear-gradient(160deg, rgba(255,255,255,.06) 0%, transparent 60%);
}
/* decorative top glow */
.plan-inner::before {
  content: '';
  position: absolute;
  inset: 0;
  background: radial-gradient(60% 50% at 70% 0%, rgba(244,180,0,.2), transparent 70%);
  pointer-events: none;
}
.plan-body { padding: 28px; position: relative; }
/* header row */
.plan-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12px;
  margin-bottom: 8px;
}
.plan-label {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: .65rem;
  font-weight: 700;
  letter-spacing: .2em;
  text-transform: uppercase;
  color: rgba(255,255,255,.5);
}
.plan-badge {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  border-radius: 9999px;
  background: rgba(244,180,0,.15);
  border: 1px solid rgba(244,180,0,.25);
  padding: 4px 10px;
  font-family: 'Barlow Condensed', sans-serif;
  font-size: .6rem;
  font-weight: 700;
  letter-spacing: .1em;
  text-transform: uppercase;
  color: var(--yellow);
}
.plan-badge svg { flex-shrink: 0; }
/* price */
.plan-price {
  font-family: 'Bebas Neue', sans-serif;
  font-size: clamp(4rem,12vw,5.5rem);
  color: var(--white);
  line-height: 1;
  letter-spacing: -.01em;
  margin-top: 4px;
}
.plan-price sup { font-size: 1.8rem; vertical-align: super; color: var(--yellow); }
.plan-period {
  font-size: .76rem;
  color: rgba(255,255,255,.35);
  margin-top: 2px;
  margin-bottom: 24px;
}
.plan-was {
  text-decoration: line-through;
  color: rgba(255,255,255,.18);
}
/* CTA button */
.plan-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  padding: 14px 24px;
  border-radius: 14px;
  background: linear-gradient(180deg, #F4C400 0%, #E0A800 100%);
  box-shadow: 0 10px 32px rgba(244,180,0,.22);
  font-family: 'Barlow Condensed', sans-serif;
  font-size: .95rem;
  font-weight: 700;
  letter-spacing: .14em;
  text-transform: uppercase;
  color: var(--black);
  text-decoration: none;
  transition: opacity .15s, transform .15s;
  margin-bottom: 28px;
}
.plan-btn:hover { opacity: .9; transform: translateY(-1px); }
/* divider */
.plan-divider {
  height: 1px;
  background: rgba(255,255,255,.07);
  margin-bottom: 24px;
}
/* feature list */
.plan-features { list-style: none; display: flex; flex-direction: column; gap: 12px; }
.plan-features li {
  display: flex;
  align-items: flex-start;
  gap: 10px;
  font-size: .9rem;
  color: rgba(255,255,255,.72);
  line-height: 1.4;
}
.plan-check {
  width: 18px;
  height: 18px;
  flex-shrink: 0;
  border-radius: 50%;
  background: rgba(244,180,0,.12);
  border: 1px solid rgba(244,180,0,.3);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 1px;
}
.plan-check svg { display: block; }

/* eyebrow acima do card final */
.plan-eyebrow {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: .65rem;
  font-weight: 700;
  letter-spacing: .22em;
  text-transform: uppercase;
  color: rgba(255,255,255,.25);
  text-align: center;
  margin-bottom: 20px;
}
/* nota abaixo do card final */
.plan-footnote {
  font-size: .7rem;
  color: rgba(255,255,255,.2);
  line-height: 1.8;
  text-align: center;
  margin-top: 20px;
  max-width: 360px;
  margin-left: auto;
  margin-right: auto;
}

/* ─── BUTTON ─────────────────────────────────────────────────── */
.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: var(--black);
  color: var(--yellow);
  font-family: 'Barlow Condensed', sans-serif;
  font-weight: 700;
  font-size: 1rem;
  letter-spacing: .16em;
  text-transform: uppercase;
  padding: 20px 60px;
  text-decoration: none;
  transition: background .15s, transform .15s;
}
.btn:hover { background: #1a1a1a; transform: translateY(-2px); }

/* ─── FOOTER ─────────────────────────────────────────────────── */
.foot {
  background: var(--black);
  border-top: 1px solid rgba(255,255,255,.05);
  padding: 48px 24px;
  text-align: center;
}
.foot-logo { width: 34px; height: auto; opacity: .3; margin: 0 auto 16px; display: block; }
.foot-links { display: flex; gap: 28px; justify-content: center; margin-bottom: 12px; }
.foot-links a { font-size: .66rem; color: rgba(255,255,255,.2); text-decoration: none; letter-spacing: .05em; }
.foot-links a:hover { color: var(--yellow); }
.foot-copy { font-size: .63rem; color: rgba(255,255,255,.12); letter-spacing: .04em; }

/* ─── REVEAL ─────────────────────────────────────────────────── */
.reveal { opacity: 0; transform: translateY(16px); transition: opacity .6s ease, transform .6s ease; }
.reveal.in { opacity: 1; transform: none; }

/* ─── RESPONSIVE ─────────────────────────────────────────────── */
@media (max-width: 768px) {
  .proof-grid       { grid-template-columns: repeat(2, 1fr); }
  .method-item      { grid-template-columns: 60px 1fr; }
  .method-n         { font-size: 2.8rem; }
  .method-body      { padding-left: 20px; }
  .trfm-item        { grid-template-columns: 60px 1fr; }
  .trfm-n           { font-size: 2.8rem; }
  .trfm-body        { padding-left: 20px; }
