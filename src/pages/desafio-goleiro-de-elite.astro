---
import Base from '../layouts/Base.astro';
---
<Base title="Desafio Goleiro de Elite | 5 Dias de Treino Físico Específico para Goleiros">

<style is:inline>
  /* ── Desafio — design system próprio ── */
  .d-page {
    background: #0A0A0A;
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* Countdown bar */
  .d-bar {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    background: #0d0d0d;
    border-bottom: 1px solid #1a1a1a;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    padding: 9px 16px;
    font-family: 'JetBrains Mono', monospace;
    font-size: .72rem;
    color: #555;
  }
  .d-bar .timer { color: #00C853; font-weight: 700; letter-spacing: .04em; }
  .d-bar .sep   { color: #2a2a2a; }

  /* Layout */
  .d-wrap {
    width: 100%;
    max-width: 860px;
    margin: 0 auto;
    padding: 0 20px;
  }

  /* Section spacing */
  .d-section {
    padding: 80px 20px;
    width: 100%;
    max-width: 860px;
    margin: 0 auto;
  }

  /* Tags */
  .d-tag {
    font-family: 'JetBrains Mono', monospace;
    font-size: .68rem;
    font-weight: 700;
    color: #555;
    letter-spacing: .22em;
    text-transform: uppercase;
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 18px;
  }
  .d-tag::before { content: '//'; color: #333; }

  /* Titles */
  .d-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(2.4rem, 7vw, 4.2rem);
    line-height: 1;
    color: #FAFAFA;
    margin-bottom: 18px;
  }
  .d-title .hl { color: #FFB300; }

  .d-sub {
    font-size: clamp(.95rem, 2vw, 1.1rem);
    color: #A0A0A0;
    line-height: 1.65;
  }

  /* Divider */
  .d-divider {
    width: 100%;
    max-width: 860px;
    margin: 0 auto;
    height: 1px;
    background: linear-gradient(to right, transparent, #1e1e1e, transparent);
  }

  /* ── Hero ─────────────────────────────── */
  .d-hero {
    padding-top: 44px; /* countdown bar height */
    min-height: 100svh;
    display: flex;
    align-items: center;
  }
  .d-hero-inner {
    display: grid;
    grid-template-columns: 1fr 380px;
    gap: 56px;
    align-items: center;
    padding: 64px 20px 56px;
    width: 100%;
    max-width: 860px;
    margin: 0 auto;
  }
  .d-hero-eyebrow {
    font-family: 'JetBrains Mono', monospace;
    font-size: .72rem;
    letter-spacing: .18em;
    color: #555;
    text-transform: uppercase;
    margin-bottom: 20px;
  }
  .d-hero-eyebrow .green { color: #00C853; }
  .d-hero-h1 {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(3rem, 9vw, 5.5rem);
    line-height: 1;
    color: #FAFAFA;
    margin-bottom: 22px;
  }
  .d-hero-p {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: clamp(1rem, 2.5vw, 1.15rem);
    color: #A0A0A0;
    line-height: 1.65;
    margin-bottom: 36px;
    max-width: 480px;
  }
  .d-hero-img {
    width: 100%;
    height: 520px;
    object-fit: cover;
    object-position: top center;
    border-radius: 4px;
    filter: grayscale(15%);
    display: block;
  }

  /* ── CTA buttons ──────────────────────── */
  .d-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    background: #00C853;
    color: #000;
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1.2rem;
    letter-spacing: .04em;
    padding: 17px 34px;
    border-radius: 3px;
    border: none;
    cursor: pointer;
    text-decoration: none;
    transition: filter .18s, transform .18s;
    -webkit-tap-highlight-color: transparent;
  }
  .d-cta:hover  { filter: brightness(1.1); transform: translateY(-1px); }
  .d-cta:active { transform: translateY(0); filter: brightness(.95); }
  .d-cta-full { width: 100%; max-width: 440px; font-size: 1.3rem; padding: 19px 28px; }
  .d-cta-price {
    font-size: .78rem;
    font-family: 'JetBrains Mono', monospace;
    letter-spacing: .05em;
    font-weight: 400;
    opacity: .8;
  }
  .d-cta-hint {
    font-size: .75rem;
    color: #444;
    font-family: 'JetBrains Mono', monospace;
    margin-top: 10px;
    text-align: center;
  }

  /* ── Problem section ──────────────────── */
  .d-pain-list {
    display: grid;
    gap: 10px;
    margin-bottom: 36px;
  }
  .d-pain-item {
    background: #111;
    border: 1px solid #1a1a1a;
    border-radius: 3px;
    padding: 16px 20px;
    display: flex;
    align-items: flex-start;
    gap: 14px;
  }
  .d-pain-x {
    color: #E53935;
    font-weight: 700;
    font-size: 1rem;
    line-height: 1.6;
    flex-shrink: 0;
  }
  .d-pain-txt {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 1.05rem;
    color: #FAFAFA;
    line-height: 1.5;
  }
  .d-pivot {
    background: #0f1a0f;
    border-left: 3px solid #00C853;
    padding: 22px 24px;
    border-radius: 0 3px 3px 0;
    font-family: 'Barlow Condensed', sans-serif;
    font-size: clamp(1rem, 2.5vw, 1.15rem);
    color: #FAFAFA;
    line-height: 1.65;
  }
  .d-pivot strong { color: #FFB300; font-style: normal; }

  /* ── Social proof ─────────────────────── */
  .d-proof-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 6px;
  }
  .d-proof-img {
    width: 100%;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    border-radius: 3px;
    filter: grayscale(10%);
    transition: filter .3s;
    display: block;
  }
  .d-proof-img:hover { filter: none; }

  /* ── Method cards ─────────────────────── */
  .d-method-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 14px;
  }
  .d-method-card {
    background: #111;
    border: 1px solid #1a1a1a;
    border-radius: 3px;
    padding: 26px 24px;
  }
  .d-method-num {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 3.2rem;
    color: #FFB300;
    line-height: 1;
    margin-bottom: 14px;
  }
  .d-method-name {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1.45rem;
    color: #FAFAFA;
    margin-bottom: 10px;
  }
  .d-method-desc {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: .95rem;
    color: #A0A0A0;
    line-height: 1.6;
  }

  /* ── Benefits ─────────────────────────── */
  .d-benefit-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 14px;
  }
  .d-benefit-card {
    background: #111;
    border: 1px solid #1a1a1a;
    border-radius: 3px;
    padding: 26px 24px;
  }
  .d-benefit-check {
    width: 38px;
    height: 38px;
    background: rgba(0,200,83,.1);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #00C853;
    font-weight: 700;
    font-size: 1rem;
    margin-bottom: 16px;
    flex-shrink: 0;
  }
  .d-benefit-name {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1.35rem;
    color: #FAFAFA;
    margin-bottom: 10px;
  }
  .d-benefit-desc {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: .92rem;
    color: #A0A0A0;
    line-height: 1.6;
  }

  /* ── Included ─────────────────────────── */
  .d-inc-list { display: grid; gap: 10px; margin-bottom: 20px; }
  .d-inc-row {
    background: #111;
    border: 1px solid #1a1a1a;
    border-radius: 3px;
    padding: 18px 22px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 20px;
  }
  .d-inc-name {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1.15rem;
    color: #FAFAFA;
    margin-bottom: 4px;
  }
  .d-inc-desc {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: .85rem;
    color: #666;
  }
  .d-inc-price {
    font-family: 'JetBrains Mono', monospace;
    font-size: .82rem;
    color: #444;
    text-decoration: line-through;
    white-space: nowrap;
  }
  .d-total-row {
    border: 1px solid #1a1a1a;
    border-radius: 3px;
    padding: 20px 22px;
    background: #0d0d0d;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .d-total-lbl { font-family: 'Barlow Condensed', sans-serif; font-size: .9rem; color: #555; }
  .d-total-was { font-family: 'JetBrains Mono', monospace; font-size: .85rem; color: #444; text-decoration: line-through; }
  .d-total-price {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 2rem;
    color: #00C853;
  }

  /* ── Offer card ───────────────────────── */
  .d-offer-wrap { display: flex; justify-content: center; }
  .d-offer-card {
    background: #111;
    border: 2px solid #00C853;
    border-radius: 5px;
    padding: 42px 36px;
    width: 100%;
    max-width: 460px;
    text-align: center;
  }
  .d-offer-badge {
    display: inline-block;
    background: rgba(0,200,83,.12);
    color: #00C853;
    font-family: 'JetBrains Mono', monospace;
    font-size: .65rem;
    letter-spacing: .18em;
    text-transform: uppercase;
    padding: 6px 14px;
    border-radius: 2px;
    margin-bottom: 26px;
  }
  .d-offer-price {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 5.5rem;
    line-height: 1;
    color: #FAFAFA;
    margin-bottom: 4px;
  }
  .d-offer-price sup { font-size: 2.2rem; vertical-align: super; color: #A0A0A0; }
  .d-offer-inst {
    font-family: 'JetBrains Mono', monospace;
    font-size: .72rem;
    color: #555;
    margin-bottom: 28px;
  }
  .d-offer-ul {
    list-style: none;
    text-align: left;
    margin-bottom: 30px;
    display: grid;
    gap: 10px;
  }
  .d-offer-ul li {
    display: flex;
    gap: 10px;
    align-items: flex-start;
    font-family: 'Barlow Condensed', sans-serif;
    font-size: .95rem;
    color: #A0A0A0;
    line-height: 1.45;
  }
  .d-offer-ul li::before {
    content: '✓';
    color: #00C853;
    font-weight: 700;
    flex-shrink: 0;
  }
  .d-offer-hint {
    margin-top: 14px;
    font-family: 'JetBrains Mono', monospace;
    font-size: .68rem;
    color: #444;
    letter-spacing: .04em;
  }

  /* ── For whom ─────────────────────────── */
  .d-whom-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px;
  }
  .d-whom-card {
    background: #111;
    border: 1px solid #1a1a1a;
    border-radius: 3px;
    padding: 28px 24px;
  }
  .d-whom-card.yes { border-top: 2px solid #00C853; }
  .d-whom-card.no  { border-top: 2px solid #E53935; }
  .d-whom-head {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1.35rem;
    margin-bottom: 20px;
  }
  .d-whom-card.yes .d-whom-head { color: #00C853; }
  .d-whom-card.no  .d-whom-head { color: #E53935; }
  .d-whom-ul { list-style: none; display: grid; gap: 11px; }
  .d-whom-ul li {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-family: 'Barlow Condensed', sans-serif;
    font-size: .92rem;
    color: #A0A0A0;
    line-height: 1.45;
  }
  .ico-yes { color: #00C853; font-weight: 700; flex-shrink: 0; }
  .ico-no  { color: #E53935; font-weight: 700; flex-shrink: 0; }

  /* ── FAQ ──────────────────────────────── */
  .d-faq-list { display: grid; gap: 6px; }
  .d-faq-item {
    background: #111;
    border: 1px solid #1a1a1a;
    border-radius: 3px;
    overflow: hidden;
  }
  .d-faq-btn {
    width: 100%;
    background: none;
    border: none;
    padding: 19px 22px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 14px;
    cursor: pointer;
    color: #FAFAFA;
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 1.05rem;
    font-weight: 600;
    text-align: left;
    -webkit-tap-highlight-color: transparent;
  }
  .d-faq-icon {
    color: #00C853;
    font-size: 1.25rem;
    flex-shrink: 0;
    transition: transform .28s ease;
    font-family: 'JetBrains Mono', monospace;
    font-weight: 400;
    line-height: 1;
  }
  .d-faq-btn[aria-expanded="true"] .d-faq-icon { transform: rotate(45deg); }
  .d-faq-body {
    max-height: 0;
    overflow: hidden;
    transition: max-height .32s ease, padding .32s ease;
    padding: 0 22px;
  }
  .d-faq-body.open { max-height: 280px; padding: 0 22px 18px; }
  .d-faq-body p {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: .97rem;
    color: #A0A0A0;
    line-height: 1.6;
  }

  /* ── Footer ───────────────────────────── */
  .d-footer {
    width: 100%;
    max-width: 860px;
    margin: 0 auto;
    padding: 48px 20px 40px;
    border-top: 1px solid #141414;
    text-align: center;
  }
  .d-footer-brand {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1.3rem;
    color: #2a2a2a;
    margin-bottom: 14px;
    letter-spacing: .06em;
  }
  .d-footer-links {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 20px;
    margin-bottom: 14px;
  }
  .d-footer-links a {
    font-family: 'JetBrains Mono', monospace;
    font-size: .68rem;
    color: #444;
    text-decoration: none;
    letter-spacing: .04em;
    transition: color .2s;
  }
  .d-footer-links a:hover { color: #888; }
  .d-footer-copy {
    font-family: 'JetBrains Mono', monospace;
    font-size: .65rem;
    color: #333;
  }

  /* ── Sticky CTA mobile ────────────────── */
  .d-sticky {
    display: none;
    position: fixed;
    bottom: 0; left: 0; right: 0;
    z-index: 200;
    background: rgba(10,10,10,.96);
    border-top: 1px solid #1a1a1a;
    padding: 12px 16px;
    backdrop-filter: blur(8px);
  }
  .d-sticky.show { display: block; }

  /* ── Reveal animations ────────────────── */
  .reveal {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity .55s ease, transform .55s ease;
  }
  .reveal.in { opacity: 1; transform: translateY(0); }

  /* ── Responsive ───────────────────────── */
  @media (max-width: 700px) {
    .d-hero-inner {
      grid-template-columns: 1fr;
      padding: 56px 20px 48px;
      gap: 0;
    }
    .d-hero-img-wrap { display: none; }
    .d-proof-grid   { grid-template-columns: repeat(2, 1fr); }
    .d-method-grid  { grid-template-columns: 1fr; }
    .d-benefit-grid { grid-template-columns: 1fr; }
    .d-whom-grid    { grid-template-columns: 1fr; }
    .d-offer-card   { padding: 28px 20px; }
    .d-offer-price  { font-size: 4.5rem; }
    .d-inc-row      { flex-direction: column; align-items: flex-start; gap: 8px; }
    .d-sticky.show  { display: block; }
  }
</style>

<div class="d-page">

  <!-- 1 · COUNTDOWN BAR -->
  <div class="d-bar">
    <span>Próxima turma abre em</span>
    <span class="timer" id="d-countdown">--:--:--</span>
    <span class="sep">·</span>
    <span>segunda-feira · 00h BRT</span>
  </div>

  <!-- 2 · HERO -->
  <section class="d-hero">
    <div class="d-hero-inner">
      <div class="reveal">
        <p class="d-hero-eyebrow">
          Próxima turma: <span class="green" id="d-next-date">segunda-feira</span>
        </p>
        <h1 class="d-hero-h1">
          Você sabe quando<br>era pra pegar<br>e não pegou.
        </h1>
        <p class="d-hero-p">
          Suas pernas não responderam. Você treinou a semana inteira e mesmo assim. Esse desafio é pra atacar o que falta: explosão real, treinada do jeito certo pra goleiro.
        </p>
        <div>
          <a href="#checkout" class="d-cta d-cta-full">
            Quero entrar no desafio
            <span class="d-cta-price">— R$ 35</span>
          </a>
          <p class="d-cta-hint">Pagamento único · Acesso imediato · 5 dias ao vivo</p>
        </div>
      </div>
      <div class="d-hero-img-wrap reveal" style="transition-delay:.18s">
        <img
          src="/images/hero-professor.webp"
          srcset="/images/hero-professor-480.webp 480w, /images/hero-professor.webp 900w"
          sizes="380px"
          alt="Pedro Ferreira — Preparador físico Goleiro de Elite"
          class="d-hero-img"
          loading="eager"
          fetchpriority="high"
        />
      </div>
    </div>
  </section>

  <div class="d-divider"></div>

  <!-- 3 · O PROBLEMA -->
  <section class="d-section">
    <div class="reveal">
      <p class="d-tag">O problema</p>
      <h2 class="d-title">Você treina. Você se dedica.<br>Mas na hora do jogo…</h2>
    </div>
    <div class="d-pain-list" style="margin-top:32px">
      <div class="d-pain-item reveal">
        <span class="d-pain-x">✗</span>
        <span class="d-pain-txt">Suas pernas não respondem no momento decisivo</span>
      </div>
      <div class="d-pain-item reveal" style="transition-delay:.07s">
        <span class="d-pain-x">✗</span>
        <span class="d-pain-txt">Você cai e demora pra levantar pra próxima jogada</span>
      </div>
      <div class="d-pain-item reveal" style="transition-delay:.12s">
        <span class="d-pain-x">✗</span>
        <span class="d-pain-txt">No segundo tempo você perde a disputa aérea que no primeiro pegava</span>
      </div>
      <div class="d-pain-item reveal" style="transition-delay:.17s">
        <span class="d-pain-x">✗</span>
        <span class="d-pain-txt">Você treina na academia toda semana mas a melhora no gol não aparece</span>
      </div>
      <div class="d-pain-item reveal" style="transition-delay:.22s">
        <span class="d-pain-x">✗</span>
        <span class="d-pain-txt">Você leva gol que sabia que era pra pegar</span>
      </div>
    </div>
    <div class="d-pivot reveal">
      Não faltou treino. Não faltou esforço. Não faltou técnica.<br>
      <strong>Faltou o tipo certo de treino para goleiro.</strong>
    </div>
  </section>

  <div class="d-divider"></div>

  <!-- 4 · PROVAS REAIS -->
  <section class="d-section">
    <div class="reveal">
      <p class="d-tag">Resultados reais</p>
      <h2 class="d-title">O que acontece quando<br>o goleiro treina do jeito certo</h2>
    </div>
    <div class="d-proof-grid reveal" style="margin-top:32px;transition-delay:.1s">
      <img src="/images/carrossel-1.webp"
           srcset="/images/carrossel-1-420.webp 420w, /images/carrossel-1.webp 900w"
           sizes="(max-width:700px) 50vw, 33vw"
           alt="Resultado goleiro" class="d-proof-img" loading="lazy" />
      <img src="/images/carrossel-2.webp"
           srcset="/images/carrossel-2-420.webp 420w, /images/carrossel-2.webp 900w"
           sizes="(max-width:700px) 50vw, 33vw"
           alt="Resultado goleiro" class="d-proof-img" loading="lazy" />
      <img src="/images/carrossel-3.webp"
           srcset="/images/carrossel-3-420.webp 420w, /images/carrossel-3.webp 900w"
           sizes="(max-width:700px) 50vw, 33vw"
           alt="Resultado goleiro" class="d-proof-img" loading="lazy" />
      <img src="/images/carrossel-4.webp"
           srcset="/images/carrossel-4-420.webp 420w, /images/carrossel-4.webp 900w"
           sizes="(max-width:700px) 50vw, 33vw"
           alt="Resultado goleiro" class="d-proof-img" loading="lazy" />
      <img src="/images/carrossel-5.webp"
           srcset="/images/carrossel-5-420.webp 420w, /images/carrossel-5.webp 900w"
           sizes="(max-width:700px) 50vw, 33vw"
           alt="Resultado goleiro" class="d-proof-img" loading="lazy" />
      <img src="/images/carrossel-6.webp"
           srcset="/images/carrossel-6-420.webp 420w, /images/carrossel-6.webp 900w"
           sizes="(max-width:700px) 50vw, 33vw"
           alt="Resultado goleiro" class="d-proof-img" loading="lazy" />
    </div>
  </section>

  <div class="d-divider"></div>

  <!-- 5 · O MÉTODO EFV -->
  <section class="d-section">
    <div class="reveal">
