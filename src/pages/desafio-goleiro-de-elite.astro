---
import Base from '../layouts/Base.astro';
---
<Base title="Desafio Goleiro de Elite | 5 Dias de Treino Físico Específico para Goleiros">
<style>
/* ── Google Fonts ─────────────────────────────── */
@import url('https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Montserrat:wght@400;500;600;700;800&display=swap');

/* ── Reset ────────────────────────────────────── */
.d *{box-sizing:border-box;margin:0;padding:0;}
.d{
  font-family:'Montserrat',sans-serif;
  background:#fff;
  color:#0B0B0B;
  overflow-x:hidden;
}

/* ── Tokens ───────────────────────────────────── */
/* --black:#0B0B0B  --white:#fff  --yellow:#F4B400
   --gray:#F5F5F5   --muted:#666  --border:#E5E5E5 */

/* ── Bebas helper ─────────────────────────────── */
.bb{font-family:'Bebas Neue',sans-serif;letter-spacing:.03em;}

/* ── Section wrappers ─────────────────────────── */
.d-sec{padding:80px 24px;}
.d-inner{max-width:960px;margin:0 auto;}
.d-inner-sm{max-width:680px;margin:0 auto;}
.d-dark{background:#0B0B0B;color:#fff;}
.d-gray{background:#F5F5F5;}

/* ── Tag ──────────────────────────────────────── */
.d-tag{
  display:inline-flex;align-items:center;gap:8px;
  font-size:.68rem;font-weight:700;letter-spacing:.16em;
  text-transform:uppercase;color:#F4B400;
  margin-bottom:14px;
}
.d-tag::before{content:'';display:block;width:18px;height:2px;background:#F4B400;}

/* ── Titles ───────────────────────────────────── */
.d-title{
  font-family:'Bebas Neue',sans-serif;
  font-size:clamp(2.6rem,6vw,4.2rem);
  line-height:1;letter-spacing:.02em;
  color:#0B0B0B;margin-bottom:18px;
}
.d-title .yl{color:#F4B400;}
.d-title-w{color:#fff;}
.d-sub{font-size:.98rem;color:#666;line-height:1.75;max-width:540px;}
.d-sub-w{color:#999;}

/* ── Yellow line ──────────────────────────────── */
.d-yline{width:36px;height:2px;background:#F4B400;margin-bottom:28px;}

/* ── HERO ─────────────────────────────────────── */
.d-hero{
  background:#fff;
  display:flex;justify-content:center;
  padding:0;
}
.d-hero-img{
  width:100%;max-width:520px;
  height:auto;display:block;
}

/* ── VAGAS + COUNTDOWN ────────────────────────── */
.d-vagas{
  background:#0B0B0B;
  padding:56px 24px;
  text-align:center;
}
.d-vagas-inner{max-width:480px;margin:0 auto;}
.d-vagas-badge{
  display:inline-flex;align-items:center;gap:8px;
  background:rgba(244,180,0,.1);
  border:1px solid rgba(244,180,0,.4);
  border-radius:3px;padding:6px 16px;
  color:#F4B400;font-size:.68rem;font-weight:700;
  letter-spacing:.16em;text-transform:uppercase;
  margin-bottom:28px;
}
.d-vagas-num{
  font-family:'Bebas Neue',sans-serif;
  font-size:6rem;line-height:1;color:#fff;
}
.d-vagas-label{
  font-size:.75rem;letter-spacing:.12em;text-transform:uppercase;
  color:#666;margin-top:4px;margin-bottom:20px;
}
.d-vagas-bar-wrap{
  background:rgba(255,255,255,.08);
  border-radius:100px;height:5px;
  margin-bottom:8px;overflow:hidden;
}
.d-vagas-bar-fill{
  height:100%;background:#F4B400;
  border-radius:100px;width:74%;
}
.d-vagas-slots{font-size:.78rem;color:#555;margin-bottom:40px;}
.d-vagas-slots strong{color:#F4B400;}
.d-vagas-divider{
  width:40px;height:1px;background:rgba(255,255,255,.1);
  margin:0 auto 32px;
}
.d-cd-lbl{
  font-size:.68rem;letter-spacing:.14em;text-transform:uppercase;
  color:#555;margin-bottom:12px;
}
.d-cd-timer{
  font-family:'Bebas Neue',sans-serif;
  font-size:3.8rem;letter-spacing:.06em;
  color:#fff;line-height:1;
}
.d-cd-date{font-size:.78rem;color:#555;margin-top:8px;}

/* ── PAIN ─────────────────────────────────────── */
.d-pain-list{display:grid;gap:8px;margin-top:36px;margin-bottom:28px;}
.d-pain-item{
  display:flex;align-items:center;gap:16px;
  background:#F5F5F5;border-radius:6px;
  padding:15px 20px;
  border-left:3px solid transparent;
  transition:border-color .2s;
}
.d-pain-item:hover{border-left-color:#F4B400;}
.d-pain-x{
  width:26px;height:26px;border-radius:50%;
  background:#0B0B0B;color:#F4B400;
  display:flex;align-items:center;justify-content:center;
  font-weight:800;font-size:.75rem;flex-shrink:0;
}
.d-pain-txt{font-size:.92rem;color:#333;font-weight:500;}
.d-pivot{
  background:#0B0B0B;border-radius:6px;
  padding:24px 28px;
  font-size:.98rem;color:#bbb;line-height:1.7;
}
.d-pivot strong{color:#F4B400;}

/* ── PROOF ────────────────────────────────────── */
.d-proof-grid{
  display:grid;grid-template-columns:repeat(3,1fr);
  gap:16px;margin-top:40px;
}
.d-proof-item{display:flex;flex-direction:column;gap:8px;}
.d-proof-img{
  width:100%;aspect-ratio:1/1;
  object-fit:cover;border-radius:6px;display:block;
  transition:transform .3s;
}
.d-proof-img:hover{transform:scale(1.02);}
.d-proof-name{font-size:.85rem;font-weight:700;color:#0B0B0B;}
.d-proof-role{font-size:.75rem;color:#666;}

/* ── METHOD (dark) ────────────────────────────── */
.d-method-grid{
  display:grid;grid-template-columns:repeat(2,1fr);
  gap:10px;margin-top:40px;
}
.d-method-card{
  background:rgba(255,255,255,.04);
  border:1px solid rgba(255,255,255,.07);
  border-radius:6px;padding:28px 24px;
  border-top:2px solid #F4B400;
}
.d-method-num{
  font-family:'Bebas Neue',sans-serif;
  font-size:2.4rem;color:#F4B400;
  line-height:1;margin-bottom:12px;
}
.d-method-name{font-size:.95rem;font-weight:700;color:#fff;margin-bottom:8px;}
.d-method-desc{font-size:.85rem;color:#777;line-height:1.65;}

/* ── BENEFITS ─────────────────────────────────── */
.d-benefit-grid{
  display:grid;grid-template-columns:repeat(2,1fr);
  gap:12px;margin-top:40px;
}
.d-benefit-card{
  background:#F5F5F5;border-radius:6px;
  padding:28px 24px;border-left:3px solid #F4B400;
}
.d-benefit-icon{font-size:1.1rem;color:#F4B400;margin-bottom:12px;}
.d-benefit-name{font-size:.95rem;font-weight:700;color:#0B0B0B;margin-bottom:6px;}
.d-benefit-desc{font-size:.85rem;color:#666;line-height:1.65;}

/* ── INCLUDED ─────────────────────────────────── */
.d-inc-list{margin-top:36px;border:1px solid #E5E5E5;border-radius:6px;overflow:hidden;}
.d-inc-row{
  display:flex;justify-content:space-between;align-items:center;
  padding:18px 22px;background:#fff;
  border-bottom:1px solid #E5E5E5;
}
.d-inc-row:last-child{border-bottom:none;}
.d-inc-name{font-size:.92rem;font-weight:700;color:#0B0B0B;}
.d-inc-desc{font-size:.78rem;color:#888;margin-top:3px;}
.d-inc-price{
  font-size:.82rem;color:#bbb;
  text-decoration:line-through;
  white-space:nowrap;margin-left:16px;flex-shrink:0;
}
.d-total-row{
  display:flex;justify-content:space-between;align-items:center;
  padding:20px 22px;background:#0B0B0B;
}
.d-total-lbl{font-size:.65rem;color:#555;letter-spacing:.08em;text-transform:uppercase;}
.d-total-was{font-size:.95rem;color:#555;text-decoration:line-through;}
.d-total-price{
  font-family:'Bebas Neue',sans-serif;
  font-size:3rem;color:#F4B400;line-height:1;
}

/* ── ACCESS ───────────────────────────────────── */
.d-access-steps{display:flex;flex-direction:column;max-width:520px;margin-top:40px;}
.d-access-step{
  display:flex;gap:20px;
  padding:24px 0;border-bottom:1px solid #E5E5E5;
}
.d-access-step:last-child{border-bottom:none;}
.d-access-num{
  width:40px;height:40px;border-radius:50%;
  background:#0B0B0B;color:#F4B400;
  font-family:'Bebas Neue',sans-serif;font-size:1.3rem;
  display:flex;align-items:center;justify-content:center;
  flex-shrink:0;
}
.d-access-title{font-size:.92rem;font-weight:700;color:#0B0B0B;margin-bottom:4px;}
.d-access-desc{font-size:.83rem;color:#666;line-height:1.65;}

/* ── WHOM ─────────────────────────────────────── */
.d-whom-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-top:36px;}
.d-whom-card{background:#F5F5F5;border-radius:6px;padding:28px 24px;}
.d-whom-card.yes{border-top:3px solid #F4B400;}
.d-whom-card.no{border-top:3px solid #0B0B0B;}
.d-whom-head{
  font-family:'Bebas Neue',sans-serif;
  font-size:1.2rem;letter-spacing:.04em;
  color:#0B0B0B;margin-bottom:18px;
}
.d-whom-ul{list-style:none;display:flex;flex-direction:column;gap:10px;}
.d-whom-ul li{font-size:.85rem;color:#444;display:flex;gap:10px;line-height:1.5;align-items:flex-start;}
.ico-yes{color:#F4B400;font-weight:800;flex-shrink:0;}
.ico-no{color:#0B0B0B;font-weight:800;flex-shrink:0;}

/* ── FAQ ──────────────────────────────────────── */
.d-faq-list{display:flex;flex-direction:column;margin-top:36px;border-top:1px solid #E5E5E5;}
.d-faq-item{border-bottom:1px solid #E5E5E5;}
.d-faq-btn{
  width:100%;display:flex;justify-content:space-between;align-items:center;
  padding:20px 0;background:none;border:none;cursor:pointer;
  font-family:'Montserrat',sans-serif;
  font-size:.92rem;font-weight:600;color:#0B0B0B;
  text-align:left;gap:16px;
}
.d-faq-icon{
  width:28px;height:28px;border:2px solid #0B0B0B;border-radius:50%;
  display:flex;align-items:center;justify-content:center;
  font-size:.9rem;font-weight:700;flex-shrink:0;
  transition:background .2s,border-color .2s,color .2s;
}
.d-faq-btn[aria-expanded="true"] .d-faq-icon{
  background:#F4B400;border-color:#F4B400;color:#0B0B0B;
}
.d-faq-body{max-height:0;overflow:hidden;transition:max-height .35s ease;}
.d-faq-body p{font-size:.88rem;color:#666;line-height:1.75;padding-bottom:20px;}

/* ── CTA FINAL (dark) ─────────────────────────── */
.d-cta-sec{
  background:#0B0B0B;
  padding:80px 24px;text-align:center;
}
.d-cta-inner{max-width:560px;margin:0 auto;}
.d-offer-badge{
  display:inline-flex;align-items:center;gap:8px;
  background:rgba(244,180,0,.08);border:1px solid rgba(244,180,0,.3);
  border-radius:3px;padding:6px 14px;
  color:#F4B400;font-size:.68rem;font-weight:700;
  letter-spacing:.14em;text-transform:uppercase;
  margin-bottom:28px;
}
.d-offer-price{
  font-family:'Bebas Neue',sans-serif;
  font-size:5.5rem;line-height:1;color:#fff;
}
.d-offer-price sup{font-size:2rem;vertical-align:super;margin-right:2px;}
.d-offer-inst{font-size:.78rem;color:#555;margin-top:6px;margin-bottom:28px;}
.d-offer-ul{
  list-style:none;display:flex;flex-direction:column;gap:10px;
  margin-bottom:36px;text-align:left;
  max-width:380px;margin-left:auto;margin-right:auto;
}
.d-offer-ul li{
  display:flex;gap:12px;font-size:.88rem;color:#999;
  align-items:flex-start;line-height:1.5;
}
.d-offer-ul li::before{content:'—';color:#F4B400;flex-shrink:0;}
.d-offer-why{
  margin-top:20px;font-size:.78rem;color:#444;
  line-height:1.7;max-width:380px;margin-left:auto;margin-right:auto;
}

/* ── BUTTON ───────────────────────────────────── */
.d-btn{
  display:inline-flex;align-items:center;justify-content:center;gap:10px;
  background:#F4B400;color:#0B0B0B;
  font-family:'Montserrat',sans-serif;
  font-weight:800;font-size:1rem;letter-spacing:.01em;
  padding:18px 48px;border-radius:4px;
  text-decoration:none;
  transition:background .2s,color .2s;
  white-space:nowrap;
}
.d-btn:hover{background:#fff;color:#0B0B0B;}

/* ── FOOTER ───────────────────────────────────── */
.d-footer{
  background:#0B0B0B;padding:32px 24px;
  text-align:center;border-top:1px solid rgba(255,255,255,.05);
}
.d-footer-logo{width:44px;height:auto;margin-bottom:14px;opacity:.35;}
.d-footer-links{display:flex;gap:24px;justify-content:center;margin-bottom:12px;}
.d-footer-links a{font-size:.72rem;color:#444;text-decoration:none;}
.d-footer-copy{font-size:.7rem;color:#333;}

/* ── Reveal ───────────────────────────────────── */
.reveal{opacity:0;transform:translateY(20px);transition:opacity .5s ease,transform .5s ease;}
.reveal.in{opacity:1;transform:translateY(0);}

/* ── Responsive ───────────────────────────────── */
@media(max-width:720px){
  .d-sec{padding:56px 20px;}
  .d-proof-grid{grid-template-columns:repeat(2,1fr);}
  .d-method-grid{grid-template-columns:1fr;}
  .d-benefit-grid{grid-template-columns:1fr;}
  .d-whom-grid{grid-template-columns:1fr;}
  .d-offer-price{font-size:4rem;}
}
</style>

<div class="d">

  <!-- ═══ HERO ═════════════════════════════════ -->
  <section class="d-hero">
    <img
      src="/images/hero-desafio.png"
      alt="Desafio Goleiro de Elite — Transformando o corpo e o desempenho de goleiros"
      class="d-hero-img"
      loading="eager"
      fetchpriority="high"
    />
  </section>

  <!-- ═══ VAGAS + COUNTDOWN ════════════════════ -->
  <section class="d-vagas">
    <div class="d-vagas-inner">
      <div class="d-vagas-badge">⚡ Vagas Limitadas</div>
      <div class="d-vagas-num">70</div>
      <div class="d-vagas-label">goleiros por turma</div>
      <div class="d-vagas-bar-wrap">
        <div class="d-vagas-bar-fill"></div>
      </div>
      <div class="d-vagas-slots"><strong>52 vagas ocupadas</strong> · 18 disponíveis</div>

      <div class="d-vagas-divider"></div>

      <div class="d-cd-lbl">Próxima turma começa em</div>
      <div class="d-cd-timer" id="d-countdown">--:--:--</div>
      <div class="d-cd-date" id="d-next-date">segunda-feira</div>
    </div>
  </section>

  <!-- ═══ O PROBLEMA ═══════════════════════════ -->
  <section class="d-sec">
    <div class="d-inner reveal">
      <div class="d-tag">O problema</div>
      <h2 class="d-title">Você treina.<br>Você se dedica.<br>Mas na hora do jogo…</h2>
      <div class="d-yline"></div>
    </div>
    <div class="d-inner">
      <div class="d-pain-list">
        <div class="d-pain-item reveal">
          <div class="d-pain-x">✗</div>
          <span class="d-pain-txt">Suas pernas não respondem no momento decisivo</span>
        </div>
        <div class="d-pain-item reveal" style="transition-delay:.06s">
          <div class="d-pain-x">✗</div>
          <span class="d-pain-txt">Você cai e demora pra levantar pra próxima jogada</span>
        </div>
        <div class="d-pain-item reveal" style="transition-delay:.1s">
          <div class="d-pain-x">✗</div>
          <span class="d-pain-txt">No segundo tempo você perde a disputa aérea que no primeiro pegava</span>
        </div>
        <div class="d-pain-item reveal" style="transition-delay:.14s">
          <div class="d-pain-x">✗</div>
          <span class="d-pain-txt">Você treina na academia toda semana mas a melhora no gol não aparece</span>
        </div>
        <div class="d-pain-item reveal" style="transition-delay:.18s">
          <div class="d-pain-x">✗</div>
          <span class="d-pain-txt">Você leva gol que sabia que era pra pegar</span>
        </div>
      </div>
      <div class="d-pivot reveal">
        Não faltou treino. Não faltou esforço. Não faltou técnica.<br>
        <strong>Faltou o tipo certo de treino para goleiro.</strong>
      </div>
    </div>
  </section>

  <!-- ═══ PROVAS REAIS ══════════════════════════ -->
  <section class="d-sec d-gray">
    <div class="d-inner reveal">
      <div class="d-tag">Resultados reais</div>
      <h2 class="d-title">O que acontece quando<br>o goleiro treina <span class="yl">do jeito certo</span></h2>
    </div>
    <div class="d-inner">
      <div class="d-proof-grid reveal" style="transition-delay:.1s">
        <div class="d-proof-item">
          <img src="/images/carrossel-1.webp" srcset="/images/carrossel-1-420.webp 420w,/images/carrossel-1.webp 900w" sizes="(max-width:720px) 50vw,33vw" alt="Resultado goleiro" class="d-proof-img" loading="lazy" />
          <div><div class="d-proof-name">Fabíola Stelzer</div><div class="d-proof-role">Goleira Amadora · ES</div></div>
        </div>
        <div class="d-proof-item">
          <img src="/images/carrossel-2.webp" srcset="/images/carrossel-2-420.webp 420w,/images/carrossel-2.webp 900w" sizes="(max-width:720px) 50vw,33vw" alt="Resultado goleiro" class="d-proof-img" loading="lazy" />
          <div><div class="d-proof-name">Rafael S.</div><div class="d-proof-role">Goleiro Profissional</div></div>
        </div>
        <div class="d-proof-item">
          <img src="/images/carrossel-3.webp" srcset="/images/carrossel-3-420.webp 420w,/images/carrossel-3.webp 900w" sizes="(max-width:720px) 50vw,33vw" alt="Resultado goleiro" class="d-proof-img" loading="lazy" />
          <div><div class="d-proof-name">Diego A.</div><div class="d-proof-role">Goleiro de base · MG</div></div>
        </div>
        <div class="d-proof-item">
          <img src="/images/carrossel-4.webp" srcset="/images/carrossel-4-420.webp 420w,/images/carrossel-4.webp 900w" sizes="(max-width:720px) 50vw,33vw" alt="Resultado goleiro" class="d-proof-img" loading="lazy" />
          <div><div class="d-proof-name">Thiago R.</div><div class="d-proof-role">Goleiro amador · PR</div></div>
        </div>
        <div class="d-proof-item">
          <img src="/images/carrossel-5.webp" srcset="/images/carrossel-5-420.webp 420w,/images/carrossel-5.webp 900w" sizes="(max-width:720px) 50vw,33vw" alt="Resultado goleiro" class="d-proof-img" loading="lazy" />
          <div><div class="d-proof-name">Matheus F.</div><div class="d-proof-role">Goleiro aspirante · RS</div></div>
        </div>
        <div class="d-proof-item">
          <img src="/images/carrossel-6.webp" srcset="/images/carrossel-6-420.webp 420w,/images/carrossel-6.webp 900w" sizes="(max-width:720px) 50vw,33vw" alt="Resultado goleiro" class="d-proof-img" loading="lazy" />
          <div><div class="d-proof-name">Bruno C.</div><div class="d-proof-role">Goleiro universitário · BA</div></div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ O MÉTODO (dark) ══════════════════════ -->
  <section class="d-sec d-dark">
    <div class="d-inner reveal">
      <div class="d-tag">O método</div>
      <h2 class="d-title d-title-w">5 dias de treino físico<br><span class="yl">específico para goleiro</span></h2>
      <p class="d-sub d-sub-w" style="margin-bottom:0">
        O método EFV — Explosão, Força e Velocidade — é o único tipo de treino físico que transfere diretamente para o que o goleiro precisa dentro de campo.
      </p>
    </div>
    <div class="d-inner">
      <div class="d-method-grid">
        <div class="d-method-card reveal">
          <div class="d-method-num">01</div>
          <div class="d-method-name">Treino específico</div>
          <div class="d-method-desc">Explosão, Força e Velocidade — sem bola, sem técnica. Só o que o corpo do goleiro precisa pra responder quando o jogo exige.</div>
        </div>
        <div class="d-method-card reveal" style="transition-delay:.08s">
          <div class="d-method-num">02</div>
          <div class="d-method-name">Acompanhamento ao vivo</div>
          <div class="d-method-desc">Grupo com treinadores certificados durante os 5 dias. Correção de execução por vídeo, dúvidas respondidas, energia coletiva.</div>
        </div>
        <div class="d-method-card reveal" style="transition-delay:.14s">
          <div class="d-method-num">03</div>
          <div class="d-method-name">Menu nutricional</div>
          <div class="d-method-desc">Plano alimentar desenhado pra otimizar os 5 dias de treino. Simples, prático, sem complicação.</div>
        </div>
        <div class="d-method-card reveal" style="transition-delay:.2s">
          <div class="d-method-num">04</div>
          <div class="d-method-name">Ciclo semanal</div>
          <div class="d-method-desc">Treinos liberados na véspera. Você treina no seu horário — academia ou em casa. Nova turma toda segunda-feira.</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ TRANSFORMAÇÃO ═════════════════════════ -->
