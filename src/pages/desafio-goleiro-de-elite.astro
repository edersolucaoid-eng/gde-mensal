---
import Base from '../layouts/Base.astro';
---
<Base title="Desafio Goleiro de Elite | 5 Dias de Treino Físico Específico para Goleiros" heroImage="/images/logo-gde.webp">
<Fragment slot="head">
  <script is:inline>!function(i,n){i._plt=i._plt||(n&&n.timeOrigin?n.timeOrigin+n.now():Date.now())}(window,performance);</script>
  <link rel="preload" href="https://scripts.converteai.net/54614f94-0915-47ec-b3bb-c6614fdad9d2/players/6a19b604dbdb1fd296650d4b/v4/player.js" as="script" />
  <link rel="preload" href="https://scripts.converteai.net/lib/js/smartplayer-wc/v4/smartplayer.js" as="script" />
  <link rel="dns-prefetch" href="https://cdn.converteai.net" />
  <link rel="dns-prefetch" href="https://scripts.converteai.net" />
  <link rel="dns-prefetch" href="https://images.converteai.net" />
  <link rel="dns-prefetch" href="https://license.vturb.com" />
</Fragment>
<style>
/* ─── Reset & base ─────────────────────────────────────────── */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

body {
  font-family: 'Barlow', sans-serif;
  background: #0B0B0B;
  color: #fff;
  overflow-x: hidden;
}

/* ─── Tokens ────────────────────────────────────────────────── */
:root {
  --black:  #0B0B0B;
  --white:  #ffffff;
  --yellow: #F4B400;
  --sec-v: clamp(60px, 8vw, 100px);
  --wrap: 860px;
  --wrap-wide: 1040px;
}

/* ─── Layout ────────────────────────────────────────────────── */
.wrap      { max-width: var(--wrap);      margin: 0 auto; padding: 0 clamp(24px,5vw,48px); }
.wrap-wide { max-width: var(--wrap-wide); margin: 0 auto; padding: 0 clamp(24px,5vw,48px); }

/* dark and light sections */
.s-dark  { background: var(--black); color: var(--white); padding: var(--sec-v) 0; }
.s-light { background: var(--white); color: var(--black); padding: var(--sec-v) 0; }
.s-yellow{ background: var(--yellow);color: var(--black); padding: var(--sec-v) 0; }

/* ─── Section label ─────────────────────────────────────────── */
.label {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: .65rem;
  font-weight: 700;
  letter-spacing: .22em;
  text-transform: uppercase;
  display: flex;
  align-items: center;
  gap: 10px;
  margin-bottom: 18px;
}
.label::before {
  content: '';
  display: block;
  width: 24px;
  height: 1px;
}
.s-dark  .label { color: var(--yellow); }
.s-dark  .label::before { background: var(--yellow); }
.s-light .label { color: rgba(0,0,0,.4); }
.s-light .label::before { background: rgba(0,0,0,.4); }
.s-yellow .label { color: rgba(0,0,0,.55); }
.s-yellow .label::before { background: rgba(0,0,0,.55); }

/* ─── Headings ──────────────────────────────────────────────── */
.display {
  font-family: 'Bebas Neue', sans-serif;
  line-height: .88;
  letter-spacing: .01em;
  font-size: clamp(3.2rem, 9vw, 6.5rem);
  margin-bottom: clamp(48px, 7vw, 80px);
}
.display .yl   { color: var(--yellow); }
.display .faded{ color: rgba(255,255,255,.18); }

/* ─── Horizontal rule ───────────────────────────────────────── */
hr {
  border: none;
  height: 1px;
  margin-bottom: clamp(48px, 7vw, 80px);
}
.s-dark  hr { background: rgba(255,255,255,.08); }
.s-light hr { background: rgba(0,0,0,.1); }

/* ─── LOCKED STATE (página fechada até 3:10 do VSL) ─────── */
body.is-locked .schedule-sec,
body.is-locked .s-dark,
body.is-locked .s-light,
body.is-locked .plan-sec,
body.is-locked .foot { display: none !important; }
.hero-cta.is-hidden { display: none !important; }
.hero-vsl {
  width: 100%;
  max-width: 420px;
  margin: clamp(8px,2vw,18px) auto 0;
}
.hero-cta {
  position: relative;
  overflow: hidden;
  align-self: center;
  margin-top: clamp(20px,3vw,32px);
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 10px;
  padding: 18px 44px;
  border-radius: 14px;
  background: linear-gradient(180deg, #F4C400 0%, #E0A800 100%);
  box-shadow: 0 16px 40px rgba(244,180,0,.32);
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 1.05rem;
  font-weight: 700;
  letter-spacing: .14em;
  text-transform: uppercase;
  color: var(--black);
  text-decoration: none;
  transition: opacity .15s, transform .2s, box-shadow .3s;
  animation: ctaPulse 2.6s ease-in-out infinite;
}
.hero-cta:hover {
  opacity: .95;
  transform: translateY(-3px);
  box-shadow: 0 24px 60px rgba(244,180,0,.55);
  animation-play-state: paused;
}

/* ─── HERO CENTRALIZADO ────────────────────────────────────── */
.hero {
  background: var(--black);
  min-height: 100svh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: clamp(20px,4vw,48px) clamp(16px,4vw,32px);
}
.hero-inner {
  width: 100%;
  max-width: 720px;
  margin: 0 auto;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: clamp(28px,4vw,40px);
}
.hero-text {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  gap: 20px;
}
.hero-eyebrow {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: .7rem;
  font-weight: 700;
  letter-spacing: .24em;
  text-transform: uppercase;
  color: var(--yellow);
}
.hero-headline {
  font-family: 'Bebas Neue', sans-serif;
  font-size: clamp(1.5rem, 3.2vw, 2.2rem);
  line-height: 1.05;
  color: var(--white);
  letter-spacing: .01em;
  margin: 0;
  max-width: 620px;
}
.hero-headline .yl { color: var(--yellow); }
.hero-sub {
  font-family: 'Barlow', sans-serif;
  font-size: clamp(.95rem, 1.6vw, 1.08rem);
  line-height: 1.5;
  color: rgba(255,255,255,.72);
  max-width: 560px;
  margin: 0;
}
.hero-sub strong { color: var(--white); font-weight: 600; }
.hero-media {
  order: -1;
  width: 100%;
  max-width: 420px;
}
.hero-media img {
  width: 100%;
  height: auto;
  display: block;
  border-radius: 16px;
  margin: 0 auto;
}
@media (max-width: 900px) {
  .hero { padding: 0 0 clamp(32px,7vw,52px); min-height: auto; }
  .hero-inner { gap: 24px; }
  .hero-media { max-width: 100%; }
  .hero-media img {
    max-width: 100%;
    border-radius: 0;
    margin: 0;
    width: 100%;
  }
  .hero-text {
    padding: 0 24px;
  }
}

/* ─── CRONOGRAMA DA SEMANA ─────────────────────────────────── */
.schedule-sec {
  background: var(--black);
  padding: clamp(40px,6vw,72px) 0;
  border-bottom: 1px solid rgba(255,255,255,.04);
}
.schedule-intro {
  text-align: center;
  max-width: 540px;
  margin: 0 auto clamp(28px,4vw,40px);
  padding: 0 clamp(24px,5vw,48px);
}
.schedule-intro .label { justify-content: center; margin-bottom: 14px; }
.schedule-intro h3 {
  font-family: 'Bebas Neue', sans-serif;
  font-size: clamp(1.6rem,3vw,2.2rem);
  letter-spacing: .02em;
  color: var(--white);
  line-height: 1.05;
}
.schedule-grid {
  max-width: var(--wrap-wide);
  margin: 0 auto;
  padding: 0 clamp(24px,5vw,48px);
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 12px;
}
.schedule-card {
  background: rgba(255,255,255,.04);
  border: 1px solid rgba(255,255,255,.08);
  border-radius: 12px;
  padding: 22px 18px 24px;
  display: flex;
  flex-direction: column;
  transition: transform .35s ease, border-color .3s, background .3s, box-shadow .3s;
}
.schedule-card:hover {
  transform: translateY(-4px);
  border-color: rgba(244,180,0,.45);
  background: rgba(244,180,0,.06);
  box-shadow: 0 18px 44px rgba(244,180,0,.22);
}
.schedule-n {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 1.6rem;
  color: var(--yellow);
  line-height: 1;
  letter-spacing: .04em;
  margin-bottom: 14px;
}
.schedule-day {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: .68rem;
  font-weight: 700;
  letter-spacing: .22em;
  text-transform: uppercase;
  color: rgba(255,255,255,.5);
  margin-bottom: 6px;
}
.schedule-title {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 1.02rem;
  font-weight: 700;
  letter-spacing: .04em;
  text-transform: uppercase;
  color: var(--white);
  line-height: 1.15;
  margin-bottom: 12px;
}
.schedule-desc {
  font-size: .78rem;
  color: rgba(255,255,255,.42);
  line-height: 1.5;
}
@media (max-width: 900px) {
  .schedule-grid { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 600px) {
  .schedule-grid { grid-template-columns: 1fr; }
}

/* ─── COUNTDOWN ─────────────────────────────────────────────── */
.cd-block {
  text-align: center;
  max-width: 520px;
  margin: 0 auto;
}
.cd-block .label { justify-content: center; margin-bottom: 4px; }
.cd-time {
  font-family: 'Bebas Neue', sans-serif;
  font-size: clamp(3rem, 9vw, 5rem);
  letter-spacing: .04em;
  color: var(--white);
  line-height: 1;
  margin: 12px 0 10px;
}
.cd-labels {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: .58rem;
  font-weight: 700;
  letter-spacing: .28em;
  text-transform: uppercase;
  color: rgba(255,255,255,.3);
  margin-bottom: 18px;
}
.cd-date {
  font-size: .82rem;
  color: rgba(255,255,255,.55);
  margin-bottom: 28px;
  font-weight: 500;
}
.cd-date span { color: var(--white); }
.cd-bar {
  height: 2px;
  background: rgba(255,255,255,.08);
  border-radius: 1px;
  overflow: hidden;
  margin-bottom: 10px;
}
.cd-fill {
  height: 100%;
  background: var(--yellow);
  width: 74.3%;
}
.cd-slots {
  font-size: .74rem;
  color: rgba(255,255,255,.4);
  letter-spacing: .03em;
  font-weight: 500;
}
.cd-slots strong { color: var(--yellow); font-weight: 700; }
.cd-cta {
  margin-top: 28px;
  font-size: 1.05rem;
  padding: 18px 36px;
  border-radius: 14px;
  animation: ctaPulse 2.6s ease-in-out infinite;
}
.cd-cta:hover { animation-play-state: paused; }
.cd-foot {
  margin-top: 14px;
  font-size: .72rem;
  letter-spacing: .04em;
  color: rgba(255,255,255,.4);
}

/* ─── PROBLEM LIST ──────────────────────────────────────────── */
.pain-list {
  list-style: none;
  border-top: 1px solid rgba(0,0,0,.1);
}
.pain-item {
  display: flex;
  align-items: center;
  gap: 20px;
  padding: 22px 0;
  border-bottom: 1px solid rgba(0,0,0,.1);
}
.pain-x {
  width: 26px;
  height: 26px;
  border: 1.5px solid var(--black);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: .62rem;
  font-weight: 700;
  color: var(--black);
  flex-shrink: 0;
}
.pain-item span {
  font-size: 1rem;
  font-weight: 500;
  color: var(--black);
  line-height: 1.3;
}
.pivot-quote {
  margin-top: 40px;
  padding: 28px 32px;
  background: var(--black);
  font-size: clamp(.95rem,2.2vw,1.08rem);
  font-weight: 500;
  color: rgba(255,255,255,.45);
  line-height: 1.7;
  border-left: 3px solid var(--yellow);
}
.pivot-quote strong { color: var(--yellow); }

/* ─── PROOF CAROUSEL ─────────────────────────────────────────── */
.proof-clip {
  overflow: hidden;   /* clips side cards — must be separate from perspective element */
  width: 100%;
  margin-top: clamp(40px,6vw,64px);
}
.proof-carousel-outer {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  perspective: 1200px;
}
.proof-track {
  position: relative;
  width: 100%;
  height: 460px;
  display: flex;
  align-items: center;
  justify-content: center;
  transform-style: preserve-3d;
}
.proof-slide {
  position: absolute;
  width: 260px;
  height: 400px;
  border-radius: 20px;
  overflow: hidden;
  border: 1px solid rgba(255,255,255,.1);
  transition: transform .5s ease, opacity .5s ease, filter .5s ease, box-shadow .5s ease, border-color .5s ease;
  cursor: pointer;
}
.proof-slide img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}
.proof-slide-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to top, rgba(0,0,0,.88) 0%, rgba(0,0,0,.2) 55%, transparent 100%);
}
.proof-caption {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 18px 18px 22px;
  z-index: 2;
}
.proof-role-pill {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  border-radius: 9999px;
  background: rgba(255,255,255,.08);
  border: 1px solid rgba(255,255,255,.15);
  padding: 3px 10px;
  font-family: 'Barlow Condensed', sans-serif;
  font-size: .62rem;
  letter-spacing: .08em;
  color: rgba(255,255,255,.75);
  margin-bottom: 7px;
}
.proof-slide-name {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 1.25rem;
  font-weight: 700;
  letter-spacing: .03em;
  color: var(--white);
  line-height: 1.1;
}
.proof-active-badge {
  display: none;
  position: absolute;
  top: 14px;
  right: 14px;
  z-index: 3;
  background: var(--yellow);
  color: var(--black);
  font-family: 'Barlow Condensed', sans-serif;
  font-size: .6rem;
  font-weight: 700;
  letter-spacing: .1em;
  text-transform: uppercase;
  border-radius: 9999px;
  padding: 4px 10px;
}
.proof-slide.is-active { border-color: rgba(244,180,0,.5); }
.proof-slide.is-active .proof-active-badge { display: block; }
/* nav buttons */
.proof-nav {
  position: absolute;
  z-index: 20;
  width: 44px;
  height: 44px;
  border-radius: 50%;
  background: rgba(0,0,0,.55);
  border: 1px solid rgba(255,255,255,.1);
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  color: var(--white);
  transition: background .2s;
  flex-shrink: 0;
}
.proof-nav:hover { background: rgba(255,255,255,.08); }
.proof-nav-prev { left: 0; }
.proof-nav-next { right: 0; }

/* ─── METHOD LIST ───────────────────────────────────────────── */
.method-list { border-top: 1px solid rgba(0,0,0,.1); }
.method-item {
  display: grid;
  grid-template-columns: 80px 1fr;
  border-bottom: 1px solid rgba(0,0,0,.1);
  padding: 36px 0;
  gap: 0;
}
.method-n {
  font-family: 'Bebas Neue', sans-serif;
  font-size: clamp(3rem,7vw,4.5rem);
  color: var(--yellow);
  line-height: 1;
  padding-right: 24px;
  border-right: 1px solid rgba(0,0,0,.1);
  align-self: start;
}
.method-body { padding-left: 32px; padding-top: 4px; }
.method-title {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 1.1rem;
  font-weight: 700;
  letter-spacing: .05em;
  text-transform: uppercase;
  color: var(--black);
  margin-bottom: 12px;
}
.method-ul { list-style: none; display: flex; flex-direction: column; gap: 8px; }
.method-ul li {
  font-size: .88rem;
  color: rgba(0,0,0,.55);
  display: flex;
  gap: 12px;
  align-items: center;
}
.method-ul li::before {
  content: '';
  width: 16px;
  height: 1px;
  background: var(--yellow);
  flex-shrink: 0;
}

/* ─── METHOD RESULT (entrega → resultado) ──────────────────── */
.method-result {
  display: flex;
  gap: 10px;
  margin-top: 16px;
  padding-top: 14px;
  border-top: 1px solid rgba(244,180,0,.22);
  font-size: .92rem;
  color: var(--black);
  font-weight: 600;
  line-height: 1.45;
}
.method-result::before {
  content: '→';
  color: var(--yellow);
  font-weight: 700;
  flex-shrink: 0;
}
.method-bonus {
  margin-top: 28px;
  padding: 18px 22px;
  background: rgba(244,180,0,.08);
  border-left: 3px solid var(--yellow);
  font-size: .9rem;
  color: rgba(0,0,0,.72);
  line-height: 1.55;
}
.method-bonus strong { color: var(--black); }
.method-intro {
  margin-top: 18px;
  max-width: 640px;
  font-size: clamp(.98rem, 1.6vw, 1.1rem);
  line-height: 1.6;
  color: rgba(0,0,0,.68);
}

/* ─── BOTÃO CTA INLINE ─────────────────────────────────────── */
.btn-inline-wrap { text-align: center; margin-top: 36px; }
.btn-inline {
  position: relative;
  overflow: hidden;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  padding: 16px 36px;
  border-radius: 12px;
  background: linear-gradient(180deg, #F4C400 0%, #E0A800 100%);
  box-shadow: 0 10px 32px rgba(244,180,0,.22);
  font-family: 'Barlow Condensed', sans-serif;
  font-size: .95rem;
  font-weight: 700;
  letter-spacing: .14em;
  text-transform: uppercase;
  color: var(--black);
  text-decoration: none;
  transition: opacity .15s, transform .2s, box-shadow .3s;
}
.btn-inline:hover {
  opacity: .95;
  transform: translateY(-2px);
  box-shadow: 0 18px 44px rgba(244,180,0,.4);
}

/* ─── INCLUDED TABLE ────────────────────────────────────────── */
.inc-table { border-top: 1px solid rgba(255,255,255,.06); }
.inc-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  padding: 22px 0;
  border-bottom: 1px solid rgba(255,255,255,.06);
  gap: 24px;
}
.inc-name {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: .95rem;
  font-weight: 700;
  letter-spacing: .04em;
  text-transform: uppercase;
  color: var(--white);
  margin-bottom: 4px;
}
.inc-desc { font-size: .76rem; color: rgba(255,255,255,.3); }
.inc-val {
  font-size: .8rem;
  color: rgba(255,255,255,.15);
  text-decoration: line-through;
  white-space: nowrap;
  flex-shrink: 0;
  padding-top: 2px;
}
.inc-total {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28px 0;
  border-top: 1px solid var(--yellow);
}
.inc-total-lbl {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: .6rem;
  letter-spacing: .16em;
  text-transform: uppercase;
  color: rgba(255,255,255,.3);
}
.inc-total-was { font-size: .82rem; color: rgba(255,255,255,.18); text-decoration: line-through; margin-top: 4px; }
.inc-price {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 4.5rem;
  color: var(--yellow);
  line-height: 1;
}
.inc-price sup { font-size: 1.6rem; vertical-align: super; }
.inc-price-label {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: .58rem;
  letter-spacing: .16em;
  text-transform: uppercase;
  color: rgba(255,255,255,.28);
  margin-bottom: 4px;
  text-align: right;
}

/* ─── ACCESS STEPS ──────────────────────────────────────────── */
.step-list { border-top: 1px solid rgba(0,0,0,.1); max-width: 640px; }
.step-item {
  display: flex;
  gap: 28px;
  padding: 32px 0;
  border-bottom: 1px solid rgba(0,0,0,.1);
  align-items: flex-start;
}
.step-n {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 2.2rem;
  color: var(--yellow);
  line-height: 1;
  flex-shrink: 0;
  min-width: 32px;
}
.step-title {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 1.05rem;
  font-weight: 700;
  letter-spacing: .05em;
  text-transform: uppercase;
  color: var(--black);
  margin-bottom: 6px;
}
.step-desc { font-size: .86rem; color: rgba(0,0,0,.5); line-height: 1.6; }

/* ─── PRA QUEM É ────────────────────────────────────────────── */
.whom-ul {
  list-style: none;
  margin-top: 28px;
  display: inline-flex;
  flex-direction: column;
  gap: 16px;
  text-align: left;
}
.whom-ul li {
  display: flex;
  gap: 14px;
  font-size: .95rem;
  line-height: 1.45;
  align-items: flex-start;
  color: rgba(255,255,255,.7);
}
.ico-y { color: var(--yellow); font-weight: 700; flex-shrink: 0; }

/* ─── FAQ ───────────────────────────────────────────────────── */
.faq-list { border-top: 1px solid rgba(0,0,0,.1); }
.faq-item { border-bottom: 1px solid rgba(0,0,0,.1); }
.faq-btn {
  width: 100%;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 22px 0;
  background: none;
  border: none;
