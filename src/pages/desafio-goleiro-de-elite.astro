---
import Base from '../layouts/Base.astro';
---
<Base title="Desafio Goleiro de Elite | 5 Dias de Treino Físico Específico para Goleiros">
<style>
@import url('https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Barlow:wght@400;500;600&family=Barlow+Condensed:wght@600;700&display=swap');

/* ── Reset ────────────────────────────────────────── */
.g *,.g *::before,.g *::after{box-sizing:border-box;margin:0;padding:0;}
.g{
  font-family:'Barlow',sans-serif;
  background:#0B0B0B;
  color:#fff;
  overflow-x:hidden;
}

/* ── Primitives ───────────────────────────────────── */
.wrap{max-width:1020px;margin:0 auto;padding:0 clamp(20px,5vw,48px);}
.wrap-sm{max-width:620px;margin:0 auto;padding:0 clamp(20px,5vw,48px);}
.sec{padding:clamp(80px,12vw,140px) 0;}
.sec-w{background:#fff;color:#0B0B0B;}
.sec-b{background:#0B0B0B;color:#fff;}

.lbl{
  font-family:'Barlow Condensed',sans-serif;
  font-size:.62rem;font-weight:700;letter-spacing:.22em;text-transform:uppercase;
  display:inline-flex;align-items:center;gap:10px;
}
.lbl::before{content:'';display:block;width:28px;height:1px;}
.lbl-y{color:#F4B400;}.lbl-y::before{background:#F4B400;}
.lbl-k{color:#0B0B0B;}.lbl-k::before{background:#0B0B0B;}

.h{font-family:'Bebas Neue',sans-serif;line-height:.9;letter-spacing:.01em;}
.yl{color:#F4B400;}

/* ── Hero ─────────────────────────────────────────── */
.hero{
  background:#0B0B0B;
  display:flex;justify-content:center;align-items:flex-start;
}
.hero img{width:100%;max-width:520px;height:auto;display:block;}

/* ── Vagas ────────────────────────────────────────── */
.vagas{
  background:#0B0B0B;
  border-top:1px solid rgba(255,255,255,.06);
  padding:clamp(64px,10vw,100px) 0;
  text-align:center;
}
.vagas-inner{max-width:440px;margin:0 auto;padding:0 24px;}
.vagas-num{
  font-family:'Bebas Neue',sans-serif;
  font-size:clamp(8rem,22vw,13rem);
  line-height:.82;color:#fff;letter-spacing:-.02em;
}
.vagas-num b{color:#F4B400;}
.vagas-sub{
  font-family:'Barlow Condensed',sans-serif;
  font-size:.68rem;font-weight:700;letter-spacing:.2em;text-transform:uppercase;
  color:#3a3a3a;margin-top:6px;margin-bottom:32px;
}
.vagas-bar{height:2px;background:rgba(255,255,255,.07);margin-bottom:7px;}
.vagas-fill{height:100%;background:#F4B400;width:74.3%;}
.vagas-slots{font-size:.72rem;color:#3a3a3a;font-weight:500;margin-bottom:48px;}
.vagas-slots strong{color:#F4B400;}
.vagas-div{width:1px;height:44px;background:rgba(255,255,255,.1);margin:0 auto 44px;}
.vagas-cd-lbl{
  font-family:'Barlow Condensed',sans-serif;
  font-size:.62rem;font-weight:700;letter-spacing:.2em;text-transform:uppercase;
  color:#3a3a3a;margin-bottom:12px;
}
.vagas-cd{
  font-family:'Bebas Neue',sans-serif;
  font-size:clamp(3.5rem,10vw,5.5rem);letter-spacing:.06em;color:#fff;line-height:1;
}
.vagas-cd-date{font-size:.72rem;color:#3a3a3a;margin-top:10px;font-weight:500;}

/* ── Problema ─────────────────────────────────────── */
.pain-h{
  font-size:clamp(3.2rem,8vw,6rem);
  color:#0B0B0B;margin-top:14px;margin-bottom:48px;
}
.pain-list{list-style:none;border-top:1px solid #E5E5E5;}
.pain-li{
  display:flex;align-items:center;gap:18px;
  padding:20px 0;border-bottom:1px solid #E5E5E5;
}
.pain-x{
  width:26px;height:26px;border:1.5px solid #0B0B0B;
  display:flex;align-items:center;justify-content:center;
  font-size:.65rem;font-weight:700;flex-shrink:0;color:#0B0B0B;
}
.pain-li span{font-size:.98rem;font-weight:500;color:#0B0B0B;line-height:1.3;}
.pivot{
  margin-top:48px;padding:30px 36px;
  background:#0B0B0B;
  font-size:clamp(.95rem,2.2vw,1.12rem);font-weight:500;
  color:#666;line-height:1.65;
}
.pivot strong{color:#F4B400;}

/* ── Provas ───────────────────────────────────────── */
.proof-h{font-size:clamp(2.8rem,7vw,5.2rem);color:#fff;margin-top:14px;}
.proof-grid{
  margin-top:52px;
  display:grid;grid-template-columns:repeat(3,1fr);gap:2px;
}
.proof-item img{
  width:100%;aspect-ratio:1/1;object-fit:cover;display:block;
  filter:grayscale(25%);transition:filter .35s;
}
.proof-item:hover img{filter:grayscale(0%);}
.proof-cap{padding:10px 0 0;border-top:1px solid rgba(255,255,255,.08);}
.proof-name{
  font-family:'Barlow Condensed',sans-serif;
  font-size:.82rem;font-weight:700;letter-spacing:.06em;
  text-transform:uppercase;color:#fff;
}
.proof-role{font-size:.68rem;color:#444;margin-top:3px;}

/* ── Método ───────────────────────────────────────── */
.method-h{font-size:clamp(2.8rem,7vw,5rem);color:#fff;margin-top:14px;}
.method-list{margin-top:64px;}
.method-item{
  display:grid;grid-template-columns:96px 1fr;
  border-top:1px solid rgba(255,255,255,.08);
  padding:36px 0;
}
.method-item:last-child{border-bottom:1px solid rgba(255,255,255,.08);}
.method-num{
  font-family:'Bebas Neue',sans-serif;
  font-size:clamp(3.5rem,8vw,5rem);
  color:#F4B400;line-height:1;
  padding-right:28px;border-right:1px solid rgba(255,255,255,.08);
}
.method-body{padding-left:36px;}
.method-title{
  font-family:'Barlow Condensed',sans-serif;
  font-size:1.15rem;font-weight:700;letter-spacing:.05em;
  text-transform:uppercase;color:#fff;margin-bottom:14px;
}
.method-ul{list-style:none;display:flex;flex-direction:column;gap:8px;}
.method-ul li{
  font-size:.88rem;color:#555;
  display:flex;gap:12px;align-items:center;
}
.method-ul li::before{content:'';width:18px;height:1px;background:#F4B400;flex-shrink:0;}

/* ── Transformação ────────────────────────────────── */
.trfm-h{font-size:clamp(2.8rem,7vw,5rem);color:#0B0B0B;margin-top:14px;}
.trfm-list{margin-top:64px;border-top:1px solid #E5E5E5;}
.trfm-item{
  display:grid;grid-template-columns:80px 1fr;
  border-bottom:1px solid #E5E5E5;padding:36px 0;
}
.trfm-num{
  font-family:'Bebas Neue',sans-serif;
  font-size:clamp(3rem,7vw,4.5rem);
  color:#F4B400;line-height:.85;padding-right:20px;
}
.trfm-title{
  font-family:'Barlow Condensed',sans-serif;
  font-size:1.1rem;font-weight:700;letter-spacing:.04em;
  text-transform:uppercase;color:#0B0B0B;margin-bottom:12px;
}
.trfm-ul{list-style:none;display:flex;flex-direction:column;gap:7px;}
.trfm-ul li{
  font-size:.87rem;color:#777;
  display:flex;gap:10px;align-items:flex-start;line-height:1.5;
}
.trfm-ul li::before{content:'';width:14px;height:1px;background:#0B0B0B;flex-shrink:0;margin-top:9px;}

/* ── Incluído ─────────────────────────────────────── */
.inc-h{font-size:clamp(2.8rem,7vw,5rem);color:#fff;margin-top:14px;}
.inc-table{margin-top:56px;border-top:1px solid rgba(255,255,255,.1);}
.inc-row{
  display:flex;justify-content:space-between;align-items:flex-start;
  padding:22px 0;border-bottom:1px solid rgba(255,255,255,.08);gap:24px;
}
.inc-name{
  font-family:'Barlow Condensed',sans-serif;
  font-size:.95rem;font-weight:700;letter-spacing:.04em;
  text-transform:uppercase;color:#fff;margin-bottom:4px;
}
.inc-desc{font-size:.76rem;color:#444;}
.inc-val{font-size:.8rem;color:#2e2e2e;text-decoration:line-through;white-space:nowrap;flex-shrink:0;padding-top:2px;}
.inc-total{
  display:flex;justify-content:space-between;align-items:center;
  padding:24px 0;border-top:1px solid #F4B400;
}
.inc-lbl{
  font-family:'Barlow Condensed',sans-serif;
  font-size:.6rem;letter-spacing:.15em;text-transform:uppercase;color:#444;
}
.inc-was{font-size:.82rem;color:#333;text-decoration:line-through;margin-top:4px;}
.inc-price{
  font-family:'Bebas Neue',sans-serif;
  font-size:4rem;color:#F4B400;line-height:1;
}
.inc-price sup{font-size:1.6rem;vertical-align:super;margin-top:6px;display:inline-block;}

/* ── Acesso ───────────────────────────────────────── */
.access-h{font-size:clamp(2.5rem,6vw,4.5rem);color:#fff;margin-top:14px;}
.steps{
  margin-top:60px;border-top:1px solid rgba(255,255,255,.1);
  max-width:580px;
}
.step{
  display:flex;gap:28px;padding:32px 0;
  border-bottom:1px solid rgba(255,255,255,.1);align-items:flex-start;
}
.step-n{
  font-family:'Bebas Neue',sans-serif;
  font-size:2rem;color:#F4B400;line-height:1;flex-shrink:0;min-width:32px;
}
.step-t{
  font-family:'Barlow Condensed',sans-serif;
  font-size:1.05rem;font-weight:700;letter-spacing:.04em;
  text-transform:uppercase;color:#fff;margin-bottom:6px;
}
.step-d{font-size:.84rem;color:#555;line-height:1.6;}

/* ── Pra quem é / não é ───────────────────────────── */
.whom-split{display:grid;grid-template-columns:1fr 1fr;}
.whom-side{padding:clamp(48px,8vw,80px) clamp(24px,6vw,64px);}
.whom-yes{background:#0B0B0B;}
.whom-no{background:#111;}
.whom-hd{
  font-family:'Bebas Neue',sans-serif;
  font-size:clamp(2rem,4vw,3rem);letter-spacing:.02em;color:#fff;
  padding-bottom:18px;margin-bottom:8px;border-bottom:2px solid;
}
.whom-yes .whom-hd{border-color:#F4B400;}
.whom-no .whom-hd{border-color:rgba(255,255,255,.12);color:#555;}
.whom-ul{list-style:none;margin-top:26px;display:flex;flex-direction:column;gap:15px;}
.whom-ul li{display:flex;gap:14px;font-size:.88rem;line-height:1.45;align-items:flex-start;}
.whom-yes .whom-ul li{color:#888;}
.whom-no .whom-ul li{color:#3a3a3a;}
.ico-y{color:#F4B400;font-weight:700;flex-shrink:0;}
.ico-n{color:#2a2a2a;font-weight:700;flex-shrink:0;}

/* ── FAQ ──────────────────────────────────────────── */
.faq-h{font-size:clamp(2.5rem,6vw,4.5rem);color:#0B0B0B;margin-top:14px;}
.faq-list{margin-top:52px;border-top:1px solid #E5E5E5;}
.faq-item{border-bottom:1px solid #E5E5E5;}
.faq-btn{
  width:100%;display:flex;justify-content:space-between;align-items:center;
  padding:22px 0;background:none;border:none;cursor:pointer;
  font-family:'Barlow',sans-serif;
  font-size:.95rem;font-weight:600;color:#0B0B0B;text-align:left;gap:20px;
}
.faq-ico{
  width:26px;height:26px;border:1.5px solid #ccc;
  display:flex;align-items:center;justify-content:center;
  font-size:1rem;font-weight:400;flex-shrink:0;
  transition:background .2s,border-color .2s;
}
.faq-btn[aria-expanded="true"] .faq-ico{background:#F4B400;border-color:#F4B400;color:#0B0B0B;}
.faq-body{max-height:0;overflow:hidden;transition:max-height .35s ease;}
.faq-body p{font-size:.86rem;color:#777;line-height:1.8;padding-bottom:22px;padding-right:46px;}

/* ── CTA Final ────────────────────────────────────── */
.cta-sec{
  background:#0B0B0B;
  padding:clamp(80px,12vw,140px) 0;
  text-align:center;
  border-top:1px solid rgba(255,255,255,.05);
}
.cta-tag{
  font-family:'Barlow Condensed',sans-serif;
  font-size:.62rem;letter-spacing:.22em;text-transform:uppercase;
  color:#F4B400;display:block;margin-bottom:20px;
}
.cta-hd{
  font-family:'Bebas Neue',sans-serif;
  font-size:clamp(3rem,8vw,6.5rem);
  line-height:.88;color:#fff;margin-bottom:40px;
}
.cta-price{
  font-family:'Bebas Neue',sans-serif;
  font-size:clamp(6rem,18vw,10rem);
  color:#F4B400;line-height:1;letter-spacing:-.02em;
}
.cta-price sup{font-size:2.5rem;vertical-align:super;}
.cta-note{font-size:.7rem;color:#333;letter-spacing:.1em;text-transform:uppercase;margin-top:8px;margin-bottom:40px;font-weight:500;}
.cta-ul{
  list-style:none;
  display:inline-flex;flex-direction:column;gap:10px;
  text-align:left;margin-bottom:44px;
}
.cta-ul li{display:flex;gap:12px;font-size:.86rem;color:#666;align-items:center;}
.cta-ul li::before{content:'';width:18px;height:1px;background:#F4B400;flex-shrink:0;}
.cta-foot{margin-top:22px;font-size:.7rem;color:#2e2e2e;line-height:1.8;max-width:340px;margin-left:auto;margin-right:auto;}

/* ── Button ───────────────────────────────────────── */
.btn{
  display:inline-flex;align-items:center;justify-content:center;
  background:#F4B400;color:#0B0B0B;
  font-family:'Barlow Condensed',sans-serif;
  font-weight:700;font-size:1rem;letter-spacing:.14em;text-transform:uppercase;
  padding:18px 56px;border-radius:0;text-decoration:none;
  transition:background .15s,transform .15s;
}
.btn:hover{background:#fff;transform:translateY(-2px);}

/* ── Footer ───────────────────────────────────────── */
.foot{
  background:#0B0B0B;border-top:1px solid rgba(255,255,255,.05);
  padding:40px 24px;text-align:center;
}
.foot-logo{width:34px;height:auto;opacity:.4;margin:0 auto 16px;display:block;}
.foot-links{display:flex;gap:28px;justify-content:center;margin-bottom:12px;}
.foot-links a{font-size:.66rem;color:#333;text-decoration:none;letter-spacing:.05em;}
.foot-links a:hover{color:#F4B400;}
.foot-copy{font-size:.63rem;color:#2e2e2e;letter-spacing:.04em;}

/* ── Reveal ───────────────────────────────────────── */
.reveal{opacity:0;transform:translateY(18px);transition:opacity .6s ease,transform .6s ease;}
.reveal.in{opacity:1;transform:none;}

/* ── Responsive ───────────────────────────────────── */
@media(max-width:768px){
  .proof-grid{grid-template-columns:repeat(2,1fr);}
  .method-item{grid-template-columns:72px 1fr;}
  .method-num{font-size:3rem;}
  .method-body{padding-left:20px;}
  .trfm-item{grid-template-columns:60px 1fr;}
  .whom-split{grid-template-columns:1fr;}
  .whom-yes{order:1;}.whom-no{order:2;}
}
@media(max-width:480px){
  .method-item{grid-template-columns:1fr;gap:0;}
  .method-num{font-size:2.5rem;padding-right:0;border-right:none;padding-bottom:12px;border-bottom:1px solid rgba(255,255,255,.08);margin-bottom:20px;}
  .method-body{padding-left:0;}
  .trfm-item{grid-template-columns:52px 1fr;}
  .inc-row{flex-wrap:wrap;}
  .inc-val{align-self:flex-end;}
}
</style>

<div class="g">

  <!-- ── HERO ─────────────────────────────────────── -->
  <section class="hero">
    <img src="/images/hero-desafio.png" alt="Desafio Goleiro de Elite" loading="eager" fetchpriority="high" />
  </section>

  <!-- ── VAGAS + COUNTDOWN ─────────────────────────── -->
  <section class="vagas">
    <div class="vagas-inner">
      <div class="lbl lbl-y" style="justify-content:center;margin-bottom:28px">Vagas limitadas</div>
      <div class="vagas-num"><b>18</b></div>
      <div class="vagas-sub">vagas disponíveis nesta turma</div>
      <div class="vagas-bar"><div class="vagas-fill"></div></div>
      <div class="vagas-slots"><strong>52 de 70</strong> vagas preenchidas</div>
      <div class="vagas-div"></div>
      <div class="vagas-cd-lbl">Próxima turma começa em</div>
      <div class="vagas-cd" id="gde-cd">--:--:--</div>
      <div class="vagas-cd-date" id="gde-date">segunda-feira</div>
    </div>
  </section>

  <!-- ── O PROBLEMA ────────────────────────────────── -->
  <section class="sec sec-w">
    <div class="wrap">
      <div class="reveal">
        <div class="lbl lbl-k">O problema</div>
        <h2 class="h pain-h">Você treina.<br>Você se dedica.<br>Mas na hora do jogo…</h2>
      </div>
      <ul class="pain-list reveal" style="transition-delay:.08s">
        <li class="pain-li">
          <div class="pain-x">✗</div>
          <span>Pernas que não respondem no momento decisivo</span>
        </li>
        <li class="pain-li">
          <div class="pain-x">✗</div>
          <span>Cai e demora pra levantar pra próxima jogada</span>
        </li>
        <li class="pain-li">
          <div class="pain-x">✗</div>
          <span>Perde a disputa aérea no segundo tempo</span>
        </li>
        <li class="pain-li">
          <div class="pain-x">✗</div>
          <span>Treina na academia mas não melhora no gol</span>
        </li>
        <li class="pain-li">
          <div class="pain-x">✗</div>
          <span>Leva gol que sabia que era pra pegar</span>
        </li>
      </ul>
      <div class="pivot reveal" style="transition-delay:.14s">
        Não faltou treino. Não faltou esforço.<br>
        <strong>Faltou o tipo certo de treino para goleiro.</strong>
      </div>
    </div>
  </section>

  <!-- ── PROVAS REAIS ───────────────────────────────── -->
  <section class="sec sec-b">
    <div class="wrap">
      <div class="reveal">
        <div class="lbl lbl-y">Resultados reais</div>
        <h2 class="h proof-h">O que muda quando<br>o goleiro treina <span class="yl">certo</span></h2>
      </div>
      <div class="proof-grid reveal" style="transition-delay:.1s">
        <div class="proof-item">
          <img src="/images/carrossel-1.webp" srcset="/images/carrossel-1-420.webp 420w,/images/carrossel-1.webp 900w" sizes="(max-width:768px)50vw,33vw" alt="" loading="lazy" />
          <div class="proof-cap">
            <div class="proof-name">Fabíola Stelzer</div>
            <div class="proof-role">Goleira Amadora · ES</div>
          </div>
        </div>
        <div class="proof-item">
          <img src="/images/carrossel-2.webp" srcset="/images/carrossel-2-420.webp 420w,/images/carrossel-2.webp 900w" sizes="(max-width:768px)50vw,33vw" alt="" loading="lazy" />
          <div class="proof-cap">
            <div class="proof-name">Rafael S.</div>
            <div class="proof-role">Goleiro Profissional</div>
          </div>
        </div>
        <div class="proof-item">
          <img src="/images/carrossel-3.webp" srcset="/images/carrossel-3-420.webp 420w,/images/carrossel-3.webp 900w" sizes="(max-width:768px)50vw,33vw" alt="" loading="lazy" />
          <div class="proof-cap">
            <div class="proof-name">Diego A.</div>
            <div class="proof-role">Goleiro de Base · MG</div>
          </div>
        </div>
        <div class="proof-item">
          <img src="/images/carrossel-4.webp" srcset="/images/carrossel-4-420.webp 420w,/images/carrossel-4.webp 900w" sizes="(max-width:768px)50vw,33vw" alt="" loading="lazy" />
          <div class="proof-cap">
            <div class="proof-name">Thiago R.</div>
            <div class="proof-role">Goleiro Amador · PR</div>
          </div>
        </div>
        <div class="proof-item">
          <img src="/images/carrossel-5.webp" srcset="/images/carrossel-5-420.webp 420w,/images/carrossel-5.webp 900w" sizes="(max-width:768px)50vw,33vw" alt="" loading="lazy" />
          <div class="proof-cap">
            <div class="proof-name">Matheus F.</div>
            <div class="proof-role">Goleiro Aspirante · RS</div>
          </div>
        </div>
        <div class="proof-item">
          <img src="/images/carrossel-6.webp" srcset="/images/carrossel-6-420.webp 420w,/images/carrossel-6.webp 900w" sizes="(max-width:768px)50vw,33vw" alt="" loading="lazy" />
          <div class="proof-cap">
            <div class="proof-name">Bruno C.</div>
            <div class="proof-role">Goleiro Universitário · BA</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── O MÉTODO EFV ───────────────────────────────── -->
  <section class="sec sec-b" style="border-top:1px solid rgba(255,255,255,.06)">
    <div class="wrap">
      <div class="reveal">
        <div class="lbl lbl-y">O método</div>
        <h2 class="h method-h">5 dias. Treino físico.<br><span class="yl">Específico para goleiro.</span></h2>
      </div>
      <div class="method-list">
        <div class="method-item reveal" style="transition-delay:.06s">
          <div class="method-num">01</div>
          <div class="method-body">
            <div class="method-title">Treino específico</div>
            <ul class="method-ul">
              <li>Explosão, força e velocidade</li>
              <li>Sem bola, sem técnica</li>
              <li>Só o que decide no jogo</li>
            </ul>
          </div>
        </div>
        <div class="method-item reveal" style="transition-delay:.1s">
          <div class="method-num">02</div>
          <div class="method-body">
