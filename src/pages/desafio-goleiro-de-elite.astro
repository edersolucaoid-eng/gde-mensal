<script>
  function pad(n){return String(n).padStart(2,'0');}
  function nextMonday(){
    const brt=new Date(new Date().toLocaleString('en-US',{timeZone:'America/Sao_Paulo'}));
    const d=brt.getDay();
    const days=d===0?1:(8-d)%7||7;
    const m=new Date(brt);
    m.setDate(brt.getDate()+days);m.setHours(0,0,0,0);return m;
  }
  function tick(){
    const now=new Date(new Date().toLocaleString('en-US',{timeZone:'America/Sao_Paulo'}));
    const diff=nextMonday()-now;
    if(diff<=0){tick();return;}
    const dy=Math.floor(diff/86400000);
    const h=Math.floor((diff%86400000)/3600000);
    const m=Math.floor((diff%3600000)/60000);
    const s=Math.floor((diff%60000)/1000);
    const el=document.getElementById('d-countdown');
    if(el)el.textContent=dy>0?`${dy}d · ${pad(h)}:${pad(m)}:${pad(s)}`:`${pad(h)}:${pad(m)}:${pad(s)}`;
  }
  function setDate(){
    const m=nextMonday();
    const el=document.getElementById('d-next-date');
    if(el)el.textContent=m.toLocaleDateString('pt-BR',{weekday:'long',day:'numeric',month:'long',timeZone:'America/Sao_Paulo'});
  }
  tick();setDate();setInterval(tick,1000);

  const io=new IntersectionObserver(es=>{
    es.forEach(e=>{if(e.isIntersecting){e.target.classList.add('in');io.unobserve(e.target);}});
  },{threshold:.08});
  document.querySelectorAll('.reveal').forEach(el=>io.observe(el));

  document.querySelectorAll('.d-faq-btn').forEach(btn=>{
    btn.addEventListener('click',()=>{
      const open=btn.getAttribute('aria-expanded')==='true';
      document.querySelectorAll('.d-faq-btn').forEach(b=>{
        b.setAttribute('aria-expanded','false');
        b.nextElementSibling.classList.remove('open');
      });
      if(!open){btn.setAttribute('aria-expanded','true');btn.nextElementSibling.classList.add('open');}
    });
  });

  const sticky=document.getElementById('d-sticky');
  let ticking=false;
  window.addEventListener('scroll',()=>{
    if(!ticking){
      requestAnimationFrame(()=>{
        if(window.scrollY/(document.body.scrollHeight-window.innerHeight)>.3)sticky.classList.add('show');
        ticking=false;
      });ticking=true;
    }
  },{passive:true});
</script>

