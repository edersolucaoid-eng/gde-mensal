---
import Base from '../layouts/Base.astro';
---
<Base title="Desafio Goleiro de Elite | 5 Dias de Treino Físico Específico para Goleiros">
<style>
@import url('https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Barlow:wght@400;500;600&family=Barlow+Condensed:wght@600;700&display=swap');

/* ── Reset ────────────────────────────────────────── */
.g *,.g *::before,.g *::after{box-sizing:border-box;margin:0;padding:0;}
.g{font-family:'Barlow',sans-serif;background:#0B0B0B;color:#fff;overflow-x:hidden;}

/* ── Keyframes ────────────────────────────────────── */
@keyframes fadeSlideIn{from{opacity:0;transform:translateY(22px)}to{opacity:1;transform:none}}
@keyframes glowPulse{0%,100%{opacity:.15}50%{opacity:.28}}

/* ── Fixed background grid ────────────────────────── */
.g-bg{
  position:fixed;inset:0;z-index:0;pointer-events:none;
  background-image:
    linear-gradient(rgba(255,255,255,.022) 1px,transparent 1px),
    linear-gradient(90deg,rgba(255,255,255,.022) 1px,transparent 1px);
  background-size:64px 64px;
}

/* ── Layout ───────────────────────────────────────── */
.z1{position:relative;z-index:1;}
.wrap{max-width:1020px;margin:0 auto;padding:0 clamp(20px,5vw,48px);}
.wrap-sm{max-width:640px;margin:0 auto;padding:0 clamp(20px,5vw,48px);}
.sec{padding:clamp(80px,12vw,140px) 0;position:relative;z-index:1;}

/* ── Glass Card ───────────────────────────────────── */
.card{
  background:linear-gradient(225deg,rgba(255,255,255,0) 0%,rgba(255,255,255,.04) 50%,rgba(255,255,255,0) 100%);
  border:1px solid rgba(255,255,255,.08);
  border-radius:24px;
  backdrop-filter:blur(12px);
}
.card-sm{border-radius:16px;}

/* ── Badge / Pill ─────────────────────────────────── */
.badge{
  display:inline-flex;align-items:center;gap:8px;border-radius:9999px;
  padding:6px 14px;
  font-family:'Barlow Condensed',sans-serif;
  font-size:.68rem;font-weight:700;letter-spacing:.12em;text-transform:uppercase;
}
.badge-y{background:rgba(244,180,0,.12);border:1px solid rgba(244,180,0,.28);color:#F4B400;}
.badge-y .dot{width:6px;height:6px;border-radius:50%;background:#F4B400;flex-shrink:0;animation:glowPulse 2s ease-in-out infinite;}

/* ── Section label row ────────────────────────────── */
.sh-row{display:flex;align-items:center;justify-content:space-between;margin-bottom:10px;}
.sh-label{
  font-family:'Barlow Condensed',sans-serif;
  font-size:.68rem;font-weight:700;letter-spacing:.14em;text-transform:uppercase;color:#F4B400;
}
.sh-num{font-size:.65rem;color:rgba(255,255,255,.2);letter-spacing:.05em;}

/* ── Gradient separator ───────────────────────────── */
.sep{
  height:1px;
  background:linear-gradient(to right,transparent,rgba(255,255,255,.14),transparent);
  margin-bottom:clamp(36px,5vw,56px);
}

/* ── Headings ─────────────────────────────────────── */
.h{font-family:'Bebas Neue',sans-serif;line-height:.9;letter-spacing:.01em;}
.yl{color:#F4B400;}
.hd-xl{font-size:clamp(3.5rem,9vw,7.5rem);}
.hd-lg{font-size:clamp(2.8rem,7vw,5.5rem);}
.hd-md{font-size:clamp(2.4rem,6vw,4.5rem);}

/* ── Ambient glow ─────────────────────────────────── */
.glow{
  position:absolute;pointer-events:none;border-radius:50%;
  background:radial-gradient(circle,rgba(244,180,0,.22) 0%,transparent 70%);
  filter:blur(48px);
}

/* ── Hero ─────────────────────────────────────────── */
.hero{
  min-height:100svh;
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  padding:clamp(48px,8vw,80px) 0 0;
  position:relative;overflow:hidden;z-index:1;
}
.hero-badge{animation:fadeSlideIn .8s ease-out both;margin-bottom:28px;}
.hero-img-wrap{
  position:relative;width:100%;max-width:560px;
  animation:fadeSlideIn .95s ease-out .18s both;
}
.hero img{width:100%;height:auto;display:block;position:relative;z-index:1;}
.hero-glow{
  width:560px;height:560px;
  top:50%;left:50%;transform:translate(-50%,-50%);
  opacity:.35;
}

/* ── Vagas ────────────────────────────────────────── */
.vagas{padding:clamp(60px,10vw,100px) 0;position:relative;z-index:1;}
.vagas-card{
  max-width:480px;margin:0 auto;
  padding:clamp(40px,6vw,64px) clamp(32px,5vw,56px);
  text-align:center;position:relative;overflow:hidden;
}
.vagas-num{font-family:'Bebas Neue',sans-serif;font-size:clamp(8rem,22vw,13rem);line-height:.82;color:#fff;letter-spacing:-.02em;}
.vagas-num b{color:#F4B400;}
.vagas-sub{font-family:'Barlow Condensed',sans-serif;font-size:.68rem;font-weight:700;letter-spacing:.2em;text-transform:uppercase;color:rgba(255,255,255,.25);margin-top:6px;margin-bottom:28px;}
.vagas-bar{height:2px;background:rgba(255,255,255,.07);margin-bottom:7px;border-radius:2px;}
.vagas-fill{height:100%;background:#F4B400;width:74.3%;border-radius:2px;}
.vagas-slots{font-size:.72rem;color:rgba(255,255,255,.3);font-weight:500;margin-bottom:40px;}
.vagas-slots strong{color:#F4B400;}
.vagas-div{width:1px;height:40px;background:rgba(255,255,255,.1);margin:0 auto 36px;}
.vagas-cd-lbl{font-family:'Barlow Condensed',sans-serif;font-size:.62rem;font-weight:700;letter-spacing:.2em;text-transform:uppercase;color:rgba(255,255,255,.25);margin-bottom:10px;}
.vagas-cd{font-family:'Bebas Neue',sans-serif;font-size:clamp(3.5rem,10vw,5.5rem);letter-spacing:.06em;color:#fff;line-height:1;}
.vagas-cd-date{font-size:.72rem;color:rgba(255,255,255,.25);margin-top:8px;font-weight:500;}

/* ── Pain section ─────────────────────────────────── */
.pain-h{color:#fff;margin-top:14px;margin-bottom:clamp(32px,5vw,48px);}
.pain-list{list-style:none;display:flex;flex-direction:column;gap:10px;}
.pain-li{display:flex;align-items:center;gap:16px;padding:20px 24px;}
.pain-x{
  width:28px;height:28px;border:1.5px solid rgba(244,180,0,.4);border-radius:6px;
  display:flex;align-items:center;justify-content:center;
  font-size:.65rem;font-weight:700;flex-shrink:0;color:#F4B400;
}
.pain-li span{font-size:.95rem;font-weight:500;color:rgba(255,255,255,.72);line-height:1.35;}
.pivot{
  margin-top:20px;padding:26px 32px 26px 28px;
  border-left:3px solid #F4B400;
  font-size:clamp(.95rem,2.2vw,1.1rem);font-weight:500;
  color:rgba(255,255,255,.5);line-height:1.7;
}
.pivot strong{color:#F4B400;}

/* ── Proof grid ───────────────────────────────────── */
.proof-h{color:#fff;margin-top:14px;}
.proof-grid{margin-top:clamp(36px,5vw,52px);display:grid;grid-template-columns:repeat(3,1fr);gap:14px;}
.proof-item{border-radius:20px;overflow:hidden;border:1px solid rgba(255,255,255,.07);}
.proof-item img{width:100%;aspect-ratio:1/1;object-fit:cover;display:block;filter:grayscale(30%);transition:filter .4s;}
.proof-item:hover img{filter:grayscale(0%);}
.proof-cap{padding:12px 16px 14px;background:rgba(255,255,255,.03);}
.proof-name{font-family:'Barlow Condensed',sans-serif;font-size:.82rem;font-weight:700;letter-spacing:.06em;text-transform:uppercase;color:#fff;}
.proof-role{font-size:.68rem;color:rgba(255,255,255,.28);margin-top:3px;}

/* ── Method ───────────────────────────────────────── */
.method-h{color:#fff;margin-top:14px;}
.method-grid{margin-top:clamp(36px,5vw,52px);display:grid;grid-template-columns:1fr 1fr;gap:14px;}
.method-card{padding:clamp(28px,4vw,40px);display:flex;flex-direction:column;gap:18px;position:relative;overflow:hidden;}
.method-num{
  font-family:'Bebas Neue',sans-serif;font-size:clamp(4rem,8vw,6rem);
  color:#F4B400;line-height:1;opacity:.22;
  position:absolute;top:16px;right:20px;user-select:none;
}
.method-title{font-family:'Barlow Condensed',sans-serif;font-size:1.15rem;font-weight:700;letter-spacing:.05em;text-transform:uppercase;color:#fff;}
.method-ul{list-style:none;display:flex;flex-direction:column;gap:9px;}
.method-ul li{font-size:.88rem;color:rgba(255,255,255,.42);display:flex;gap:12px;align-items:center;}
.method-ul li::before{content:'';width:16px;height:1px;background:#F4B400;flex-shrink:0;}

/* ── Transformation ───────────────────────────────── */
.trfm-h{color:#fff;margin-top:14px;}
.trfm-grid{margin-top:clamp(36px,5vw,52px);display:grid;grid-template-columns:1fr 1fr;gap:14px;}
.trfm-card{padding:clamp(28px,4vw,40px);display:flex;flex-direction:column;gap:14px;position:relative;overflow:hidden;}
.trfm-num-bg{
  position:absolute;bottom:-16px;right:12px;
  font-family:'Bebas Neue',sans-serif;font-size:8rem;color:#F4B400;line-height:1;
  opacity:.055;pointer-events:none;user-select:none;
}
.trfm-title{font-family:'Barlow Condensed',sans-serif;font-size:1.05rem;font-weight:700;letter-spacing:.04em;text-transform:uppercase;color:#fff;}
.trfm-ul{list-style:none;display:flex;flex-direction:column;gap:8px;}
.trfm-ul li{font-size:.87rem;color:rgba(255,255,255,.42);display:flex;gap:10px;align-items:flex-start;line-height:1.5;}
.trfm-ul li::before{content:'';width:14px;height:1px;background:#F4B400;flex-shrink:0;margin-top:9px;}

/* ── Included ─────────────────────────────────────── */
.inc-h{color:#fff;margin-top:14px;}
.inc-card{margin-top:clamp(36px,5vw,52px);}
.inc-row{display:flex;justify-content:space-between;align-items:flex-start;padding:22px 28px;border-bottom:1px solid rgba(255,255,255,.06);gap:24px;}
.inc-name{font-family:'Barlow Condensed',sans-serif;font-size:.95rem;font-weight:700;letter-spacing:.04em;text-transform:uppercase;color:#fff;margin-bottom:4px;}
.inc-desc{font-size:.76rem;color:rgba(255,255,255,.28);}
.inc-val{font-size:.8rem;color:rgba(255,255,255,.18);text-decoration:line-through;white-space:nowrap;flex-shrink:0;padding-top:2px;}
.inc-total{display:flex;justify-content:space-between;align-items:center;padding:24px 28px;border-top:1px solid rgba(244,180,0,.28);}
.inc-lbl{font-family:'Barlow Condensed',sans-serif;font-size:.6rem;letter-spacing:.15em;text-transform:uppercase;color:rgba(255,255,255,.28);}
.inc-was{font-size:.82rem;color:rgba(255,255,255,.18);text-decoration:line-through;margin-top:4px;}
.inc-price{font-family:'Bebas Neue',sans-serif;font-size:4rem;color:#F4B400;line-height:1;}
.inc-price sup{font-size:1.6rem;vertical-align:super;margin-top:6px;display:inline-block;}

/* ── Access steps ─────────────────────────────────── */
.access-h{color:#fff;margin-top:14px;}
.steps{margin-top:clamp(36px,5vw,52px);display:grid;grid-template-columns:repeat(3,1fr);gap:14px;}
.step-card{padding:28px 28px 32px;display:flex;flex-direction:column;gap:14px;}
.step-n{
  display:inline-flex;align-items:center;justify-content:center;
  width:36px;height:36px;border-radius:9999px;
  background:rgba(244,180,0,.1);border:1px solid rgba(244,180,0,.3);
  font-family:'Bebas Neue',sans-serif;font-size:1.3rem;color:#F4B400;
}
.step-t{font-family:'Barlow Condensed',sans-serif;font-size:1.05rem;font-weight:700;letter-spacing:.04em;text-transform:uppercase;color:#fff;}
.step-d{font-size:.84rem;color:rgba(255,255,255,.38);line-height:1.6;}

/* ── Who / not who ────────────────────────────────── */
.whom-outer{position:relative;z-index:1;padding:clamp(80px,12vw,140px) 0;}
.whom-split{display:grid;grid-template-columns:1fr 1fr;gap:14px;max-width:1020px;margin:0 auto;padding:0 clamp(20px,5vw,48px);}
.whom-card{padding:clamp(40px,5vw,56px) clamp(32px,4vw,48px);}
.whom-hd{
  font-family:'Bebas Neue',sans-serif;
  font-size:clamp(2rem,4vw,3rem);letter-spacing:.02em;
  padding-bottom:14px;margin-bottom:6px;border-bottom:2px solid;
}
.whom-yes .whom-hd{border-color:#F4B400;color:#F4B400;}
.whom-no .whom-hd{border-color:rgba(255,255,255,.08);color:rgba(255,255,255,.25);}
.whom-ul{list-style:none;margin-top:24px;display:flex;flex-direction:column;gap:14px;}
.whom-ul li{display:flex;gap:14px;font-size:.88rem;line-height:1.45;align-items:flex-start;}
.whom-yes .whom-ul li{color:rgba(255,255,255,.62);}
.whom-no .whom-ul li{color:rgba(255,255,255,.22);}
.ico-y{color:#F4B400;font-weight:700;flex-shrink:0;}
.ico-n{color:rgba(255,255,255,.2);font-weight:700;flex-shrink:0;}

/* ── FAQ ──────────────────────────────────────────── */
.faq-h{color:#fff;margin-top:14px;}
.faq-list{margin-top:clamp(36px,5vw,52px);display:flex;flex-direction:column;gap:8px;}
.faq-item{overflow:hidden;}
.faq-btn{
  width:100%;display:flex;justify-content:space-between;align-items:center;
  padding:20px 24px;background:none;border:none;cursor:pointer;
  font-family:'Barlow',sans-serif;font-size:.95rem;font-weight:600;color:#fff;text-align:left;gap:20px;
}
.faq-ico{
  width:26px;height:26px;border:1px solid rgba(255,255,255,.14);border-radius:6px;
  display:flex;align-items:center;justify-content:center;
  font-size:1rem;font-weight:400;flex-shrink:0;
  transition:background .2s,border-color .2s,color .2s;
}
.faq-btn[aria-expanded="true"] .faq-ico{background:#F4B400;border-color:#F4B400;color:#0B0B0B;}
.faq-body{max-height:0;overflow:hidden;transition:max-height .35s ease;}
.faq-body p{font-size:.86rem;color:rgba(255,255,255,.38);line-height:1.8;padding:0 24px 20px;padding-right:66px;}

/* ── CTA Final ────────────────────────────────────── */
.cta-sec{padding:clamp(100px,14vw,160px) 0;text-align:center;position:relative;z-index:1;overflow:hidden;}
.cta-tag{font-family:'Barlow Condensed',sans-serif;font-size:.68rem;letter-spacing:.22em;text-transform:uppercase;color:#F4B400;display:block;margin-bottom:20px;}
.cta-hd{font-family:'Bebas Neue',sans-serif;font-size:clamp(3rem,8vw,7rem);line-height:.88;color:#fff;margin-bottom:40px;}
.cta-price{font-family:'Bebas Neue',sans-serif;font-size:clamp(6rem,18vw,11rem);color:#F4B400;line-height:1;letter-spacing:-.02em;}
.cta-price sup{font-size:2.5rem;vertical-align:super;}
.cta-note{font-size:.7rem;color:rgba(255,255,255,.2);letter-spacing:.1em;text-transform:uppercase;margin-top:8px;margin-bottom:40px;font-weight:500;}
.cta-ul{list-style:none;display:inline-flex;flex-direction:column;gap:10px;text-align:left;margin-bottom:48px;}
.cta-ul li{display:flex;gap:12px;font-size:.86rem;color:rgba(255,255,255,.42);align-items:center;}
.cta-ul li::before{content:'';width:18px;height:1px;background:#F4B400;flex-shrink:0;}
.cta-foot{margin-top:22px;font-size:.7rem;color:rgba(255,255,255,.2);line-height:1.8;max-width:340px;margin-left:auto;margin-right:auto;}

/* ── Button ───────────────────────────────────────── */
.btn{
  display:inline-flex;align-items:center;justify-content:center;
  background:#F4B400;color:#0B0B0B;
  font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1rem;letter-spacing:.14em;text-transform:uppercase;
  padding:18px 56px;border-radius:9999px;text-decoration:none;
  transition:background .15s,transform .15s,box-shadow .15s;
  box-shadow:0 8px 32px rgba(244,180,0,.28);
}
.btn:hover{background:#fff;transform:translateY(-2px);box-shadow:0 14px 44px rgba(244,180,0,.38);}

/* ── Footer ───────────────────────────────────────── */
.foot{border-top:1px solid rgba(255,255,255,.05);padding:40px 24px;text-align:center;position:relative;z-index:1;}
.foot-logo{width:34px;height:auto;opacity:.28;margin:0 auto 16px;display:block;}
.foot-links{display:flex;gap:28px;justify-content:center;margin-bottom:12px;}
.foot-links a{font-size:.66rem;color:rgba(255,255,255,.18);text-decoration:none;letter-spacing:.05em;}
.foot-links a:hover{color:#F4B400;}
.foot-copy{font-size:.63rem;color:rgba(255,255,255,.14);letter-spacing:.04em;}

/* ── Reveal ───────────────────────────────────────── */
.reveal{opacity:0;transform:translateY(18px);transition:opacity .65s ease,transform .65s ease;}
.reveal.in{opacity:1;transform:none;}

/* ── Responsive ───────────────────────────────────── */
@media(max-width:768px){
  .proof-grid{grid-template-columns:repeat(2,1fr);}
  .method-grid,.trfm-grid{grid-template-columns:1fr;}
  .steps{grid-template-columns:1fr;}
  .whom-split{grid-template-columns:1fr;}
}
@media(max-width:480px){
  .inc-row{flex-wrap:wrap;}
  .inc-val{align-self:flex-end;}
}
</style>

<!-- Fixed subtle grid background (Fluxora pattern) -->
<div class="g-bg" aria-hidden="true"></div>

<div class="g">

  <!-- ── HERO ─────────────────────────────────────── -->
  <section class="hero">
    <div class="hero-badge">
      <span class="badge badge-y"><span class="dot"></span>Próxima turma · segunda-feira</span>
    </div>
    <div class="hero-img-wrap">
      <div class="glow hero-glow"></div>
      <img src="/images/hero-desafio.png" alt="Desafio Goleiro de Elite" loading="eager" fetchpriority="high" />
    </div>
  </section>

  <!-- ── VAGAS + COUNTDOWN ─────────────────────────── -->
  <section class="vagas">
    <div class="wrap">
      <div class="card vagas-card reveal">
        <div class="glow" style="width:280px;height:280px;top:50%;left:50%;transform:translate(-50%,-50%);opacity:.18;"></div>
        <div style="margin-bottom:22px">
          <span class="badge badge-y"><span class="dot"></span>Vagas limitadas</span>
        </div>
        <div class="vagas-num"><b>18</b></div>
        <div class="vagas-sub">vagas disponíveis nesta turma</div>
        <div class="vagas-bar"><div class="vagas-fill"></div></div>
        <div class="vagas-slots"><strong>52 de 70</strong> vagas preenchidas</div>
        <div class="vagas-div"></div>
        <div class="vagas-cd-lbl">Próxima turma começa em</div>
        <div class="vagas-cd" id="gde-cd">--:--:--</div>
        <div class="vagas-cd-date" id="gde-date">segunda-feira</div>
      </div>
    </div>
  </section>

  <!-- ── O PROBLEMA ────────────────────────────────── -->
  <section class="sec" style="border-top:1px solid rgba(255,255,255,.05)">
    <div class="wrap">
      <div class="reveal">
        <div class="sh-row">
          <span class="sh-label">O problema</span>
          <span class="sh-num">(01)</span>
        </div>
        <div class="sep"></div>
        <h2 class="h hd-lg pain-h">Você treina.<br>Você se dedica.<br>Mas na hora do jogo…</h2>
      </div>
      <ul class="pain-list reveal" style="transition-delay:.08s">
        <li class="pain-li card card-sm">
          <div class="pain-x">✗</div>
          <span>Pernas que não respondem no momento decisivo</span>
        </li>
        <li class="pain-li card card-sm">
          <div class="pain-x">✗</div>
          <span>Cai e demora pra levantar pra próxima jogada</span>
        </li>
        <li class="pain-li card card-sm">
          <div class="pain-x">✗</div>
          <span>Perde a disputa aérea no segundo tempo</span>
        </li>
        <li class="pain-li card card-sm">
          <div class="pain-x">✗</div>
          <span>Treina na academia mas não melhora no gol</span>
        </li>
        <li class="pain-li card card-sm">
          <div class="pain-x">✗</div>
          <span>Leva gol que sabia que era pra pegar</span>
        </li>
      </ul>
      <div class="pivot card card-sm reveal" style="transition-delay:.14s;border-left:3px solid #F4B400;padding:26px 32px;">
        Não faltou treino. Não faltou esforço.<br>
        <strong>Faltou o tipo certo de treino para goleiro.</strong>
      </div>
    </div>
  </section>

  <!-- ── PROVAS REAIS ───────────────────────────────── -->
  <section class="sec" style="border-top:1px solid rgba(255,255,255,.05)">
    <div class="wrap">
      <div class="reveal">
        <div class="sh-row">
          <span class="sh-label">Resultados reais</span>
          <span class="sh-num">(02)</span>
        </div>
        <div class="sep"></div>
        <h2 class="h hd-lg proof-h">O que muda quando<br>o goleiro treina <span class="yl">certo</span></h2>
      </div>
      <div class="proof-grid reveal" style="transition-delay:.1s">
        <div class="proof-item">
          <img src="/images/carrossel-1.webp" srcset="/images/carrossel-1-420.webp 420w,/images/carrossel-1.webp 900w" sizes="(max-width:768px)50vw,33vw" alt="" loading="lazy" />
          <div class="proof-cap">
            <div class="proof-name">Fabíola Stelzer</div>
            <div class="proof-role">Goleira Amadora · ES</div>
          </div>
        </div>
        <div class="proof-item">
          <img src="/images/carrossel-2.webp" srcset="/images/carrossel-2-420.webp 420w,/images/carrossel-2.webp 900w" sizes="(max-width:768px)50vw,33vw" alt="" loading="lazy" />
