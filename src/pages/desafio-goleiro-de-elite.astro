<script>
  // ── Countdown to next Monday 00:00 BRT ──────────────
  function pad(n) { return String(n).padStart(2, '0'); }

  function nextMonday() {
    const brt = new Date(new Date().toLocaleString('en-US', { timeZone: 'America/Sao_Paulo' }));
    const day = brt.getDay(); // 0=Sun
    const days = day === 0 ? 1 : (8 - day) % 7 || 7;
    const m = new Date(brt);
    m.setDate(brt.getDate() + days);
    m.setHours(0, 0, 0, 0);
    return m;
  }

  function tickCountdown() {
    const now  = new Date(new Date().toLocaleString('en-US', { timeZone: 'America/Sao_Paulo' }));
    const diff = nextMonday() - now;
    if (diff <= 0) { tickCountdown(); return; }
    const d = Math.floor(diff / 86400000);
    const h = Math.floor((diff % 86400000) / 3600000);
    const m = Math.floor((diff % 3600000) / 60000);
    const s = Math.floor((diff % 60000) / 1000);
    const el = document.getElementById('d-countdown');
    if (el) el.textContent = d > 0
      ? `${d} dia${d !== 1 ? 's' : ''} · ${pad(h)}:${pad(m)}:${pad(s)}`
      : `${pad(h)}:${pad(m)}:${pad(s)}`;
  }

  function setNextDate() {
    const m = nextMonday();
    const el = document.getElementById('d-next-date');
    if (el) el.textContent = m.toLocaleDateString('pt-BR', {
      weekday: 'long', day: 'numeric', month: 'long',
      timeZone: 'America/Sao_Paulo'
    });
  }

  tickCountdown();
  setNextDate();
  setInterval(tickCountdown, 1000);

  // ── Scroll reveal ────────────────────────────────────
  const io = new IntersectionObserver(entries => {
    entries.forEach(e => {
      if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); }
    });
  }, { threshold: 0.08 });
  document.querySelectorAll('.reveal').forEach(el => io.observe(el));

  // ── FAQ accordion ────────────────────────────────────
  document.querySelectorAll('.d-faq-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const open = btn.getAttribute('aria-expanded') === 'true';
      document.querySelectorAll('.d-faq-btn').forEach(b => {
        b.setAttribute('aria-expanded', 'false');
        b.nextElementSibling.classList.remove('open');
      });
      if (!open) {
        btn.setAttribute('aria-expanded', 'true');
        btn.nextElementSibling.classList.add('open');
      }
    });
  });

  // ── Sticky CTA mobile (after 30% scroll) ────────────
  const sticky = document.getElementById('d-sticky');
  let ticking = false;
  window.addEventListener('scroll', () => {
    if (!ticking) {
      requestAnimationFrame(() => {
        const pct = window.scrollY / (document.body.scrollHeight - window.innerHeight);
        if (pct > 0.3) sticky.classList.add('show');
        ticking = false;
      });
      ticking = true;
    }
  }, { passive: true });
</script>

