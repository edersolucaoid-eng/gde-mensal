---
import Base from '../layouts/Base.astro';
---
<Base title="Desafio Goleiro de Elite | 5 Dias de Treino Físico Específico para Goleiros">

<!-- Inter font -->
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link rel="preload" as="style"
  href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
  onload="this.onload=null;this.rel='stylesheet'" />
<noscript>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" />
</noscript>

<style is:inline>
/* ── Reset & tokens ─────────────────────────── */
.d {
  --bg:       #0a0a0a;
  --card:     #111111;
  --card2:    #171717;
  --blue:     #60a5fa;
  --blue-d:   #3b82f6;
  --blue-glow:rgba(96,165,250,.22);
  --amber:    #fbbf24;
  --white:    #f5f5f5;
  --muted:    #a1a1aa;
  --border:   rgba(255,255,255,.08);
  --border-m: rgba(255,255,255,.18);
  font-family: 'Inter', ui-sans-serif, system-ui, sans-serif;
  background: var(--bg);
  color: var(--white);
  overflow-x: hidden;
}

/* ── Border-gradient (Fluxora) ──────────────── */
.bg-card {
  position: relative;
  background: linear-gradient(225deg,rgba(255,255,255,.0) 0%,rgba(255,255,255,.04) 50%,rgba(255,255,255,.0) 100%);
}
.bg-card::before {
  content:"";
  position:absolute;
  inset:0;
  border-radius:inherit;
  padding:1px;
  -webkit-mask:linear-gradient(#fff 0 0) content-box,linear-gradient(#fff 0 0);
  -webkit-mask-composite:xor;
  mask-composite:exclude;
  background:linear-gradient(225deg,rgba(255,255,255,.0) 0%,rgba(255,255,255,.18) 50%,rgba(255,255,255,.0) 100%);
  pointer-events:none;
}

/* ── Countdown bar ──────────────────────────── */
.d-bar {
  position:fixed;top:0;left:0;right:0;z-index:100;
  background:rgba(10,10,10,.85);
  backdrop-filter:blur(12px);
  -webkit-backdrop-filter:blur(12px);
  border-bottom:1px solid var(--border);
  display:flex;align-items:center;justify-content:center;
  gap:10px;padding:9px 20px;
  font-size:.72rem;letter-spacing:.04em;color:var(--muted);
}
.d-bar .timer {color:var(--blue);font-weight:600;}
.d-bar .sep   {color:#2a2a2a;}

/* ── Layout ─────────────────────────────────── */
.d-wrap {
  width:100%;max-width:900px;
  margin:0 auto;padding:0 24px;
}
.d-section {
  padding:88px 24px;
  width:100%;max-width:900px;
  margin:0 auto;
}
.d-divider {
  width:100%;max-width:900px;margin:0 auto;
  height:1px;
  background:linear-gradient(to right,transparent,rgba(255,255,255,.06),transparent);
}

/* ── Tag / eyebrow ──────────────────────────── */
.d-tag {
  display:inline-flex;align-items:center;gap:8px;
  background:rgba(255,255,255,.05);
  border:1px solid rgba(255,255,255,.1);
  border-radius:9999px;
  padding:5px 14px;
  font-size:.72rem;font-weight:500;
  color:var(--muted);letter-spacing:.12em;text-transform:uppercase;
  margin-bottom:20px;
}
.d-tag .dot {
  width:6px;height:6px;border-radius:50%;
  background:var(--blue);
  box-shadow:0 0 6px var(--blue);
}

/* ── Titles ─────────────────────────────────── */
.d-title {
  font-size:clamp(2.2rem,6vw,3.8rem);
  font-weight:700;
  line-height:1.05;
  letter-spacing:-.03em;
  color:var(--white);
  margin-bottom:16px;
}
.d-title .hl { color:var(--amber); }
.d-title .bl { color:var(--blue); }

.d-sub {
  font-size:clamp(.95rem,2vw,1.05rem);
  color:var(--muted);
  line-height:1.7;
  font-weight:400;
}

/* ── Buttons ─────────────────────────────────── */
.d-cta {
  display:inline-flex;align-items:center;justify-content:center;gap:10px;
  background:linear-gradient(135deg,var(--blue) 0%,var(--blue-d) 100%);
  color:#000;
  font-size:.95rem;font-weight:600;
  padding:14px 32px;
  border-radius:9999px;border:none;cursor:pointer;
  text-decoration:none;
  box-shadow:0 8px 30px var(--blue-glow);
  transition:opacity .2s,transform .2s;
  -webkit-tap-highlight-color:transparent;
}
.d-cta:hover {opacity:.9;transform:translateY(-2px);}
.d-cta:active{transform:translateY(0);}
.d-cta-lg {font-size:1.05rem;padding:16px 40px;}
.d-cta-full{width:100%;max-width:440px;}
.d-cta-price{font-size:.8rem;font-weight:400;opacity:.8;}
.d-cta-hint {font-size:.72rem;color:#3f3f46;margin-top:10px;text-align:center;letter-spacing:.03em;}

/* ── Hero ────────────────────────────────────── */
.d-hero {
  padding-top:44px;
  min-height:100svh;
  display:flex;align-items:center;
  position:relative;overflow:hidden;
}
.d-hero-blob {
  position:absolute;pointer-events:none;
  border-radius:50%;filter:blur(80px);opacity:.35;
}
.d-hero-blob-1 {
  width:500px;height:500px;
  background:radial-gradient(circle,rgba(96,165,250,.4),transparent 70%);
  top:-120px;right:-80px;
}
.d-hero-blob-2 {
  width:350px;height:350px;
  background:radial-gradient(circle,rgba(251,191,36,.2),transparent 70%);
  bottom:-60px;left:-60px;
}
.d-hero-inner {
  display:grid;
  grid-template-columns:1fr 380px;
  gap:64px;align-items:center;
  padding:64px 24px 56px;
  width:100%;max-width:900px;margin:0 auto;
  position:relative;z-index:1;
}
.d-hero-logo {
  width:88px;height:auto;
  margin-bottom:28px;
  filter:drop-shadow(0 4px 16px rgba(251,191,36,.3));
}
.d-hero-eyebrow {
  font-size:.72rem;font-weight:500;letter-spacing:.14em;
  color:var(--muted);text-transform:uppercase;
  margin-bottom:18px;
}
.d-hero-eyebrow .green-dt{color:var(--blue);}
.d-hero-h1 {
  font-size:clamp(2.8rem,8vw,4.8rem);
  font-weight:700;line-height:1;
  letter-spacing:-.04em;color:var(--white);
  margin-bottom:22px;
}
.d-hero-p {
  font-size:clamp(.95rem,2vw,1.05rem);
  color:var(--muted);line-height:1.7;
  margin-bottom:36px;max-width:460px;
}
.d-hero-img {
  width:100%;height:520px;
  object-fit:cover;object-position:top center;
  border-radius:24px;
  border:1px solid rgba(255,255,255,.08);
  display:block;
}

/* ── Pain section ───────────────────────────── */
.d-pain-list {display:grid;gap:8px;margin-bottom:28px;}
.d-pain-item {
  border-radius:16px;
  padding:16px 20px;
  display:flex;align-items:flex-start;gap:14px;
  backdrop-filter:blur(4px);
}
.d-pain-x {
  width:28px;height:28px;border-radius:50%;
  background:rgba(239,68,68,.12);
  display:flex;align-items:center;justify-content:center;
  color:#f87171;font-weight:700;font-size:.85rem;
  flex-shrink:0;margin-top:1px;
}
.d-pain-txt {font-size:1rem;color:var(--white);line-height:1.55;}
.d-pivot {
  border-radius:16px;
  padding:24px 26px;
  border-left:3px solid var(--blue);
  background:rgba(96,165,250,.06);
  backdrop-filter:blur(8px);
  font-size:clamp(1rem,2.2vw,1.1rem);
  color:var(--white);line-height:1.7;
}
.d-pivot strong{color:var(--amber);}

/* ── Social proof ───────────────────────────── */
.d-proof-grid {
  display:grid;
  grid-template-columns:repeat(3,1fr);
  gap:8px;
}
.d-proof-img {
  width:100%;aspect-ratio:1/1;
  object-fit:cover;border-radius:16px;
  border:1px solid rgba(255,255,255,.06);
  display:block;
  transition:transform .3s,border-color .3s;
}
.d-proof-img:hover{transform:scale(1.02);border-color:rgba(96,165,250,.3);}

/* ── Method ─────────────────────────────────── */
.d-method-grid {display:grid;grid-template-columns:repeat(2,1fr);gap:12px;}
.d-method-card {
  border-radius:24px;
  padding:28px 26px;
  backdrop-filter:blur(8px);
  -webkit-backdrop-filter:blur(8px);
}
.d-method-num {
  font-size:3rem;font-weight:700;
  color:var(--amber);line-height:1;
  letter-spacing:-.04em;
  margin-bottom:14px;
  opacity:.9;
}
.d-method-name {
  font-size:1.1rem;font-weight:600;
  color:var(--white);margin-bottom:10px;
}
.d-method-desc {font-size:.9rem;color:var(--muted);line-height:1.65;}

/* ── Benefits ───────────────────────────────── */
.d-benefit-grid {display:grid;grid-template-columns:repeat(2,1fr);gap:12px;}
.d-benefit-card {
  border-radius:24px;padding:28px 26px;
  backdrop-filter:blur(8px);-webkit-backdrop-filter:blur(8px);
}
.d-benefit-icon {
  width:40px;height:40px;border-radius:12px;
  background:rgba(96,165,250,.12);
  display:flex;align-items:center;justify-content:center;
  color:var(--blue);font-size:.95rem;font-weight:700;
  margin-bottom:16px;
}
.d-benefit-name {font-size:1.05rem;font-weight:600;color:var(--white);margin-bottom:8px;}
.d-benefit-desc {font-size:.88rem;color:var(--muted);line-height:1.65;}

/* ── Included ───────────────────────────────── */
.d-inc-list {display:grid;gap:8px;margin-bottom:16px;}
.d-inc-row {
  border-radius:16px;
  padding:18px 22px;
  display:flex;justify-content:space-between;align-items:center;gap:20px;
  backdrop-filter:blur(4px);-webkit-backdrop-filter:blur(4px);
}
.d-inc-name {font-size:1rem;font-weight:600;color:var(--white);margin-bottom:4px;}
.d-inc-desc {font-size:.82rem;color:var(--muted);}
.d-inc-price {
  font-size:.8rem;color:#3f3f46;
  text-decoration:line-through;white-space:nowrap;font-weight:500;
}
.d-total-row {
  border-radius:16px;padding:20px 22px;
  background:rgba(96,165,250,.06);
  border:1px solid rgba(96,165,250,.15);
  display:flex;align-items:center;justify-content:space-between;
}
.d-total-lbl {font-size:.82rem;color:var(--muted);}
.d-total-was {font-size:.8rem;color:#3f3f46;text-decoration:line-through;font-weight:500;}
.d-total-price {font-size:2.2rem;font-weight:700;color:var(--blue);letter-spacing:-.04em;}

/* ── Offer card ─────────────────────────────── */
.d-offer-wrap {display:flex;justify-content:center;}
.d-offer-card {
  border-radius:28px;
  padding:44px 38px;
  width:100%;max-width:460px;
  text-align:center;
  background:linear-gradient(160deg,rgba(96,165,250,.08) 0%,rgba(96,165,250,.02) 100%);
  border:1px solid rgba(96,165,250,.25);
  box-shadow:0 0 60px rgba(96,165,250,.08);
  backdrop-filter:blur(12px);-webkit-backdrop-filter:blur(12px);
}
.d-offer-badge {
  display:inline-flex;align-items:center;gap:8px;
  background:rgba(96,165,250,.1);
  border:1px solid rgba(96,165,250,.2);
  border-radius:9999px;
  padding:5px 16px;
  font-size:.68rem;font-weight:600;letter-spacing:.14em;text-transform:uppercase;
  color:var(--blue);margin-bottom:28px;
}
.d-offer-price {
  font-size:5.5rem;font-weight:700;letter-spacing:-.05em;
  color:var(--white);line-height:1;margin-bottom:4px;
}
.d-offer-price sup {font-size:2rem;vertical-align:super;color:var(--muted);font-weight:500;}
.d-offer-inst {font-size:.72rem;color:#3f3f46;letter-spacing:.04em;margin-bottom:28px;}
.d-offer-ul {
  list-style:none;text-align:left;
  margin-bottom:30px;display:grid;gap:10px;
}
.d-offer-ul li {
  display:flex;gap:10px;align-items:flex-start;
  font-size:.9rem;color:var(--muted);line-height:1.5;
}
.d-offer-ul li::before {
  content:'✓';color:var(--blue);font-weight:700;flex-shrink:0;margin-top:1px;
}
.d-offer-hint {margin-top:14px;font-size:.68rem;color:#3f3f46;letter-spacing:.04em;}

/* ── For whom ───────────────────────────────── */
.d-whom-grid {display:grid;grid-template-columns:1fr 1fr;gap:12px;}
.d-whom-card {
  border-radius:24px;padding:28px 24px;
  backdrop-filter:blur(8px);-webkit-backdrop-filter:blur(8px);
}
.d-whom-card.yes {
  background:rgba(96,165,250,.05);
  border:1px solid rgba(96,165,250,.15);
}
.d-whom-card.no  {
  background:rgba(239,68,68,.04);
  border:1px solid rgba(239,68,68,.12);
}
.d-whom-head {font-size:1rem;font-weight:600;margin-bottom:20px;}
.d-whom-card.yes .d-whom-head {color:var(--blue);}
.d-whom-card.no  .d-whom-head {color:#f87171;}
.d-whom-ul {list-style:none;display:grid;gap:11px;}
.d-whom-ul li {
  display:flex;align-items:flex-start;gap:10px;
  font-size:.88rem;color:var(--muted);line-height:1.5;
}
.ico-yes {color:var(--blue);font-weight:700;flex-shrink:0;}
.ico-no  {color:#f87171;font-weight:700;flex-shrink:0;}

/* ── FAQ ─────────────────────────────────────── */
.d-faq-list {display:grid;gap:6px;}
.d-faq-item {
  border-radius:16px;overflow:hidden;
  backdrop-filter:blur(4px);-webkit-backdrop-filter:blur(4px);
}
.d-faq-btn {
  width:100%;background:none;border:none;
  padding:18px 22px;
  display:flex;justify-content:space-between;align-items:center;gap:14px;
  cursor:pointer;color:var(--white);
  font-family:'Inter',sans-serif;
  font-size:.95rem;font-weight:500;text-align:left;
  -webkit-tap-highlight-color:transparent;
}
.d-faq-icon {
  width:24px;height:24px;border-radius:50%;
  background:rgba(96,165,250,.12);
  display:flex;align-items:center;justify-content:center;
  color:var(--blue);font-size:1rem;font-weight:400;
  flex-shrink:0;
  transition:transform .28s ease,background .2s;
}
.d-faq-btn[aria-expanded="true"] .d-faq-icon {
  transform:rotate(45deg);
  background:rgba(96,165,250,.22);
}
.d-faq-body {
  max-height:0;overflow:hidden;
  transition:max-height .32s ease,padding .32s ease;
  padding:0 22px;
}
.d-faq-body.open {max-height:280px;padding:0 22px 18px;}
.d-faq-body p {font-size:.9rem;color:var(--muted);line-height:1.7;}

/* ── Footer ──────────────────────────────────── */
.d-footer {
  width:100%;max-width:900px;margin:0 auto;
  padding:56px 24px 40px;
  border-top:1px solid rgba(255,255,255,.05);
  text-align:center;
}
.d-footer-logo {
  width:56px;height:auto;
  margin:0 auto 16px;
  opacity:.35;
  filter:grayscale(1);
}
.d-footer-links {
  display:flex;justify-content:center;flex-wrap:wrap;gap:20px;margin-bottom:14px;
}
.d-footer-links a {
  font-size:.72rem;color:#3f3f46;text-decoration:none;letter-spacing:.04em;
  transition:color .2s;
}
.d-footer-links a:hover {color:var(--muted);}
.d-footer-copy {font-size:.68rem;color:#2a2a2a;letter-spacing:.04em;}

/* ── Sticky CTA ──────────────────────────────── */
.d-sticky {
  display:none;
  position:fixed;bottom:0;left:0;right:0;z-index:200;
  background:rgba(10,10,10,.92);
  border-top:1px solid rgba(255,255,255,.06);
  padding:12px 20px;
  backdrop-filter:blur(12px);-webkit-backdrop-filter:blur(12px);
}
.d-sticky.show {display:block;}

/* ── Reveal ──────────────────────────────────── */
.reveal {
  opacity:0;
  transform:translateY(24px);
  filter:blur(4px);
  transition:opacity .6s ease,transform .6s ease,filter .6s ease;
}
.reveal.in {opacity:1;transform:translateY(0);filter:blur(0);}

/* ── Responsive ──────────────────────────────── */
@media (max-width:720px) {
  .d-hero-inner      {grid-template-columns:1fr;padding:52px 20px 44px;gap:0;}
  .d-hero-img-wrap   {display:none;}
  .d-hero-logo       {width:72px;}
  .d-proof-grid      {grid-template-columns:repeat(2,1fr);}
  .d-method-grid     {grid-template-columns:1fr;}
  .d-benefit-grid    {grid-template-columns:1fr;}
  .d-whom-grid       {grid-template-columns:1fr;}
  .d-offer-card      {padding:30px 20px;}
  .d-offer-price     {font-size:4.5rem;}
  .d-inc-row         {flex-direction:column;align-items:flex-start;gap:6px;}
  .d-section         {padding:64px 20px;}
  .d-sticky.show     {display:block;}
}
</style>

<div class="d">

  <!-- COUNTDOWN BAR -->
  <div class="d-bar">
    <span>Próxima turma abre em</span>
    <span class="timer" id="d-countdown">--:--:--</span>
    <span class="sep">·</span>
    <span>segunda-feira · 00h BRT</span>
  </div>

  <!-- HERO -->
  <section class="d-hero">
    <div class="d-hero-blob d-hero-blob-1"></div>
    <div class="d-hero-blob d-hero-blob-2"></div>
    <div class="d-hero-inner">
      <div class="reveal">
        <img src="/images/logo-gde.png" alt="Goleiro de Elite" class="d-hero-logo" />
        <p class="d-hero-eyebrow">
          Próxima turma: <span class="green-dt" id="d-next-date">segunda-feira</span>
        </p>
        <h1 class="d-hero-h1">
          Você sabe quando<br>era pra pegar<br>e não pegou.
        </h1>
        <p class="d-hero-p">
          Suas pernas não responderam. Você treinou a semana inteira e mesmo assim. Esse desafio é pra atacar o que falta: explosão real, treinada do jeito certo pra goleiro.
        </p>
        <div>
          <a href="#checkout" class="d-cta d-cta-lg d-cta-full">
            Quero entrar no desafio
            <span class="d-cta-price">— R$ 35</span>
          </a>
          <p class="d-cta-hint">Pagamento único · Acesso imediato · 5 dias ao vivo</p>
        </div>
      </div>
      <div class="d-hero-img-wrap reveal" style="transition-delay:.2s">
        <img
          src="/images/hero-professor.webp"
          srcset="/images/hero-professor-480.webp 480w, /images/hero-professor.webp 900w"
          sizes="380px"
          alt="Pedro Ferreira — Preparador físico Goleiro de Elite"
          class="d-hero-img"
          loading="eager" fetchpriority="high"
        />
      </div>
    </div>
  </section>

  <div class="d-divider"></div>

  <!-- O PROBLEMA -->
  <section class="d-section">
    <div class="reveal">
      <div class="d-tag"><span class="dot"></span>O problema</div>
      <h2 class="d-title">Você treina. Você se dedica.<br>Mas na hora do jogo…</h2>
    </div>
    <div class="d-pain-list" style="margin-top:36px">
      <div class="d-pain-item bg-card reveal">
        <div class="d-pain-x">✗</div>
        <span class="d-pain-txt">Suas pernas não respondem no momento decisivo</span>
      </div>
      <div class="d-pain-item bg-card reveal" style="transition-delay:.06s">
        <div class="d-pain-x">✗</div>
        <span class="d-pain-txt">Você cai e demora pra levantar pra próxima jogada</span>
      </div>
      <div class="d-pain-item bg-card reveal" style="transition-delay:.1s">
        <div class="d-pain-x">✗</div>
        <span class="d-pain-txt">No segundo tempo você perde a disputa aérea que no primeiro pegava</span>
      </div>
      <div class="d-pain-item bg-card reveal" style="transition-delay:.14s">
        <div class="d-pain-x">✗</div>
        <span class="d-pain-txt">Você treina na academia toda semana mas a melhora no gol não aparece</span>
      </div>
      <div class="d-pain-item bg-card reveal" style="transition-delay:.18s">
        <div class="d-pain-x">✗</div>
        <span class="d-pain-txt">Você leva gol que sabia que era pra pegar</span>
      </div>
    </div>
    <div class="d-pivot reveal">
      Não faltou treino. Não faltou esforço. Não faltou técnica.<br>
      <strong>Faltou o tipo certo de treino para goleiro.</strong>
    </div>
  </section>

  <div class="d-divider"></div>

  <!-- PROVAS REAIS -->
  <section class="d-section">
    <div class="reveal">
      <div class="d-tag"><span class="dot"></span>Resultados reais</div>
      <h2 class="d-title">O que acontece quando<br>o goleiro treina <span class="bl">do jeito certo</span></h2>
    </div>
    <div class="d-proof-grid reveal" style="margin-top:36px;transition-delay:.1s">
      <img src="/images/carrossel-1.webp"
           srcset="/images/carrossel-1-420.webp 420w,/images/carrossel-1.webp 900w"
           sizes="(max-width:720px) 50vw,33vw"
           alt="Resultado goleiro" class="d-proof-img" loading="lazy" />
      <img src="/images/carrossel-2.webp"
           srcset="/images/carrossel-2-420.webp 420w,/images/carrossel-2.webp 900w"
           sizes="(max-width:720px) 50vw,33vw"
