---
import Base from '../layouts/Base.astro';
---
<Base title="Desafio Goleiro de Elite | 5 Dias de Treino Físico Específico para Goleiros">
<style>
@import url('https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Montserrat:wght@400;500;600;700;800&display=swap');

.d *{box-sizing:border-box;margin:0;padding:0;}
.d{font-family:'Montserrat',sans-serif;background:#fff;color:#0B0B0B;overflow-x:hidden;}

/* ── Layout ─────────────────────────────────────── */
.d-sec{padding:clamp(72px,10vw,120px) 24px;}
.d-wrap{max-width:960px;margin:0 auto;}
.d-wrap-sm{max-width:640px;margin:0 auto;}
.d-dark{background:#0B0B0B;color:#fff;}
.d-gray{background:#F5F5F5;}

/* ── Tag ─────────────────────────────────────────── */
.d-tag{
  display:inline-flex;align-items:center;gap:10px;
  font-size:.65rem;font-weight:700;letter-spacing:.18em;
  text-transform:uppercase;color:#F4B400;
  margin-bottom:20px;
}
.d-tag::before{content:'';display:block;width:20px;height:2px;background:#F4B400;}

/* ── Titles ──────────────────────────────────────── */
.d-h2{
  font-family:'Bebas Neue',sans-serif;
  font-size:clamp(2.8rem,6vw,4.4rem);
  line-height:.95;letter-spacing:.02em;
  color:#0B0B0B;margin-bottom:0;
}
.d-h2-w{color:#fff;}
.d-yl{color:#F4B400;}
.d-lead{
  font-size:1rem;color:#666;line-height:1.7;
  margin-top:20px;max-width:520px;
}
.d-lead-w{color:#888;}

/* ── Section head block ──────────────────────────── */
.d-head{margin-bottom:56px;}

/* ── Yellow accent ───────────────────────────────── */
.d-bar{display:none;}

/* ── HERO ────────────────────────────────────────── */
.d-hero{background:#fff;display:flex;justify-content:center;}
.d-hero img{width:100%;max-width:520px;height:auto;display:block;}

/* ── Grain overlay (dark sections) ──────────────── */
.d-grain{position:relative;}
.d-grain::after{
  content:'';pointer-events:none;
  position:absolute;inset:0;z-index:1;
  background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='1'/%3E%3C/svg%3E");
  background-size:200px 200px;
  opacity:.028;mix-blend-mode:overlay;
}
.d-grain > *{position:relative;z-index:2;}

/* ── VAGAS ───────────────────────────────────────── */
.d-vagas{background:#0B0B0B;padding:64px 24px;text-align:center;}
.d-vagas-in{max-width:440px;margin:0 auto;}
.d-badge{
  display:inline-flex;align-items:center;gap:8px;
  background:rgba(244,180,0,.1);border:1px solid rgba(244,180,0,.35);
  border-radius:3px;padding:7px 18px;
  color:#F4B400;font-size:.65rem;font-weight:700;
  letter-spacing:.18em;text-transform:uppercase;margin-bottom:32px;
}
.d-vagas-num{
  font-family:'Bebas Neue',sans-serif;
  font-size:7rem;line-height:1;color:#fff;
  letter-spacing:-.02em;
}
.d-vagas-sub{
  font-size:.72rem;letter-spacing:.14em;text-transform:uppercase;
  color:#444;margin-top:6px;margin-bottom:24px;
}
.d-progress{background:rgba(255,255,255,.07);border-radius:100px;height:4px;overflow:hidden;margin-bottom:10px;}
.d-progress-fill{height:100%;background:#F4B400;border-radius:100px;width:74%;}
.d-slots{font-size:.75rem;color:#444;margin-bottom:48px;}
.d-slots strong{color:#F4B400;font-weight:700;}
.d-sep{width:40px;height:1px;background:rgba(255,255,255,.12);margin:0 auto 48px;}
.d-cd-lbl{font-size:.65rem;letter-spacing:.16em;text-transform:uppercase;color:#444;margin-bottom:14px;}
.d-cd-num{
  font-family:'Bebas Neue',sans-serif;
  font-size:4rem;letter-spacing:.04em;color:#fff;line-height:1;
}
.d-cd-date{font-size:.75rem;color:#444;margin-top:10px;}

/* ── PAIN ────────────────────────────────────────── */
.d-pain-grid{display:grid;gap:6px;margin-bottom:40px;}
.d-pain-row{
  display:flex;align-items:center;gap:18px;
  padding:18px 22px;background:#F5F5F5;
  border-left:3px solid transparent;
  transition:border-color .2s,background .2s;
}
.d-pain-row:hover{border-left-color:#F4B400;background:#efefef;}
.d-px{
  width:24px;height:24px;border-radius:50%;
  background:#0B0B0B;color:#F4B400;
  display:flex;align-items:center;justify-content:center;
  font-weight:800;font-size:.7rem;flex-shrink:0;
}
.d-pain-row span{font-size:.92rem;font-weight:600;color:#222;}
.d-pivot{
  background:#0B0B0B;padding:28px 32px;
  font-size:.95rem;color:#888;line-height:1.75;
}
.d-pivot strong{color:#F4B400;}

/* ── PROOF ───────────────────────────────────────── */
.d-proof-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;}
.d-proof-item{display:flex;flex-direction:column;gap:10px;}
.d-proof-img{
  width:100%;aspect-ratio:1/1;object-fit:cover;display:block;
  border-radius:4px;
  transition:transform .3s;
}
.d-proof-img:hover{transform:scale(1.02);}
.d-proof-name{font-size:.85rem;font-weight:700;color:#0B0B0B;}
.d-proof-role{font-size:.72rem;color:#999;margin-top:2px;}

/* ── METHOD ──────────────────────────────────────── */
.d-method-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:24px;}
.d-mcard{
  padding:36px 32px;
  border-top:2px solid #F4B400;
  background:rgba(255,255,255,.05);
  border:1px solid rgba(255,255,255,.08);
  border-top:2px solid #F4B400;
}
.d-mnum{
  font-family:'Bebas Neue',sans-serif;
  font-size:3rem;color:#F4B400;line-height:1;margin-bottom:16px;
}
.d-mname{font-size:1rem;font-weight:700;color:#fff;margin-bottom:16px;}
.d-mbullets{list-style:none;display:flex;flex-direction:column;gap:8px;}
.d-mbullets li{
  font-size:.82rem;color:#666;
  display:flex;align-items:center;gap:10px;
}
.d-mbullets li::before{content:'—';color:#F4B400;flex-shrink:0;}

/* ── BENEFITS ────────────────────────────────────── */
.d-blist{display:flex;flex-direction:column;gap:0;border-top:1px solid #E5E5E5;}
.d-brow{
  display:grid;grid-template-columns:64px 1fr;
  gap:28px;align-items:start;
  padding:36px 0;border-bottom:1px solid #E5E5E5;
}
.d-bnum{
  font-family:'Bebas Neue',sans-serif;
  font-size:3.8rem;color:#F4B400;line-height:1;padding-top:0;
  opacity:.9;
}
.d-bname{font-size:1rem;font-weight:700;color:#0B0B0B;margin-bottom:8px;}
.d-bbullets{list-style:none;display:flex;flex-direction:column;gap:6px;}
.d-bbullets li{
  font-size:.85rem;color:#666;
  display:flex;gap:10px;align-items:flex-start;
}
.d-bbullets li::before{content:'—';color:#F4B400;flex-shrink:0;margin-top:1px;}

/* ── INCLUDED ────────────────────────────────────── */
.d-inc-list{border:1px solid #E5E5E5;overflow:hidden;}
.d-inc-row{
  display:flex;justify-content:space-between;align-items:center;
  padding:20px 24px;background:#fff;border-bottom:1px solid #E5E5E5;
}
.d-inc-row:last-child{border-bottom:none;}
.d-inc-name{font-size:.9rem;font-weight:700;color:#0B0B0B;}
.d-inc-desc{font-size:.75rem;color:#999;margin-top:3px;}
.d-inc-val{font-size:.8rem;color:#ccc;text-decoration:line-through;white-space:nowrap;margin-left:20px;flex-shrink:0;}
.d-total{
  display:flex;justify-content:space-between;align-items:center;
  padding:22px 24px;background:#0B0B0B;
}
.d-total-lbl{font-size:.6rem;color:#555;letter-spacing:.1em;text-transform:uppercase;}
.d-total-was{font-size:.9rem;color:#555;text-decoration:line-through;margin-top:4px;}
.d-total-price{
  font-family:'Bebas Neue',sans-serif;
  font-size:3.4rem;color:#F4B400;line-height:1;
}

/* ── ACCESS ──────────────────────────────────────── */
.d-steps{display:flex;flex-direction:column;border-top:1px solid #E5E5E5;max-width:560px;}
.d-step{
  display:flex;gap:24px;align-items:flex-start;
  padding:32px 0;border-bottom:1px solid #E5E5E5;
}
.d-step:last-child{border-bottom:none;}
.d-snum{
  font-family:'Bebas Neue',sans-serif;font-size:1.2rem;
  width:40px;height:40px;border-radius:50%;
  background:#0B0B0B;color:#F4B400;
  display:flex;align-items:center;justify-content:center;flex-shrink:0;
}
.d-stitle{font-size:.95rem;font-weight:700;color:#0B0B0B;margin-bottom:6px;}
.d-sdesc{font-size:.83rem;color:#888;line-height:1.6;}

/* ── WHOM ────────────────────────────────────────── */
.d-whom-grid{display:grid;grid-template-columns:1fr 1fr;gap:16px;}
.d-wcard{padding:36px 32px;}
.d-wcard.yes{background:#0B0B0B;border-top:3px solid #F4B400;}
.d-wcard.no{background:#F5F5F5;border-top:3px solid #0B0B0B;}
.d-whead{
  font-family:'Bebas Neue',sans-serif;
  font-size:1.3rem;letter-spacing:.04em;margin-bottom:24px;
}
.d-wcard.yes .d-whead{color:#fff;}
.d-wcard.no .d-whead{color:#0B0B0B;}
.d-wul{list-style:none;display:flex;flex-direction:column;gap:14px;}
.d-wul li{font-size:.85rem;display:flex;gap:12px;line-height:1.5;align-items:flex-start;}
.d-wcard.yes .d-wul li{color:#aaa;}
.d-wcard.no .d-wul li{color:#555;}
.ico-yes{color:#F4B400;font-weight:800;flex-shrink:0;margin-top:1px;}
.ico-no{color:#0B0B0B;font-weight:800;flex-shrink:0;margin-top:1px;}

/* ── FAQ ─────────────────────────────────────────── */
.d-faq{display:flex;flex-direction:column;border-top:1px solid #E5E5E5;}
.d-faq-item{border-bottom:1px solid #E5E5E5;}
.d-faq-btn{
  width:100%;display:flex;justify-content:space-between;align-items:center;
  padding:22px 0;background:none;border:none;cursor:pointer;
  font-family:'Montserrat',sans-serif;
  font-size:.9rem;font-weight:600;color:#0B0B0B;
  text-align:left;gap:16px;
}
.d-faq-icon{
  width:30px;height:30px;border:2px solid #0B0B0B;border-radius:50%;
  display:flex;align-items:center;justify-content:center;
  font-size:.85rem;font-weight:700;flex-shrink:0;
  transition:background .2s,border-color .2s;
}
.d-faq-btn[aria-expanded="true"] .d-faq-icon{background:#F4B400;border-color:#F4B400;}
.d-faq-body{max-height:0;overflow:hidden;transition:max-height .35s ease;}
.d-faq-body p{font-size:.85rem;color:#666;line-height:1.8;padding-bottom:22px;}

/* ── CTA FINAL ───────────────────────────────────── */
.d-cta-sec{background:#0B0B0B;padding:clamp(72px,10vw,120px) 24px;text-align:center;}
.d-cta-in{max-width:520px;margin:0 auto;}
.d-cta-badge{
  display:inline-flex;align-items:center;gap:8px;
  border:1px solid rgba(244,180,0,.3);border-radius:3px;
  padding:7px 18px;color:#F4B400;
  font-size:.65rem;font-weight:700;letter-spacing:.18em;text-transform:uppercase;
  margin-bottom:32px;
}
.d-price{
  font-family:'Bebas Neue',sans-serif;
  font-size:6rem;line-height:1;color:#fff;
}
.d-price sup{font-size:2.2rem;vertical-align:super;}
.d-price-note{font-size:.72rem;color:#444;margin-top:8px;margin-bottom:40px;letter-spacing:.06em;}
.d-cta-ul{
  list-style:none;display:flex;flex-direction:column;gap:12px;
  margin-bottom:40px;text-align:left;
  max-width:360px;margin-left:auto;margin-right:auto;
}
.d-cta-ul li{display:flex;gap:12px;font-size:.85rem;color:#888;align-items:flex-start;line-height:1.5;}
.d-cta-ul li::before{content:'—';color:#F4B400;flex-shrink:0;}
.d-cta-note{margin-top:24px;font-size:.73rem;color:#333;line-height:1.7;max-width:360px;margin-left:auto;margin-right:auto;}

/* ── BUTTON ──────────────────────────────────────── */
.d-btn{
  display:inline-flex;align-items:center;justify-content:center;
  background:#F4B400;color:#0B0B0B;
  font-family:'Montserrat',sans-serif;
  font-weight:800;font-size:1rem;letter-spacing:.02em;
  padding:20px 52px;border-radius:4px;
  text-decoration:none;
  transition:background .2s,transform .2s,box-shadow .2s;
}
.d-btn:hover{
  background:#fff;
  transform:translateY(-2px);
  box-shadow:0 8px 24px rgba(244,180,0,.25);
}

/* ── FOOTER ──────────────────────────────────────── */
.d-footer{
  background:#0B0B0B;padding:40px 24px;text-align:center;
  border-top:1px solid rgba(255,255,255,.05);
}
.d-footer-logo{width:40px;height:auto;margin-bottom:16px;opacity:.55;}
.d-footer-links{display:flex;gap:28px;justify-content:center;margin-bottom:12px;}
.d-footer-links a{font-size:.7rem;color:#555;text-decoration:none;}
.d-footer-links a:hover{color:#F4B400;}
.d-footer-copy{font-size:.68rem;color:#444;}

/* ── Reveal ──────────────────────────────────────── */
.reveal{opacity:0;transform:translateY(22px);transition:opacity .55s ease,transform .55s ease;}
.reveal.in{opacity:1;transform:none;}

/* ── Responsive ──────────────────────────────────── */
@media(max-width:720px){
  .d-proof-grid{grid-template-columns:repeat(2,1fr);}
  .d-method-grid{grid-template-columns:1fr;}
  .d-whom-grid{grid-template-columns:1fr;}
  .d-price{font-size:4.5rem;}
  .d-brow{grid-template-columns:52px 1fr;gap:16px;}
}
</style>

<div class="d">

  <!-- HERO -->
  <section class="d-hero">
    <img src="/images/hero-desafio.png" alt="Desafio Goleiro de Elite" loading="eager" fetchpriority="high" />
  </section>

  <!-- VAGAS + COUNTDOWN -->
  <section class="d-vagas d-grain">
    <div class="d-vagas-in">
      <div class="d-badge">⚡ Vagas Limitadas</div>
      <div class="d-vagas-num">70</div>
      <div class="d-vagas-sub">goleiros por turma</div>
      <div class="d-progress"><div class="d-progress-fill"></div></div>
      <div class="d-slots"><strong>52 vagas ocupadas</strong> · 18 disponíveis</div>
      <div class="d-sep"></div>
      <div class="d-cd-lbl">Próxima turma começa em</div>
      <div class="d-cd-num" id="d-countdown">--:--:--</div>
      <div class="d-cd-date" id="d-next-date">segunda-feira</div>
    </div>
  </section>

  <!-- O PROBLEMA -->
  <section class="d-sec">
    <div class="d-wrap">
      <div class="d-head reveal">
        <div class="d-tag">O problema</div>
        <h2 class="d-h2">Você treina.<br>Você se dedica.<br>Mas na hora do jogo…</h2>
        <div class="d-bar"></div>
      </div>
      <div class="d-pain-grid reveal" style="transition-delay:.08s">
        <div class="d-pain-row"><div class="d-px">✗</div><span>Pernas que não respondem no momento decisivo</span></div>
        <div class="d-pain-row"><div class="d-px">✗</div><span>Cai e demora pra levantar pra próxima jogada</span></div>
        <div class="d-pain-row"><div class="d-px">✗</div><span>Perde a disputa aérea no segundo tempo</span></div>
        <div class="d-pain-row"><div class="d-px">✗</div><span>Treina na academia mas não melhora no gol</span></div>
        <div class="d-pain-row"><div class="d-px">✗</div><span>Leva gol que sabia que era pra pegar</span></div>
      </div>
      <div class="d-pivot reveal" style="transition-delay:.14s">
        Não faltou treino. Não faltou esforço.<br>
        <strong>Faltou o tipo certo de treino para goleiro.</strong>
      </div>
    </div>
  </section>

  <!-- PROVAS REAIS -->
  <section class="d-sec d-gray">
    <div class="d-wrap">
      <div class="d-head reveal">
        <div class="d-tag">Resultados reais</div>
        <h2 class="d-h2">O que muda quando<br>o goleiro treina <span class="d-yl">certo</span></h2>
      </div>
      <div class="d-proof-grid reveal" style="transition-delay:.1s">
        <div class="d-proof-item">
          <img src="/images/carrossel-1.webp" srcset="/images/carrossel-1-420.webp 420w,/images/carrossel-1.webp 900w" sizes="(max-width:720px) 50vw,33vw" alt="" class="d-proof-img" loading="lazy" />
          <div class="d-proof-name">Fabíola Stelzer</div>
          <div class="d-proof-role">Goleira Amadora · ES</div>
        </div>
        <div class="d-proof-item">
          <img src="/images/carrossel-2.webp" srcset="/images/carrossel-2-420.webp 420w,/images/carrossel-2.webp 900w" sizes="(max-width:720px) 50vw,33vw" alt="" class="d-proof-img" loading="lazy" />
          <div class="d-proof-name">Rafael S.</div>
          <div class="d-proof-role">Goleiro Profissional</div>
        </div>
        <div class="d-proof-item">
          <img src="/images/carrossel-3.webp" srcset="/images/carrossel-3-420.webp 420w,/images/carrossel-3.webp 900w" sizes="(max-width:720px) 50vw,33vw" alt="" class="d-proof-img" loading="lazy" />
          <div class="d-proof-name">Diego A.</div>
          <div class="d-proof-role">Goleiro de Base · MG</div>
        </div>
        <div class="d-proof-item">
          <img src="/images/carrossel-4.webp" srcset="/images/carrossel-4-420.webp 420w,/images/carrossel-4.webp 900w" sizes="(max-width:720px) 50vw,33vw" alt="" class="d-proof-img" loading="lazy" />
          <div class="d-proof-name">Thiago R.</div>
          <div class="d-proof-role">Goleiro Amador · PR</div>
        </div>
        <div class="d-proof-item">
          <img src="/images/carrossel-5.webp" srcset="/images/carrossel-5-420.webp 420w,/images/carrossel-5.webp 900w" sizes="(max-width:720px) 50vw,33vw" alt="" class="d-proof-img" loading="lazy" />
          <div class="d-proof-name">Matheus F.</div>
          <div class="d-proof-role">Goleiro Aspirante · RS</div>
        </div>
        <div class="d-proof-item">
          <img src="/images/carrossel-6.webp" srcset="/images/carrossel-6-420.webp 420w,/images/carrossel-6.webp 900w" sizes="(max-width:720px) 50vw,33vw" alt="" class="d-proof-img" loading="lazy" />
          <div class="d-proof-name">Bruno C.</div>
          <div class="d-proof-role">Goleiro Universitário · BA</div>
        </div>
      </div>
    </div>
  </section>

  <!-- O MÉTODO (dark) -->
  <section class="d-sec d-dark d-grain">
    <div class="d-wrap">
      <div class="d-head reveal">
        <div class="d-tag">O método</div>
        <h2 class="d-h2 d-h2-w">5 dias. Treino físico.<br><span class="d-yl">Específico para goleiro.</span></h2>
      </div>
      <div class="d-method-grid">
        <div class="d-mcard reveal">
          <div class="d-mnum">01</div>
          <div class="d-mname">Treino específico</div>
          <ul class="d-mbullets">
            <li>Explosão, força e velocidade</li>
            <li>Sem bola, sem técnica</li>
            <li>Só o que decide no jogo</li>
          </ul>
        </div>
        <div class="d-mcard reveal" style="transition-delay:.08s">
          <div class="d-mnum">02</div>
          <div class="d-mname">Acompanhamento ao vivo</div>
          <ul class="d-mbullets">
            <li>Treinadores certificados</li>
            <li>Correção por vídeo</li>
            <li>5 dias de suporte direto</li>
          </ul>
        </div>
        <div class="d-mcard reveal" style="transition-delay:.14s">
          <div class="d-mnum">03</div>
          <div class="d-mname">Menu nutricional</div>
          <ul class="d-mbullets">
            <li>Plano alimentar específico</li>
            <li>Simples e prático</li>
            <li>Otimizado para os 5 dias</li>
          </ul>
        </div>
        <div class="d-mcard reveal" style="transition-delay:.2s">
          <div class="d-mnum">04</div>
          <div class="d-mname">Ciclo semanal</div>
          <ul class="d-mbullets">
            <li>Treino liberado na véspera</li>
            <li>Academia ou em casa</li>
            <li>Nova turma toda segunda</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- TRANSFORMAÇÃO -->
  <section class="d-sec">
    <div class="d-wrap">
      <div class="d-head reveal">
        <div class="d-tag">A transformação</div>
        <h2 class="d-h2">Depois de 5 dias,<br>o que muda no seu jogo</h2>
        <div class="d-bar"></div>
      </div>
      <div class="d-blist reveal" style="transition-delay:.08s">
        <div class="d-brow">
          <div class="d-bnum">01</div>
